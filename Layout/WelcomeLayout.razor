@inherits LayoutComponentBase

<div class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-md bg-primary" data-bs-theme="dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-semibold" href="/">Simply Job Application</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Welcome</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/evaluate">Evaluate &amp; Generate</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/history">History</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/files">Files</NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/settings">Settings</NavLink>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        @Body
    </main>

    <footer class="text-center text-muted py-2 small border-top">
        Simply Job Application — all data stored locally in your browser
    </footer>
</div>
