@page "/opportunities"
@inject IIndexedDbService Db
@inject IDataSyncService DataSync
@inject NavigationManager Nav
@implements IDisposable
@using System.Text.RegularExpressions

<PageTitle>Opportunities — Simply Job Application</PageTitle>

<h4 class="mb-3">Opportunities</h4>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else if (_opportunities.Count == 0)
{
    <div class="alert alert-secondary">
        No opportunities yet — add one from an Organization page to get started
    </div>
}
else
{
    <div class="mb-3">
        <input class="form-control" style="max-width:360px"
               placeholder="Filter opportunities…"
               @bind="_filter" @bind:event="oninput" />
    </div>

    @if (Filtered.Count == 0)
    {
        <div class="text-muted">No opportunities match your filter.</div>
    }
    else
    {
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Organization</th>
                    <th>Role</th>
                    <th>Stage</th>
                    <th>Work Arrangement</th>
                    <th>Compensation</th>
                    <th style="width:120px">Created</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var opp in Filtered)
                {
                    var orgName = OrgName(opp.OrganizationId);
                    <tr style="cursor:pointer" @onclick="() => NavigateToOpp(opp.Id)">
                        <td>
                            <a href="/organizations/@opp.OrganizationId" @onclick:stopPropagation>
                                @Highlight(orgName)
                            </a>
                        </td>
                        <td class="fw-semibold">@Highlight(opp.Role)</td>
                        <td><span class="badge bg-secondary">@StageName(opp.Stage)</span></td>
                        <td class="text-muted small">
                            @Highlight(opp.WorkArrangement is null ? "—" : WorkArrangementLabel(opp.WorkArrangement.Value))
                        </td>
                        <td class="text-muted small">
                            @Highlight(string.IsNullOrWhiteSpace(opp.CompensationRange) ? "—" : opp.CompensationRange)
                        </td>
                        <td class="text-muted small">@opp.CreatedAt.ToLocalTime().ToString("d")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private List<Opportunity> _opportunities = new();
    private Dictionary<string, string> _orgNames = new();
    private string _filter = "";
    private bool _loading = true;

    private List<Opportunity> Filtered => string.IsNullOrWhiteSpace(_filter)
        ? _opportunities
        : _opportunities.Where(o =>
            Contains(OrgName(o.OrganizationId), _filter) ||
            Contains(o.Role, _filter) ||
            Contains(StageName(o.Stage), _filter) ||
            Contains(o.WorkArrangement is null ? "" : WorkArrangementLabel(o.WorkArrangement.Value), _filter) ||
            Contains(o.CompensationRange, _filter))
          .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        DataSync.OnOpportunityChanged += HandleOpportunityChanged;
        DataSync.OnOrganizationChanged += HandleOrgChanged;
    }

    public void Dispose()
    {
        DataSync.OnOpportunityChanged -= HandleOpportunityChanged;
        DataSync.OnOrganizationChanged -= HandleOrgChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var opps = await Db.GetAllOpportunitiesAsync();
        _opportunities = opps.OrderByDescending(o => o.CreatedAt).ToList();
        var orgs = await Db.GetAllOrganizationsAsync();
        _orgNames = orgs.ToDictionary(o => o.Id, o => o.Name);
        _loading = false;
    }

    private void HandleOpportunityChanged(string? id, string @event)
    {
        InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    }

    private void HandleOrgChanged(string? id, string @event)
    {
        InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    }

    private string OrgName(string orgId) =>
        _orgNames.TryGetValue(orgId, out var name) ? name : orgId;

    private static bool Contains(string? source, string term) =>
        source?.Contains(term, StringComparison.OrdinalIgnoreCase) ?? false;

    private RenderFragment Highlight(string text) => builder =>
    {
        if (string.IsNullOrWhiteSpace(_filter) || string.IsNullOrWhiteSpace(text))
        {
            builder.AddContent(0, text);
            return;
        }
        var idx = text.IndexOf(_filter, StringComparison.OrdinalIgnoreCase);
        if (idx < 0) { builder.AddContent(0, text); return; }

        var seq = 0;
        builder.AddContent(seq++, text[..idx]);
        builder.OpenElement(seq++, "mark");
        builder.AddAttribute(seq++, "class", "p-0");
        builder.AddContent(seq++, text.Substring(idx, _filter.Length));
        builder.CloseElement();
        builder.AddContent(seq++, text[(idx + _filter.Length)..]);
    };

    private static string StageName(OpportunityStage stage) => stage switch
    {
        OpportunityStage.NotInterested => "Not Interested",
        OpportunityStage.NotQualified  => "Not Qualified",
        OpportunityStage.InProgress    => "In Progress",
        _ => stage.ToString(),
    };

    private static string WorkArrangementLabel(WorkArrangement wa) => wa switch
    {
        WorkArrangement.OnSite => "On-site",
        _ => wa.ToString(),
    };

    private void NavigateToOpp(string id) => Nav.NavigateTo("/opportunities/" + id);
}
