@page "/evaluate"
@inherits NavigationGuardBase
@inject IIndexedDbService Db
@inject IDocxService Docx
@inject IAiProviderFactory Providers
@inject IDataSyncService DataSync
@inject AppStateService AppState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Evaluate &amp; Generate — Simply Job Application</PageTitle>

@if (!_hasApiKey)
{
    <div class="alert alert-warning sja-api-alert" role="alert">
        No API key configured for the selected provider.
        <a href="settings">Go to Settings</a> to enter your key.
    </div>
}

<!-- ── Sticky progress bar ─────────────────────────────────────────────── -->
<div class="sja-progress-bar" role="navigation" aria-label="Application progress">
    <nav class="sja-steps" aria-label="Steps">
        <div class="sja-step @StepClass(1)" aria-current="@(StepClass(1) == "active" ? "step" : null)">
            @if (StepClass(1) == "completed") { <span class="sja-step-icon" aria-hidden="true">✓</span> }
            <span>Input</span>
        </div>
        <div class="sja-step-connector" aria-hidden="true"></div>
        <div class="sja-step @StepClass(2)" aria-current="@(StepClass(2) == "active" ? "step" : null)">
            @if (StepClass(2) == "completed") { <span class="sja-step-icon" aria-hidden="true">✓</span> }
            <span>Evaluation</span>
        </div>
        <div class="sja-step-connector" aria-hidden="true"></div>
        <div class="sja-step @StepClass(3)" aria-current="@(StepClass(3) == "active" ? "step" : null)">
            @if (StepClass(3) == "completed") { <span class="sja-step-icon" aria-hidden="true">✓</span> }
            <span>Generation</span>
        </div>
    </nav>
    <button class="btn btn-outline-secondary btn-sm"
            title="Reset all form values."
            disabled="@(_evaluating || _reevaluating || _generating)"
            @onclick="NewSession">
        New
    </button>
</div>

<!-- ── Pre-evaluate deletion banners (M6-9) ──────────────────────────────── -->
@if (_showPreEvalOrgDeletedBanner)
{
    <div class="alert alert-warning alert-dismissible mt-2" role="alert">
        The linked organization was deleted in another tab and has been cleared.
        <button type="button" class="btn-close" @onclick="() => _showPreEvalOrgDeletedBanner = false" aria-label="Dismiss"></button>
    </div>
}
@if (_showPreEvalOppDeletedBanner)
{
    <div class="alert alert-warning alert-dismissible mt-2" role="alert">
        The linked opportunity was deleted in another tab and has been cleared.
        <button type="button" class="btn-close" @onclick="() => _showPreEvalOppDeletedBanner = false" aria-label="Dismiss"></button>
    </div>
}

<!-- ── Unsaved Changes Banner (M6-4) ─────────────────────────────────────── -->
@if (_showUnsavedChangesBanner)
{
    <div class="alert alert-warning d-flex flex-wrap gap-2 justify-content-between align-items-center mt-2" role="alert">
        <span>Role or description differs from the saved Opportunity values.</span>
        <button class="btn btn-sm btn-warning"
                disabled="@(_evaluating || _generating)"
                @onclick="UpdateOpportunityAsync">
            Update Opportunity
        </button>
    </div>
}

<!-- ══ Swimlane 1: User Input ════════════════════════════════════════════ -->
<section id="lane-input" class="sja-swimlane sja-lane-input" aria-label="User Input">
    <div class="sja-swimlane-header">
        <h5 class="mb-0">Job/Role &amp; Resume Input</h5>
    </div>
    <div class="sja-swimlane-body">

        <!-- ── Entity Selection (M6-2) ───────────────────────────────────── -->
        <div class="card mb-3">
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">
                            Organization <span class="text-danger">*</span>
                        </label>
                        @if (_entitySelectionLocked)
                        {
                            <div class="input-group">
                                <span class="form-control bg-light">@_orgText</span>
                                <button class="btn btn-outline-secondary" type="button"
                                        title="Clear organization"
                                        disabled="@(_evaluating || _generating)"
                                        @onclick="ClearOrganization">✕</button>
                            </div>
                        }
                        else
                        {
                            <div class="position-relative">
                                <input type="text"
                                       class="form-control @(_linkedOrgId is not null ? "border-success" : "")"
                                       @bind="_orgText"
                                       @bind:event="oninput"
                                       @bind:after="OnOrgTextChanged"
                                       @onblur="OnOrgBlur"
                                       placeholder="Type to search or enter new…"
                                       disabled="@(_evaluating || _generating)" />
                                @if (_orgSuggestions.Count > 0 && _showOrgDropdown)
                                {
                                    <div class="dropdown-menu show position-absolute w-100"
                                         style="top:100%;left:0;z-index:1000;max-height:200px;overflow-y:auto">
                                        @foreach (var org in _orgSuggestions)
                                        {
                                            var orgCopy = org;
                                            <button class="dropdown-item" type="button"
                                                    @onmousedown:preventDefault
                                                    @onmousedown="() => SelectOrgSuggestion(orgCopy)">
                                                @org.Name
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                            @if (_linkedOrgId is not null)
                            {
                                <small class="text-success">Linked to existing organization</small>
                            }
                        }
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label fw-semibold">
                            Opportunity <span class="text-muted fw-normal small">(optional)</span>
                        </label>
                        @if (_entitySelectionLocked && _linkedOppId is not null)
                        {
                            <div class="input-group">
                                <span class="form-control bg-light">@_linkedOppRole</span>
                                <button class="btn btn-outline-secondary" type="button"
                                        title="Clear opportunity"
                                        disabled="@(_evaluating || _generating)"
                                        @onclick="ClearOpportunity">✕</button>
                            </div>
                        }
                        else
                        {
                            <select class="form-select"
                                    disabled="@(_linkedOrgId is null || _evaluating || _generating)"
                                    value="@(_linkedOppId ?? "")"
                                    @onchange="OnOppChanged">
                                <option value="">-- Select opportunity (optional) --</option>
                                @if (_linkedOrgId is not null && _opportunities.Count == 0)
                                {
                                    <option value="" disabled>(none available)</option>
                                }
                                @foreach (var opp in _opportunities)
                                {
                                    <option value="@opp.Id">@opp.Role</option>
                                }
                            </select>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- ── Job Description + Resume row ──────────────────────────────── -->
        <div class="row g-3">
            <!-- Role & Role Description card (M6-3) -->
            <div class="col-12 col-lg-7">
                <div class="card h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>Job Description</span>
                        @if (_roleFieldsLocked && !_editingPostEvaluate)
                        {
                            <button class="btn btn-sm btn-outline-secondary"
                                    disabled="@(_evaluating || _generating)"
                                    @onclick="EditRoleFields">Edit</button>
                        }
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Role</label>
                            <input class="form-control"
                                   @bind="_role"
                                   @bind:event="oninput"
                                   @bind:after="OnRoleAfterBind"
                                   placeholder="Software Engineer"
                                   readonly="@(_roleFieldsLocked && !_editingPostEvaluate)" />
                        </div>
                        <div>
                            <label class="form-label">Role Description</label>
                            <textarea class="form-control" rows="8"
                                      @bind="_roleDescription"
                                      @bind:event="oninput"
                                      @bind:after="OnRoleDescAfterBind"
                                      placeholder="Paste the full job description here…"
                                      readonly="@(_roleFieldsLocked && !_editingPostEvaluate)"></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Resume card (M6-1) -->
            <div class="col-12 col-lg-5">
                <div class="card h-100">
                    <div class="card-header">Resume</div>
                    <div class="card-body">
                        @if (_noResumesExist)
                        {
                            <div class="alert alert-info mb-3">
                                No resumes available.
                                <a href="/resumes">Go to My Resumes</a> to upload your first resume.
                            </div>
                        }
                        else
                        {
                            @if (_selectedResumeId is not null)
                            {
                                <div class="alert @(_resumeDeleted ? "alert-danger" : "alert-success") py-2 d-flex align-items-center gap-2 mb-3">
                                    <span>@(_resumeDeleted ? "⚠️" : "📄")</span>
                                    <span class="flex-grow-1">@ResumeDisplayLabel()</span>
                                    @if (_resumeDeleted)
                                    {
                                        <span class="text-danger small">(deleted)</span>
                                    }
                                </div>
                            }
                            <button class="btn btn-outline-secondary w-100" type="button"
                                    disabled="@(_evaluating || _generating)"
                                    @onclick="OpenResumePicker">
                                @(_selectedResumeId is null ? "Select Resume" : "Change Resume")
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Evaluate error shown in pre-eval state -->
        @if (_evalError is not null && !_evaluating && !_roleFieldsLocked)
        {
            <div class="alert alert-danger mt-3" role="alert">@_evalError</div>
        }

        <div class="d-flex justify-content-between align-items-center mt-3">
            @if (_evaluation is not null && _linkedOppId is null)
            {
                <button class="btn btn-outline-primary"
                        disabled="@(_evaluating || _generating)"
                        @onclick="OpenSaveOppModal">
                    Save Opportunity
                </button>
            }
            else
            {
                <div></div>
            }
            <button class="btn btn-primary px-4"
                    disabled="@(!CanEvaluate)"
                    @onclick="EvaluateWithScrollAsync"
                    aria-label="Evaluate match">
                @if (_evaluating)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>@_loadingStep</span>
                }
                else { <span>Evaluate</span> }
            </button>
        </div>
    </div>
</section>

<!-- ══ Swimlane 2: Evaluation ════════════════════════════════════════════ -->
<section id="lane-evaluation" class="sja-swimlane sja-lane-eval" aria-label="Evaluation">
    <div class="sja-swimlane-header">
        <h5 class="mb-0">Match Evaluation &amp; ATS fitting</h5>
    </div>
    <div class="sja-swimlane-body">
        @if (_evaluating || _reevaluating)
        {
            <div class="card mb-3" aria-busy="true" aria-label="Loading match evaluation">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="sja-skeleton" style="width:9rem;height:0.9rem"></div>
                    <div class="sja-skeleton" style="width:4.5rem;height:1.4rem;border-radius:0.75rem"></div>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <div class="sja-skeleton" style="height:0.8rem;width:32%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:90%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:76%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:84%"></div>
                    <div class="sja-skeleton mt-2" style="height:0.8rem;width:28%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:93%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:70%"></div>
                </div>
            </div>
            <div class="card" aria-busy="true" aria-label="Loading keyword suggestions">
                <div class="card-header"><div class="sja-skeleton" style="width:14rem;height:0.9rem"></div></div>
                <div class="card-body d-flex flex-column gap-2">
                    <div class="sja-skeleton" style="height:0.8rem;width:58%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:70%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:48%"></div>
                </div>
            </div>
        }
        else if (_evaluation is null)
        {
            <div class="sja-empty-state">
                <p class="text-muted mb-3">Evaluate your input to see match analysis and keyword suggestions.</p>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="@(() => ScrollToAsync("lane-input"))"
                        aria-label="Go to User Input section">
                    ↑ Go to Input
                </button>
            </div>
        }
        else
        {
            var currentKwSet = _evaluation.SuggestedKeywords
                .Select(k => k.Keyword)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            var previouslyConfirmed = _confirmedKeywords
                .Where(k => !currentKwSet.Contains(k.Keyword))
                .ToList();
            var usedKeywords = GetAllKeywordsForSession();

            <!-- Match evaluation -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Match Evaluation</span>
                    <span class="badge @ScoreBadgeClass(_evaluation.Score)">@_evaluation.Score</span>
                </div>
                <div class="card-body">
                    @if (_evaluation.Strengths.Count > 0)
                    {
                        <p class="mb-1 fw-semibold text-success">Strengths:</p>
                        <ul class="mb-3">
                            @foreach (var s in _evaluation.Strengths) { <li>@s</li> }
                        </ul>
                    }
                    @if (_evaluation.Gaps.Count > 0)
                    {
                        <p class="mb-1 fw-semibold">Areas needing attention:</p>
                        <ul class="mb-0">
                            @foreach (var g in _evaluation.Gaps) { <li>@g</li> }
                        </ul>
                    }
                    else
                    {
                        <p class="mb-0 text-success">No significant gaps identified.</p>
                    }
                </div>
            </div>

            <!-- Keywords card: interactive before generate, read-only after -->
            @if (_materials is null)
            {
                <div class="card mb-3">
                    <div class="card-header">Additional Keywords for ATS</div>
                    <div class="card-body">
                        @if (previouslyConfirmed.Count > 0)
                        {
                            <p class="fw-semibold small mb-1">Previously selected</p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var kw in previouslyConfirmed)
                                {
                                    var kwCopy = kw;
                                    <span class="badge text-bg-secondary d-flex align-items-center gap-1">
                                        @if (!string.IsNullOrEmpty(kw.Category))
                                        {
                                            <span class="opacity-75 small">@kw.Category:</span>
                                        }
                                        @kw.Keyword
                                        <button type="button" class="btn-close btn-close-white"
                                                style="font-size:0.6rem"
                                                aria-label="Remove @kw.Keyword"
                                                @onclick="() => RemoveConfirmedKeyword(kwCopy.Keyword)"></button>
                                    </span>
                                }
                            </div>
                        }

                        @if (_evaluation.SuggestedKeywords.Count > 0)
                        {
                            <p class="text-muted small mb-2">
                                These skills appear in the job description but not in your resume.
                                Check the ones you are comfortable adding to your Skills section.
                            </p>
                            var kwIdx = 0;
                            foreach (var group in _evaluation.SuggestedKeywords.GroupBy(k => k.Category))
                            {
                                if (!string.IsNullOrEmpty(group.Key))
                                {
                                    <p class="fw-semibold mb-1 mt-2 small">@group.Key</p>
                                }
                                foreach (var kw in group)
                                {
                                    var idx = kwIdx++;
                                    var kwCopy = kw;
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="kw-@idx"
                                               checked="@_confirmedKeywords.Any(c => string.Equals(c.Keyword, kwCopy.Keyword, StringComparison.OrdinalIgnoreCase))"
                                               @onchange="e => ToggleKeyword(kwCopy, (bool)e.Value!)" />
                                        <label class="form-check-label small" for="kw-@idx">@kw.Keyword</label>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <p class="text-muted small mb-0">No additional keywords suggested for this job description.</p>
                        }

                        <div class="mt-3">
                            <label class="form-label small">
                                Add keywords manually
                                <span class="text-muted">(one per line, optionally prefixed with <code>Category: </code>; or comma-separated)</span>
                            </label>
                            <textarea class="form-control form-control-sm" rows="2"
                                      placeholder="@("Developer Tools: Terraform\nGraphQL, REST")"
                                      @bind="_customKeywords"
                                      @bind:after="() => _customKeywords = _customKeywords.Trim()"></textarea>
                        </div>

                        @if (GetAdditionalKeywords().Count > 0)
                        {
                            <button class="btn btn-outline-secondary btn-sm w-100 mt-3"
                                    disabled="@(_reevaluating || _generating)"
                                    @onclick="ReEvaluateAsync"
                                    aria-label="Re-evaluate with selected keywords">
                                @if (_reevaluating)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Re-evaluating…</span>
                                }
                                else { <span>Re-evaluate with Selected Keywords</span> }
                            </button>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-success px-4"
                            disabled="@(!CanGenerate)"
                            title="@(_resumeDeleted ? "The selected resume is no longer available. Please select a different resume." : null)"
                            @onclick="GenerateWithScrollAsync"
                            aria-label="Generate application materials">
                        @if (_generating)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>@_loadingStep</span>
                        }
                        else { <span>Generate</span> }
                    </button>
                </div>
            }
            else if (usedKeywords.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-header">Additional Keywords Used</div>
                    <div class="card-body">
                        @foreach (var group in usedKeywords.GroupBy(k => string.IsNullOrEmpty(k.Category) ? "Other" : k.Category))
                        {
                            <p class="fw-semibold small mb-1 mt-2">@group.Key</p>
                            <div class="d-flex flex-wrap gap-2 mb-1">
                                @foreach (var kw in group)
                                {
                                    <span class="badge text-bg-secondary">@kw.Keyword</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }

        @if (_evalError is not null && !_evaluating && !_reevaluating && _roleFieldsLocked)
        {
            <div class="alert alert-danger mt-3" role="alert">@_evalError</div>
        }
    </div>
</section>

<!-- ══ Swimlane 3: Generated Content ════════════════════════════════════ -->
<section id="lane-generated" class="sja-swimlane sja-lane-gen" aria-label="Generated Content">
    <div class="sja-swimlane-header">
        <h5 class="mb-0">Generated Customized Content</h5>
    </div>
    <div class="sja-swimlane-body">
        @if (_generating)
        {
            <div class="row g-3" aria-busy="true">
                <div class="col-12 col-lg-6">
                    <div class="card h-100" aria-label="Loading tailored resume">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="sja-skeleton" style="width:8rem;height:0.9rem"></div>
                            <div class="sja-skeleton" style="width:6.5rem;height:1.8rem;border-radius:0.25rem"></div>
                        </div>
                        <div class="card-body"><div class="sja-skeleton" style="height:0.8rem;width:75%"></div></div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="card h-100" aria-label="Loading why apply">
                        <div class="card-header"><div class="sja-skeleton" style="width:5rem;height:0.9rem"></div></div>
                        <div class="card-body d-flex flex-column gap-2">
                            <div class="sja-skeleton" style="height:0.8rem;width:95%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:68%"></div>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card" aria-label="Loading cover letter">
                        <div class="card-header"><div class="sja-skeleton" style="width:6rem;height:0.9rem"></div></div>
                        <div class="card-body d-flex flex-column gap-2">
                            <div class="sja-skeleton" style="height:0.8rem;width:91%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:83%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:62%"></div>
                            <div class="sja-skeleton mt-2" style="height:0.8rem;width:88%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:74%"></div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (_materials is null)
        {
            <div class="sja-empty-state">
                <p class="text-muted mb-2">To generate tailored application materials:</p>
                <ol class="text-muted mb-3 d-inline-block text-start ps-3">
                    <li>Complete evaluation</li>
                    <li>Click Generate</li>
                </ol>
                <br />
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="@(() => ScrollToAsync("lane-evaluation"))"
                        aria-label="Go to Evaluation section">
                    ↑ Go to Evaluation
                </button>
            </div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>Tailored Resume</span>
                            @if (_tailoredResumeFileId is not null)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="DownloadTailoredResume">
                                    Download DOCX
                                </button>
                            }
                        </div>
                        <div class="card-body text-muted small">
                            Tailored resume generated and ready for download.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header">Why Apply</div>
                        <div class="card-body">
                            @foreach (var para in _materials.WhyApplyText.Split(
                                new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p class="mb-1">@para</p>
                            }
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>Cover Letter</span>
                            @if (_coverLetterFileId is not null)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="DownloadCoverLetter">
                                    Download DOCX
                                </button>
                            }
                        </div>
                        <div class="card-body">
                            @foreach (var para in _materials.CoverLetterText.Split(
                                new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p>@para</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (_generateError is not null && !_generating)
        {
            <div class="alert alert-danger mt-3" role="alert">@_generateError</div>
        }
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- MODALS                                                                -->
<!-- ══════════════════════════════════════════════════════════════════════ -->

<!-- ── Resume Picker Modal (M6-1) ────────────────────────────────────── -->
@if (_showResumePicker)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);z-index:1055"
         role="dialog" aria-modal="true" aria-label="Select Resume">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Resume</h5>
                    <button class="btn-close" @onclick="() => _showResumePicker = false" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (_resumes.Count == 0)
                    {
                        <p class="text-muted">No resumes available. <a href="/resumes">Go to My Resumes</a> to upload one.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var resume in _resumes.OrderBy(r => r.Name, StringComparer.OrdinalIgnoreCase))
                            {
                                var r = resume;
                                var isExpanded = _resumePickerExpanded.GetValueOrDefault(r.Id);
                                var ver = _latestVersions.GetValueOrDefault(r.Id);
                                var isSelected = r.Id == _selectedResumeId;
                                <div class="list-group-item @(isSelected ? "list-group-item-success" : "") p-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <button class="btn btn-link text-start p-0 flex-grow-1 text-decoration-none @(isSelected ? "fw-semibold" : "")"
                                                @onclick="() => SelectResume(r)">
                                            @r.Name
                                            @if (isSelected) { <span class="ms-1 text-muted small">(selected)</span> }
                                        </button>
                                        <button class="btn btn-sm btn-outline-secondary ms-2"
                                                @onclick="() => ToggleResumePickerExpand(r.Id)">
                                            @(isExpanded ? "▲" : "▼")
                                        </button>
                                    </div>
                                    @if (isExpanded && ver is not null)
                                    {
                                        <div class="mt-2 small text-muted ps-1">
                                            <div>Uploaded: @ver.UploadedAt.ToLocalTime().ToString("g")</div>
                                            @if (!string.IsNullOrEmpty(ver.Notes))
                                            {
                                                <div>Notes: @ver.Notes</div>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- ── Navigation Guard Modal (from base class) ───────────────────────── -->
<NavigationGuardModal Show="_showGuardModal"
                      StayLabel="@StayLabel"
                      LeaveLabel="@LeaveLabel"
                      OnStay="() => OnGuardStay()"
                      OnLeave="() => OnGuardLeave()" />
<NavigationLock OnBeforeInternalNavigation="HandleLocationChanging" />

<!-- ── New + Banner Modal (M6-7) ─────────────────────────────────────── -->
@if (_showNewWithBannerModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);z-index:1055" role="dialog" aria-modal="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reset Form</h5>
                </div>
                <div class="modal-body">
                    <p>You have unsaved changes to the linked Opportunity's Role or Description. What would you like to do?</p>
                </div>
                <div class="modal-footer gap-2">
                    <button class="btn btn-outline-secondary" @onclick="() => _showNewWithBannerModal = false">Cancel</button>
                    <button class="btn btn-outline-warning" @onclick="NewWithBannerResetAsync">Reset Without Saving</button>
                    <button class="btn btn-warning" @onclick="NewWithBannerUpdateAsync">Update Opportunity &amp; Reset</button>
                </div>
            </div>
        </div>
