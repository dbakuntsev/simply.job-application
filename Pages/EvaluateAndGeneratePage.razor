}

<!-- ── Save Opportunity Modal (M6-5) ──────────────────────────────────── -->
@if (_showSaveOppModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);z-index:1055" role="dialog" aria-modal="true" aria-label="Save Opportunity">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Save Opportunity</h5>
                    <button class="btn-close" @onclick="CloseSaveOppModal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (_saveOppStep == 0)
                    {
                        <!-- Form -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Organization</label>
                            @if (_linkedOrgId is not null)
                            {
                                <input class="form-control" value="@_linkedOrgName" readonly />
                            }
                            else
                            {
                                <input class="form-control"
                                       @bind="_saveOppOrgName"
                                       @bind:event="oninput"
                                       @bind:after="() => _saveOppOrgName = _saveOppOrgName.Trim()"
                                       placeholder="Organization name" />
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Role</label>
                            <input class="form-control" value="@_role" readonly />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Role Description</label>
                            <textarea class="form-control" rows="4" value="@_roleDescription" readonly></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Posting URL</label>
                            <input class="form-control" @bind="_saveOppPostingUrl"
                                   @bind:after="() => _saveOppPostingUrl = _saveOppPostingUrl.Trim()"
                                   placeholder="https://…" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Compensation Range</label>
                            <input class="form-control" @bind="_saveOppCompensationRange"
                                   @bind:after="() => _saveOppCompensationRange = _saveOppCompensationRange.Trim()"
                                   placeholder="e.g. $120k–$150k" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Work Arrangement</label>
                            <select class="form-select" value="@(_saveOppWorkArrangement?.ToString() ?? "")"
                                    @onchange="e => _saveOppWorkArrangement = string.IsNullOrEmpty((string?)e.Value) ? null : Enum.Parse<WorkArrangement>((string)e.Value!)">
                                <option value="">-- Not specified --</option>
                                <option value="Remote">Remote</option>
                                <option value="Hybrid">Hybrid</option>
                                <option value="OnSite">On-site</option>
                            </select>
                        </div>
                        @if (_saveOppError is not null)
                        {
                            <div class="alert alert-danger">@_saveOppError</div>
                        }
                    }
                    else if (_saveOppStep == 1)
                    {
                        <!-- Org conflict resolution -->
                        <p>An organization named <strong>@_saveOppConflictOrg?.Name</strong> already exists. What would you like to do?</p>
                        <div class="d-flex flex-column gap-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" id="soo-link" name="soo-org"
                                       checked="@_saveOppOrgChoiceLink"
                                       @onchange="SelectExistingOrgForSaveOpp" />
                                <label class="form-check-label" for="soo-link">Link to existing organization</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" id="soo-new" name="soo-org"
                                       checked="@(!_saveOppOrgChoiceLink)"
                                       @onchange="() => { _saveOppOrgChoiceLink = false; _saveOppNewOrgName = _saveOppOrgName; }" />
                                <label class="form-check-label" for="soo-new">Create new organization</label>
                            </div>
                            @if (!_saveOppOrgChoiceLink)
                            {
                                <div class="ms-4">
                                    <label class="form-label small">New organization name</label>
                                    <input class="form-control form-control-sm" @bind="_saveOppNewOrgName"
                                           @bind:event="oninput"
                                           @bind:after="() => _saveOppNewOrgName = _saveOppNewOrgName.Trim()" />
                                </div>
                            }
                        </div>
                    }
                    else if (_saveOppStep == 2)
                    {
                        <!-- Opp conflict resolution -->
                        @if (_saveOppOppExactMatch)
                        {
                            <p>An opportunity with the same Role and Role Description already exists: <strong>@_saveOppConflictOpp?.Role</strong>. Would you like to link to it instead of creating a new one?</p>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" id="soo-opp-link" name="soo-opp"
                                       checked="@_saveOppOppChoiceLink"
                                       @onchange="() => _saveOppOppChoiceLink = true" />
                                <label class="form-check-label" for="soo-opp-link">Link to existing opportunity</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" id="soo-opp-new" name="soo-opp"
                                       checked="@(!_saveOppOppChoiceLink)"
                                       @onchange="() => _saveOppOppChoiceLink = false" />
                                <label class="form-check-label" for="soo-opp-new">Create new opportunity</label>
                            </div>
                        }
                        else
                        {
                            <p class="text-warning">An opportunity with the same Role but a different description already exists: <strong>@_saveOppConflictOpp?.Role</strong>. A new opportunity with a duplicate role name will be created. Continue?</p>
                        }
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="CloseSaveOppModal">Cancel</button>
                    @if (_saveOppStep == 0)
                    {
                        <button class="btn btn-primary" disabled="@(_saveOppSaving || string.IsNullOrWhiteSpace(_linkedOrgId is null ? _saveOppOrgName : _linkedOrgName))"
                                @onclick="SaveOppNextAsync">
                            @if (_saveOppSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Next
                        </button>
                    }
                    else
                    {
                        <button class="btn btn-primary" disabled="@_saveOppSaving"
                                @onclick="SaveOppNextAsync">
                            @if (_saveOppSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            @(_saveOppStep == 2 ? "Save" : "Next")
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

