    // ── AI turns ──────────────────────────────────────────────────────────────

    async Task EvaluateAsync()
    {
        _evalError = null;
        _generateError = null;
        _evaluation = null;
        _confirmedKeywords.Clear();
        _customKeywords = "";
        _roleFieldsLocked = true;
        _editingPostEvaluate = false;
        _evaluating = true;
        _evalRoleSnapshot = _role;
        _evalRoleDescSnapshot = _roleDescription;

        try
        {
            // Delete old generated files if re-evaluating a session that had Generate
            if (_sessionId is not null)
            {
                if (_pendingDeleteTailoredFileId is not null)
                {
                    await Db.DeleteFileAsync(_pendingDeleteTailoredFileId);
                    _pendingDeleteTailoredFileId = null;
                }
                if (_pendingDeleteCoverLetterFileId is not null)
                {
                    await Db.DeleteFileAsync(_pendingDeleteCoverLetterFileId);
                    _pendingDeleteCoverLetterFileId = null;
                }
            }

            _settings = await Db.GetSettingsAsync();
            var apiKey  = _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider) ?? "";
            var modelId = _settings.ProviderModels.GetValueOrDefault(_settings.AiProvider)
                          ?? Providers.Get(_settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(_settings.AiProvider);

            _loadingStep = "Loading resume…";
            StateHasChanged();

            var version = await Db.GetBaseResumeVersionAsync(_selectedVersionId!);
            if (version is null) throw new InvalidOperationException("Selected resume version not found.");
            _resumeBytes = Convert.FromBase64String(version.FileDataBase64);

            _loadingStep = "Extracting resume…";
            StateHasChanged();
            _resumeMarkdown = Docx.ExtractMarkdown(_resumeBytes);

            var job = new JobDescription
            {
                CompanyName = _linkedOrgName ?? _orgText,
                JobTitle    = _role,
                JobDetails  = _roleDescription,
            };

            _evaluation = await provider.EvaluateMatchAsync(job, _resumeMarkdown, modelId, apiKey, null,
                onProgress: msg => { _loadingStep = msg; StateHasChanged(); });

            if (_sessionId is null)
                _sessionId = Guid.NewGuid().ToString();
            await SaveSessionAsync();
            await DataSync.BroadcastAsync("session", _sessionId, "updated");
        }
        catch (Exception ex)
        {
            _evalError = ex.Message;
            _roleFieldsLocked = false;
            _evalRoleSnapshot = null;
            _evalRoleDescSnapshot = null;
        }
        finally
        {
            _evaluating = false;
            _loadingStep = null;
        }
    }

    async Task GenerateAsync()
    {
        if (_evaluation is null || _resumeMarkdown is null) return;

        _generateError = null;
        _generating = true;

        try
        {
            _settings = await Db.GetSettingsAsync();
            var apiKey  = _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider) ?? "";
            var modelId = _settings.ProviderModels.GetValueOrDefault(_settings.AiProvider)
                          ?? Providers.Get(_settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(_settings.AiProvider);

            var orgName = _linkedOrgName ?? _orgText;
            var job = new JobDescription
            {
                CompanyName = orgName,
                JobTitle    = _role,
                JobDetails  = _roleDescription,
            };

            var sourcePageCount = Docx.GetPageCount(_resumeBytes!);
            var targetPageCount = _settings.OutputResumePages ?? sourcePageCount;

            _materials = await provider.GenerateMaterialsAsync(
                job, _resumeMarkdown, _evaluation, modelId, apiKey, GetAdditionalKeywords(),
                sourcePageCount: sourcePageCount ?? 2,
                targetPageCount: targetPageCount ?? 2,
                onProgress: msg => { _loadingStep = msg; StateHasChanged(); });

            var resumeDocxBytes = Docx.GenerateResumeDocx(_resumeBytes!, _materials.ResumeMarkdown);
            var resumeFileId = Guid.NewGuid().ToString();
            await Db.SaveFileAsync(new StoredFile
            {
                Id         = resumeFileId,
                Name       = $"Resume - {orgName} - {_role}.docx",
                DataBase64 = Convert.ToBase64String(resumeDocxBytes),
                LastUsedAt = DateTime.UtcNow,
                SessionCount = 1,
            });
            _tailoredResumeFileId = resumeFileId;

            var clDocx   = Docx.GenerateCoverLetterDocx(_materials.CoverLetterText);
            var clFileId = Guid.NewGuid().ToString();
            await Db.SaveFileAsync(new StoredFile
            {
                Id         = clFileId,
                Name       = $"Cover Letter - {orgName} - {_role}.docx",
                DataBase64 = Convert.ToBase64String(clDocx),
                LastUsedAt = DateTime.UtcNow,
                SessionCount = 1,
            });
            _coverLetterFileId = clFileId;

            await SaveSessionAsync();
            await DataSync.BroadcastAsync("session", _sessionId!, "updated");
        }
        catch (Exception ex)
        {
            _generateError = ex.Message;
            _materials = null;
        }
        finally
        {
            _generating = false;
            _loadingStep = null;
        }
    }

    async Task ReEvaluateAsync()
    {
        if (_resumeMarkdown is null) return;

        _evalError = null;
        _generateError = null;
        _materials = null;
        _tailoredResumeFileId = null;
        _coverLetterFileId = null;
        _reevaluating = true;

        try
        {
            _settings = await Db.GetSettingsAsync();
            var apiKey  = _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider) ?? "";
            var modelId = _settings.ProviderModels.GetValueOrDefault(_settings.AiProvider)
                          ?? Providers.Get(_settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(_settings.AiProvider);

            var job = new JobDescription
            {
                CompanyName = _linkedOrgName ?? _orgText,
                JobTitle    = _role,
                JobDetails  = _roleDescription,
            };

            _evaluation = await provider.EvaluateMatchAsync(
                job, _resumeMarkdown, modelId, apiKey, GetAdditionalKeywords(),
                onProgress: msg => { _loadingStep = msg; StateHasChanged(); });

            await SaveSessionAsync();
            await DataSync.BroadcastAsync("session", _sessionId!, "updated");
        }
        catch (Exception ex)
        {
            _evalError = ex.Message;
        }
        finally
        {
            _reevaluating = false;
            _loadingStep = null;
        }
    }

