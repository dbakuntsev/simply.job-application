    // ── State preservation (M6-6) ─────────────────────────────────────────────

    void SavePreEvaluateState()
    {
        AppState.PreservedOrgText = _orgText;
        AppState.PreservedLinkedOrgId = _linkedOrgId;
        AppState.PreservedLinkedOrgName = _linkedOrgName;
        AppState.PreservedLinkedOppId = _linkedOppId;
        AppState.PreservedLinkedOppRole = _linkedOppRole;
        AppState.PreservedLinkedOppRoleDesc = _linkedOppRoleDesc;
        AppState.PreservedRole = _role;
        AppState.PreservedRoleDescription = _roleDescription;
        AppState.PreservedResumeId = _selectedResumeId;
    }

    async Task RestorePreservedStateAsync()
    {
        _orgText = AppState.PreservedOrgText ?? "";
        _role = AppState.PreservedRole ?? "";
        _roleDescription = AppState.PreservedRoleDescription ?? "";

        if (AppState.PreservedLinkedOrgId is not null)
        {
            var org = _organizations.FirstOrDefault(o => o.Id == AppState.PreservedLinkedOrgId);
            if (org is null)
            {
                _showPreEvalOrgDeletedBanner = true;
                _orgText = AppState.PreservedOrgText ?? "";
            }
            else
            {
                _linkedOrgId = org.Id;
                _linkedOrgName = org.Name;
                _orgText = org.Name;
                _opportunities = await Db.GetOpportunitiesByOrganizationAsync(org.Id);

                if (AppState.PreservedLinkedOppId is not null)
                {
                    var opp = _opportunities.FirstOrDefault(o => o.Id == AppState.PreservedLinkedOppId);
                    if (opp is null)
                    {
                        _showPreEvalOppDeletedBanner = true;
                    }
                    else
                    {
                        _linkedOppId = opp.Id;
                        _linkedOppRole = opp.Role;
                        _linkedOppRoleDesc = opp.RoleDescription;
                        _entitySelectionLocked = true;
                    }
                }
            }
        }

        if (AppState.PreservedResumeId is not null)
        {
            var resume = _resumes.FirstOrDefault(r => r.Id == AppState.PreservedResumeId);
            if (resume is not null)
            {
                var version = _latestVersions.GetValueOrDefault(resume.Id);
                if (version is not null)
                {
                    _selectedResumeId = resume.Id;
                    _selectedVersionId = version.Id;
                    _selectedResumeName = resume.Name;
                    _selectedVersionNumber = version.VersionNumber;
                    _selectedVersionIsLatest = true;
                    _resumeDeleted = false;
                }
            }
        }

        if (_selectedResumeId is null)
            await ApplyAutoSelectResume();
        else
            _noResumesExist = _resumes.Count == 0;

        RecalculateUnsavedChangesBanner();
    }

    async Task LoadContextualNavAsync()
    {
        _linkedOrgId = AppState.ContextualOrgId;
        _linkedOrgName = AppState.ContextualOrgName;
        _orgText = AppState.ContextualOrgName ?? "";

        if (_linkedOrgId is not null)
        {
            var org = _organizations.FirstOrDefault(o => o.Id == _linkedOrgId);
            if (org is null)
            {
                _linkedOrgId = null;
                _linkedOrgName = null;
            }
            else
            {
                _linkedOrgName = org.Name;
                _orgText = org.Name;
                _opportunities = await Db.GetOpportunitiesByOrganizationAsync(_linkedOrgId);

                if (AppState.ContextualOppId is not null)
                {
                    var opp = _opportunities.FirstOrDefault(o => o.Id == AppState.ContextualOppId);
                    if (opp is not null)
                    {
                        _linkedOppId = opp.Id;
                        _linkedOppRole = opp.Role;
                        _linkedOppRoleDesc = opp.RoleDescription;
                        _role = opp.Role;
                        _roleDescription = opp.RoleDescription;
                        _entitySelectionLocked = true;
                    }
                }
            }
        }

        await ApplyAutoSelectResume();
        RecalculateUnsavedChangesBanner();
    }

    // ── Remote event handlers (M6-9, M6-10) ──────────────────────────────────

    private void HandleOrganizationChanged(string? id, string @event)
    {
        if (id != _linkedOrgId) return;
        InvokeAsync(async () =>
        {
            if (@event == "deleted")
            {
                if (_sessionId is not null)
                {
                    _remoteDeletionMessage = "The linked organization was deleted in another tab. The current session is no longer available.";
                    _remoteDeletionNavTarget = "/organizations";
                    _showRemoteDeletionModal = true;
                }
                else
                {
                    _linkedOrgId = null;
                    _linkedOrgName = null;
                    _linkedOppId = null;
                    _linkedOppRole = null;
                    _linkedOppRoleDesc = null;
                    _entitySelectionLocked = false;
                    _opportunities.Clear();
                    _showPreEvalOrgDeletedBanner = true;
                    RecalculateUnsavedChangesBanner();
                }
            }
            else if (@event == "updated")
            {
                var org = await Db.GetOrganizationAsync(id!);
                if (org is null || org.Name == _linkedOrgName) return;
                _linkedOrgName = org.Name;
                _orgText = org.Name;
                if (_sessionId is not null)
                {
                    DiscardEvaluation();
                    _remoteChangeNoticeMessage = $"The linked organization was renamed to '{org.Name}' in another tab. Evaluation results have been discarded — please re-evaluate.";
                    _showRemoteChangeNoticeModal = true;
                }
            }
            StateHasChanged();
        });
    }

    private void HandleOpportunityChanged(string? id, string @event)
    {
        if (id != _linkedOppId) return;
        InvokeAsync(async () =>
        {
            if (@event == "deleted")
            {
                if (_sessionId is not null)
                {
                    _remoteDeletionMessage = "The linked opportunity was deleted in another tab. The current session is no longer available.";
                    _remoteDeletionNavTarget = _linkedOrgId is not null
                        ? $"/organizations/{_linkedOrgId}"
                        : "/organizations";
                    _showRemoteDeletionModal = true;
                }
                else
                {
                    _linkedOppId = null;
                    _linkedOppRole = null;
                    _linkedOppRoleDesc = null;
                    _entitySelectionLocked = false;
                    _showPreEvalOppDeletedBanner = true;
                    RecalculateUnsavedChangesBanner();
                }
            }
            else if (@event == "updated")
            {
                var opp = await Db.GetOpportunityAsync(id!);
                if (opp is null) return;

                bool roleChanged = opp.Role != _linkedOppRole;
                bool descChanged = opp.RoleDescription != _linkedOppRoleDesc;
                if (!roleChanged && !descChanged) return;

                var oldOppRole = _linkedOppRole;
                var oldOppDesc = _linkedOppRoleDesc;
                _linkedOppRole = opp.Role;
                _linkedOppRoleDesc = opp.RoleDescription;

                bool userModified = _role != oldOppRole || _roleDescription != oldOppDesc;

                if (!userModified)
                {
                    _role = opp.Role;
                    _roleDescription = opp.RoleDescription;
                    if (_sessionId is not null)
                    {
                        DiscardEvaluation();
                        _remoteChangeNoticeMessage = "The linked opportunity was changed in another tab. Evaluation results have been discarded — please re-evaluate.";
                        _showRemoteChangeNoticeModal = true;
                    }
                }
                else if (_role != opp.Role || _roleDescription != opp.RoleDescription)
                {
                    _remoteConflictMyRole = _role;
                    _remoteConflictMyRoleDesc = _roleDescription;
                    _remoteConflictRemoteRole = opp.Role;
                    _remoteConflictRemoteRoleDesc = opp.RoleDescription;
                    _showRemoteConflictModal = true;
                }

                RecalculateUnsavedChangesBanner();
            }
            StateHasChanged();
        });
    }

    private void HandleBaseResumeChanged(string? id, string @event)
    {
        InvokeAsync(async () =>
        {
            _resumes = await Db.GetAllBaseResumesAsync();
            await LoadLatestVersionsAsync();
            _noResumesExist = _resumes.Count == 0;

            if (@event == "created" && _selectedResumeId is null && _resumes.Count == 1)
            {
                await ApplyAutoSelectResume();
            }
            else if (id == _selectedResumeId)
            {
                if (@event == "deleted")
                {
                    _resumeDeleted = true;
                }
                else if (@event == "updated")
                {
                    var resume = _resumes.FirstOrDefault(r => r.Id == id);
                    if (resume is not null)
                        _selectedResumeName = resume.Name;
                }
            }

            StateHasChanged();
        });
    }

    private void HandleBaseResumeVersionChanged(string? id, string @event)
    {
        if (@event != "created") return;
        InvokeAsync(async () =>
        {
            var version = await Db.GetBaseResumeVersionAsync(id!);
            if (version is null) return;

            _latestVersions[version.ResumeId] = version;

            if (version.ResumeId == _selectedResumeId)
            {
                if (_sessionId is null)
                {
                    // Pre-evaluate: silently update to new latest
                    _selectedVersionId = version.Id;
                    _selectedVersionNumber = version.VersionNumber;
                    _selectedVersionIsLatest = true;
                }
                else
                {
                    // Post-evaluate/generate: keep original, update display label
                    _selectedVersionIsLatest = false;
                }
            }

            StateHasChanged();
        });
    }

    private void HandleSessionChanged(string? id, string @event)
    {
        if (id != _sessionId || _sessionId is null) return;
        if (@event != "deleted") return;
        InvokeAsync(() =>
        {
            _sessionDeletedMessage = "The current session was deleted in another tab.";
            _showSessionDeletedModal = true;
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    private void HandleSessionsCleared()
    {
        if (_sessionId is null || _linkedOrgId is not null) return;
        InvokeAsync(() =>
        {
            _sessionDeletedMessage = "All ad-hoc sessions were cleared in another tab.";
            _showSessionDeletedModal = true;
            StateHasChanged();
            return Task.CompletedTask;
        });
    }

    // ── Keyword helpers ───────────────────────────────────────────────────────

    List<SuggestedKeyword> GetAllKeywordsForSession()
    {
        var seen   = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var result = new List<SuggestedKeyword>();
        foreach (var kw in _confirmedKeywords)
            if (seen.Add(kw.Keyword)) result.Add(kw);
        foreach (var kw in ParseCustomKeywords())
            if (seen.Add(kw.Keyword)) result.Add(kw);
        return result;
    }

    IReadOnlyList<string> GetAdditionalKeywords() =>
        GetAllKeywordsForSession()
            .Select(kw => string.IsNullOrEmpty(kw.Category) ? kw.Keyword : $"{kw.Category}: {kw.Keyword}")
            .ToList();

    List<SuggestedKeyword> ParseCustomKeywords()
    {
        var result = new List<SuggestedKeyword>();
        foreach (var line in _customKeywords.Split(new[] { '\n', '\r' },
                     StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (string.IsNullOrWhiteSpace(line)) continue;
            var colonIdx = line.IndexOf(':');
            if (colonIdx > 0)
            {
                var cat = line[..colonIdx].Trim();
                var kw  = line[(colonIdx + 1)..].Trim();
                if (!string.IsNullOrWhiteSpace(kw))
                    result.Add(new SuggestedKeyword { Category = cat, Keyword = kw });
            }
            else
            {
                foreach (var part in line.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    if (!string.IsNullOrWhiteSpace(part))
                        result.Add(new SuggestedKeyword { Category = "", Keyword = part });
            }
        }
        return result;
    }

    void ToggleKeyword(SuggestedKeyword kw, bool isChecked)
    {
        if (isChecked)
        {
            if (!_confirmedKeywords.Any(c => string.Equals(c.Keyword, kw.Keyword, StringComparison.OrdinalIgnoreCase)))
                _confirmedKeywords.Add(kw);
        }
        else
        {
            _confirmedKeywords.RemoveAll(c => string.Equals(c.Keyword, kw.Keyword, StringComparison.OrdinalIgnoreCase));
        }
    }

    void RemoveConfirmedKeyword(string keyword) =>
        _confirmedKeywords.RemoveAll(c => string.Equals(c.Keyword, keyword, StringComparison.OrdinalIgnoreCase));

    // ── Score badge helper ────────────────────────────────────────────────────

    static string ScoreBadgeClass(string score) => score switch
    {
        _ when score.Contains("High", StringComparison.OrdinalIgnoreCase)   => "bg-success",
        _ when score.Contains("Medium", StringComparison.OrdinalIgnoreCase) => "bg-warning text-dark",
        _ when score.Contains("Low", StringComparison.OrdinalIgnoreCase)    => "bg-danger",
        _                                                                    => "bg-secondary",
    };

    // ── Downloads ─────────────────────────────────────────────────────────────

    async Task DownloadTailoredResume()
    {
        if (_tailoredResumeFileId is null) return;
        var orgName = _linkedOrgName ?? _orgText;
        await DownloadFileAsync(_tailoredResumeFileId, $"Resume - {orgName} - {_role}.docx");
    }

    async Task DownloadCoverLetter()
    {
        if (_coverLetterFileId is null) return;
        var orgName = _linkedOrgName ?? _orgText;
        await DownloadFileAsync(_coverLetterFileId, $"Cover Letter - {orgName} - {_role}.docx");
    }

    async Task DownloadFileAsync(string fileId, string fileName)
    {
        var file = await Db.GetFileAsync(fileId);
        if (file is null) return;
        await Db.DownloadFileAsync(fileName, Convert.FromBase64String(file.DataBase64));
    }
