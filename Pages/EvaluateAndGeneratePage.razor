        _materials = null;
        _tailoredResumeFileId = null;
        _coverLetterFileId = null;
        _resumeBytes = null;
        _resumeMarkdown = null;
        _roleFieldsLocked = false;
        _editingPostEvaluate = false;
        _evalRoleSnapshot = null;
        _evalRoleDescSnapshot = null;
        _backedUpEvaluation = null;
