@code {
    // ── Entity selection ──────────────────────────────────────────────────────
    List<Organization> _organizations = new();
    string _orgText = "";
    string? _linkedOrgId;
    string? _linkedOrgName;
    bool _showOrgDropdown;
    List<Organization> _orgSuggestions = new();
    List<Opportunity> _opportunities = new();
    string? _linkedOppId;
    string? _linkedOppRole;
    string? _linkedOppRoleDesc;
    bool _entitySelectionLocked;

    // ── Role / RoleDescription ────────────────────────────────────────────────
    string _role = "";
    string _roleDescription = "";
    bool _roleFieldsLocked;
    bool _editingPostEvaluate;
    string? _evalRoleSnapshot;
    string? _evalRoleDescSnapshot;
    MatchEvaluation? _backedUpEvaluation;
    GeneratedMaterials? _backedUpMaterials;
    string? _backedUpTailoredResumeFileId;
    string? _backedUpCoverLetterFileId;
    string? _backedUpResumeMarkdown;

    // ── Resume ────────────────────────────────────────────────────────────────
    List<BaseResume> _resumes = new();
    Dictionary<string, BaseResumeVersion?> _latestVersions = new();
    string? _selectedResumeId;
    string? _selectedVersionId;
    string? _selectedResumeName;
    int _selectedVersionNumber;
    bool _selectedVersionIsLatest;
    bool _resumeDeleted;
    bool _noResumesExist;
    bool _showResumePicker;
    Dictionary<string, bool> _resumePickerExpanded = new();

    // ── Operation state ───────────────────────────────────────────────────────
    bool _evaluating;
    bool _reevaluating;
    bool _generating;
    string? _loadingStep;
    bool _hasApiKey = true;
    AppSettings _settings = new();

    // ── Error messages ────────────────────────────────────────────────────────
    string? _evalError;
    string? _generateError;

    // ── Evaluation results ────────────────────────────────────────────────────
    MatchEvaluation? _evaluation;
    GeneratedMaterials? _materials;
    string? _tailoredResumeFileId;
    string? _coverLetterFileId;
    byte[]? _resumeBytes;
    string? _resumeMarkdown;
    string? _sessionId;
    string? _pendingDeleteTailoredFileId;
    string? _pendingDeleteCoverLetterFileId;

    // ── Keywords ──────────────────────────────────────────────────────────────
    readonly List<SuggestedKeyword> _confirmedKeywords = new();
    string _customKeywords = "";

    // ── Unsaved changes banner (M6-4) ─────────────────────────────────────────
    bool _showUnsavedChangesBanner;

    // ── New + Banner modal (M6-7) ─────────────────────────────────────────────
    bool _showNewWithBannerModal;

    // ── Save Opportunity modal (M6-5) ─────────────────────────────────────────
    bool _showSaveOppModal;
    int _saveOppStep;
    string _saveOppOrgName = "";
    Organization? _saveOppConflictOrg;
    bool _saveOppOrgChoiceLink = true;
    string _saveOppNewOrgName = "";
    Opportunity? _saveOppConflictOpp;
    bool _saveOppOppExactMatch;
    bool _saveOppOppChoiceLink = true;
    string _saveOppPostingUrl = "";
    string _saveOppCompensationRange = "";
    WorkArrangement? _saveOppWorkArrangement;
    bool _saveOppSaving;
    string? _saveOppError;

    // ── Remote event modals (M6-9) ────────────────────────────────────────────
    bool _showRemoteChangeNoticeModal;
    string? _remoteChangeNoticeMessage;
    bool _showRemoteConflictModal;
    string? _remoteConflictMyRole;
    string? _remoteConflictMyRoleDesc;
    string? _remoteConflictRemoteRole;
    string? _remoteConflictRemoteRoleDesc;
    bool _showRemoteDeletionModal;
    string? _remoteDeletionMessage;
    string? _remoteDeletionNavTarget;
    bool _showSessionDeletedModal;
    string? _sessionDeletedMessage;

    // ── Pre-eval deletion banners (M6-9) ─────────────────────────────────────
    bool _showPreEvalOrgDeletedBanner;
    bool _showPreEvalOppDeletedBanner;

    // ── Computed properties ───────────────────────────────────────────────────

    bool CanEvaluate => !_evaluating && !_reevaluating && !_generating && !_roleFieldsLocked && _hasApiKey &&
                        !string.IsNullOrWhiteSpace(_orgText) &&
                        !string.IsNullOrWhiteSpace(_role) &&
                        !string.IsNullOrWhiteSpace(_roleDescription) &&
                        _selectedVersionId is not null &&
                        !_resumeDeleted;

    bool CanGenerate => !_generating && !_reevaluating && !_evaluating &&
                        _evaluation is not null && !_resumeDeleted;

    protected override bool IsDirty => _showUnsavedChangesBanner;
    protected override string StayLabel => "Stay and update the Opportunity";
    protected override string LeaveLabel => "Discard changes and leave";

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        SubscribeEvents();
        _settings = await Db.GetSettingsAsync();
        _hasApiKey = !string.IsNullOrWhiteSpace(
            _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider));
        _organizations = await Db.GetAllOrganizationsAsync();
        _resumes = await Db.GetAllBaseResumesAsync();
        await LoadLatestVersionsAsync();
        _noResumesExist = _resumes.Count == 0;

        if (AppState.HasContextualNav)
        {
            await LoadContextualNavAsync();
            AppState.ClearContextualNav();
        }
        else if (AppState.HasPreservedState)
        {
            await RestorePreservedStateAsync();
            AppState.ClearPreservedState();
        }
        else
        {
            await ApplyAutoSelectResume();
        }
    }

    public override async ValueTask DisposeAsync()
    {
        UnsubscribeEvents();
        if (_sessionId is null)
            SavePreEvaluateState();
        else
            AppState.ClearPreservedState();
        await base.DisposeAsync();
    }

    // ── DataSync subscriptions ────────────────────────────────────────────────

    void SubscribeEvents()
    {
        DataSync.OnOrganizationChanged += HandleOrganizationChanged;
        DataSync.OnOpportunityChanged += HandleOpportunityChanged;
        DataSync.OnBaseResumeChanged += HandleBaseResumeChanged;
        DataSync.OnBaseResumeVersionChanged += HandleBaseResumeVersionChanged;
        DataSync.OnSessionChanged += HandleSessionChanged;
        DataSync.OnSessionsCleared += HandleSessionsCleared;
    }

    void UnsubscribeEvents()
    {
        DataSync.OnOrganizationChanged -= HandleOrganizationChanged;
        DataSync.OnOpportunityChanged -= HandleOpportunityChanged;
        DataSync.OnBaseResumeChanged -= HandleBaseResumeChanged;
        DataSync.OnBaseResumeVersionChanged -= HandleBaseResumeVersionChanged;
        DataSync.OnSessionChanged -= HandleSessionChanged;
        DataSync.OnSessionsCleared -= HandleSessionsCleared;
    }

    // ── Scroll helpers ────────────────────────────────────────────────────────

    Task ScrollToAsync(string id) =>
        JS.InvokeVoidAsync("sjaScrollTo", id).AsTask();

    async Task EvaluateWithScrollAsync()
    {
        await ScrollToAsync("lane-evaluation");
        await EvaluateAsync();
    }

    async Task GenerateWithScrollAsync()
    {
        await ScrollToAsync("lane-generated");
        await GenerateAsync();
    }

    // ── Progress step state ───────────────────────────────────────────────────

    string StepClass(int step) => step switch
    {
        1 => (_roleFieldsLocked && !_editingPostEvaluate) ? "completed" : "active",
        2 => _materials is not null                       ? "completed"
           : (_roleFieldsLocked && !_editingPostEvaluate) ? "active"
                                                          : "",
        3 => _materials is not null                       ? "active" : "",
        _ => ""
    };

    // ── Org combobox handlers (M6-2) ──────────────────────────────────────────

    async Task OnOrgTextChanged()
    {
        _orgText = _orgText.Trim();
        _showOrgDropdown = false;

        if (string.IsNullOrWhiteSpace(_orgText))
        {
            if (_linkedOrgId is not null || _evaluation is not null || _materials is not null)
            {
                _linkedOrgId = null;
                _linkedOrgName = null;
                _linkedOppId = null;
                _linkedOppRole = null;
                _linkedOppRoleDesc = null;
                _entitySelectionLocked = false;
                _opportunities.Clear();
                DiscardEvaluation();
            }
            _orgSuggestions.Clear();
            RecalculateUnsavedChangesBanner();
            return;
        }

        var exactMatch = _organizations.FirstOrDefault(o =>
            string.Equals(o.Name.Trim(), _orgText.Trim(), StringComparison.OrdinalIgnoreCase));

        if (exactMatch is not null)
        {
            _orgText = exactMatch.Name;
            if (_linkedOrgId != exactMatch.Id)
            {
                _linkedOrgId = exactMatch.Id;
                _linkedOrgName = exactMatch.Name;
                _opportunities = await Db.GetOpportunitiesByOrganizationAsync(exactMatch.Id);
            }
            _orgSuggestions.Clear();
        }
        else
        {
            if (_linkedOrgId is not null)
            {
                _linkedOrgId = null;
                _linkedOrgName = null;
                _linkedOppId = null;
                _linkedOppRole = null;
                _linkedOppRoleDesc = null;
                _entitySelectionLocked = false;
                _opportunities.Clear();
                DiscardEvaluation();
            }

            _orgSuggestions = _organizations
                .Where(o => o.Name.Contains(_orgText, StringComparison.OrdinalIgnoreCase))
                .Take(8)
                .ToList();
            _showOrgDropdown = _orgSuggestions.Count > 0;
        }

        RecalculateUnsavedChangesBanner();
    }

    void OnOrgBlur()
    {
        _showOrgDropdown = false;
        if (string.IsNullOrWhiteSpace(_orgText) || _linkedOrgId is not null) return;

        var exactMatch = _organizations.FirstOrDefault(o =>
            string.Equals(o.Name.Trim(), _orgText.Trim(), StringComparison.OrdinalIgnoreCase));
        if (exactMatch is not null)
        {
            _orgText = exactMatch.Name;
            _linkedOrgId = exactMatch.Id;
            _linkedOrgName = exactMatch.Name;
            _ = LoadOpportunitiesAsync(exactMatch.Id);
        }
    }

    async Task SelectOrgSuggestion(Organization org)
    {
        _orgText = org.Name;
        _showOrgDropdown = false;
        _orgSuggestions.Clear();
        if (_linkedOrgId != org.Id)
        {
            _linkedOrgId = org.Id;
            _linkedOrgName = org.Name;
            _opportunities = await Db.GetOpportunitiesByOrganizationAsync(org.Id);
        }
        RecalculateUnsavedChangesBanner();
    }

    async Task LoadOpportunitiesAsync(string orgId)
    {
        _opportunities = await Db.GetOpportunitiesByOrganizationAsync(orgId);
        StateHasChanged();
    }

    void ClearOrganization()
    {
        _orgText = "";
        _linkedOrgId = null;
        _linkedOrgName = null;
        _linkedOppId = null;
        _linkedOppRole = null;
        _linkedOppRoleDesc = null;
        _entitySelectionLocked = false;
        _opportunities.Clear();
        _showUnsavedChangesBanner = false;
        DiscardEvaluation();
    }

    // ── Opportunity dropdown handlers (M6-2) ──────────────────────────────────

    async Task OnOppChanged(ChangeEventArgs e)
    {
        var oppId = (string?)e.Value;
        if (string.IsNullOrEmpty(oppId))
        {
            _linkedOppId = null;
            _linkedOppRole = null;
            _linkedOppRoleDesc = null;
            _entitySelectionLocked = false;
            RecalculateUnsavedChangesBanner();
            return;
        }

        var opp = _opportunities.FirstOrDefault(o => o.Id == oppId);
        if (opp is null) return;

        _linkedOppId = opp.Id;
        _linkedOppRole = opp.Role;
        _linkedOppRoleDesc = opp.RoleDescription;
        _entitySelectionLocked = true;

        if (!_roleFieldsLocked)
        {
            _role = opp.Role;
            _roleDescription = opp.RoleDescription;
        }

        RecalculateUnsavedChangesBanner();
        await Task.CompletedTask;
    }

    void ClearOpportunity()
    {
        _linkedOppId = null;
        _linkedOppRole = null;
        _linkedOppRoleDesc = null;
        _entitySelectionLocked = false;
        _showUnsavedChangesBanner = false;
    }

    // ── Role field handlers (M6-3) ────────────────────────────────────────────

    void OnRoleAfterBind()
    {
        _role = _role.Trim();
        if (_editingPostEvaluate) CheckRoleEditState();
        RecalculateUnsavedChangesBanner();
    }

    void OnRoleDescAfterBind()
    {
        _roleDescription = _roleDescription.Trim();
        if (_editingPostEvaluate) CheckRoleEditState();
        RecalculateUnsavedChangesBanner();
    }

    void EditRoleFields()
    {
        _editingPostEvaluate = true;
        _backedUpEvaluation = _evaluation;
        _backedUpMaterials = _materials;
        _backedUpTailoredResumeFileId = _tailoredResumeFileId;
        _backedUpCoverLetterFileId = _coverLetterFileId;
        _backedUpResumeMarkdown = _resumeMarkdown;
    }

    void CheckRoleEditState()
    {
        if (_role == _evalRoleSnapshot && _roleDescription == _evalRoleDescSnapshot)
        {
            // Exact revert — restore evaluation
            _evaluation = _backedUpEvaluation;
            _materials = _backedUpMaterials;
            _tailoredResumeFileId = _backedUpTailoredResumeFileId;
            _coverLetterFileId = _backedUpCoverLetterFileId;
            _resumeMarkdown = _backedUpResumeMarkdown;
            _roleFieldsLocked = true;
            _editingPostEvaluate = false;
        }
        else
        {
            // Field changed — discard evaluation
            DiscardEvaluation();
        }
        RecalculateUnsavedChangesBanner();
    }

    // ── Resume handlers (M6-1) ────────────────────────────────────────────────

    void OpenResumePicker() => _showResumePicker = true;

    void SelectResume(BaseResume resume)
    {
        var version = _latestVersions.GetValueOrDefault(resume.Id);
        if (version is null) return;

        bool isDifferent = _selectedResumeId != resume.Id;
        _selectedResumeId = resume.Id;
        _selectedVersionId = version.Id;
        _selectedResumeName = resume.Name;
        _selectedVersionNumber = version.VersionNumber;
        _selectedVersionIsLatest = true;
        _resumeDeleted = false;
        _showResumePicker = false;

        if (isDifferent && (_evaluation is not null || _materials is not null))
            DiscardEvaluation();
    }

    void ToggleResumePickerExpand(string resumeId)
    {
        _resumePickerExpanded[resumeId] = !_resumePickerExpanded.GetValueOrDefault(resumeId);
    }

    async Task ApplyAutoSelectResume()
    {
        _noResumesExist = _resumes.Count == 0;
        if (_resumes.Count != 1) return;

        var resume = _resumes[0];
        var version = _latestVersions.GetValueOrDefault(resume.Id);
        if (version is null) return;

        _selectedResumeId = resume.Id;
        _selectedVersionId = version.Id;
        _selectedResumeName = resume.Name;
        _selectedVersionNumber = version.VersionNumber;
        _selectedVersionIsLatest = true;
        _resumeDeleted = false;
        await Task.CompletedTask;
    }

    async Task LoadLatestVersionsAsync()
    {
        _latestVersions.Clear();
        foreach (var resume in _resumes)
        {
            var versions = await Db.GetVersionsByResumeAsync(resume.Id);
            _latestVersions[resume.Id] = versions.OrderByDescending(v => v.VersionNumber).FirstOrDefault();
        }
    }

    string ResumeDisplayLabel()
    {
        if (_selectedResumeName is null) return "";
        return _selectedVersionIsLatest
            ? $"{_selectedResumeName} (latest)"
            : $"{_selectedResumeName} (v{_selectedVersionNumber})";
    }

