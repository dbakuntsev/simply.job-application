        _saveOppOrgName = _orgText;
        _saveOppPostingUrl = "";
        _saveOppCompensationRange = "";
        _saveOppWorkArrangement = null;
        _saveOppConflictOrg = null;
        _saveOppOrgChoiceLink = true;
        _saveOppNewOrgName = "";
        _saveOppConflictOpp = null;
        _saveOppOppExactMatch = false;
        _saveOppOppChoiceLink = true;
        _saveOppSaving = false;
        _saveOppError = null;
        _showSaveOppModal = true;
    }

    void CloseSaveOppModal() => _showSaveOppModal = false;

    void SelectExistingOrgForSaveOpp() { _saveOppOrgChoiceLink = true; _saveOppNewOrgName = _saveOppConflictOrg?.Name ?? string.Empty; }

    async Task SaveOppNextAsync()
    {
        _saveOppSaving = true;
        _saveOppError = null;

        try
        {
            if (_saveOppStep == 0)
            {
                // Resolve org
                if (_linkedOrgId is null)
                {
                    var orgName = _saveOppOrgName.Trim();
                    var existingOrg = _organizations.FirstOrDefault(o =>
                        string.Equals(o.Name.Trim(), orgName, StringComparison.OrdinalIgnoreCase));
                    if (existingOrg is not null)
                    {
                        _saveOppConflictOrg = existingOrg;
                        _saveOppOrgChoiceLink = true;
                        _saveOppNewOrgName = orgName;
                        _saveOppStep = 1;
                        return;
                    }
                }
                // No org conflict — go straight to opp conflict check
                await CheckOppConflictAsync();
            }
            else if (_saveOppStep == 1)
            {
                // Org conflict resolved — check opp conflict
                await CheckOppConflictAsync();
            }
            else if (_saveOppStep == 2)
            {
                await CommitSaveOppAsync();
            }
        }
        catch (Exception ex)
        {
            _saveOppError = ex.Message;
        }
        finally
        {
            _saveOppSaving = false;
        }
    }

    async Task CheckOppConflictAsync()
    {
        var resolvedOrgId = await GetOrCreateOrgIdAsync(dryRun: true);
        if (resolvedOrgId is null) return;

        var orgOpps = await Db.GetOpportunitiesByOrganizationAsync(resolvedOrgId);
        var exactMatch = orgOpps.FirstOrDefault(o =>
            string.Equals(o.Role.Trim(), _role.Trim(), StringComparison.OrdinalIgnoreCase) &&
            string.Equals(o.RoleDescription.Trim(), _roleDescription.Trim(), StringComparison.OrdinalIgnoreCase));
        var roleMatch = exactMatch is null
            ? orgOpps.FirstOrDefault(o =>
                string.Equals(o.Role.Trim(), _role.Trim(), StringComparison.OrdinalIgnoreCase))
            : null;

        if (exactMatch is not null || roleMatch is not null)
        {
            _saveOppConflictOpp = exactMatch ?? roleMatch;
            _saveOppOppExactMatch = exactMatch is not null;
            _saveOppOppChoiceLink = exactMatch is not null;
            _saveOppStep = 2;
        }
        else
        {
            await CommitSaveOppAsync();
        }
    }

    async Task<string?> GetOrCreateOrgIdAsync(bool dryRun)
    {
        if (_linkedOrgId is not null) return _linkedOrgId;

        if (_saveOppStep == 0 || (_saveOppStep >= 1 && _saveOppOrgChoiceLink && _saveOppConflictOrg is not null))
        {
            // Link to existing
            if (_saveOppConflictOrg is not null) return _saveOppConflictOrg.Id;
            // No conflict found — will create new
        }

        if (!dryRun)
        {
            var name = (_saveOppStep >= 1 && !_saveOppOrgChoiceLink)
                ? _saveOppNewOrgName.Trim()
                : _saveOppOrgName.Trim();
            var newOrg = new Organization { Name = name };
            await Db.SaveOrganizationAsync(newOrg);
            await DataSync.BroadcastAsync("organization", newOrg.Id, "created");
            _organizations = await Db.GetAllOrganizationsAsync();
            return newOrg.Id;
        }

        // Dry run: use a placeholder to load the org's existing opps
        // For dry run when we'd create a new org, there are no existing opps
        return "__new__";
    }

    async Task CommitSaveOppAsync()
    {
        // Resolve org
        string resolvedOrgId;
        string resolvedOrgName;

        if (_linkedOrgId is not null)
        {
            resolvedOrgId = _linkedOrgId;
            resolvedOrgName = _linkedOrgName!;
        }
        else if (_saveOppStep >= 1 && _saveOppOrgChoiceLink && _saveOppConflictOrg is not null)
        {
            resolvedOrgId = _saveOppConflictOrg.Id;
            resolvedOrgName = _saveOppConflictOrg.Name;
        }
        else
        {
            var name = (_saveOppStep >= 1 && !_saveOppOrgChoiceLink)
                ? _saveOppNewOrgName.Trim()
                : _saveOppOrgName.Trim();
            var newOrg = new Organization { Name = name };
            await Db.SaveOrganizationAsync(newOrg);
            await DataSync.BroadcastAsync("organization", newOrg.Id, "created");
            _organizations = await Db.GetAllOrganizationsAsync();
            resolvedOrgId = newOrg.Id;
            resolvedOrgName = newOrg.Name;
        }

        // Resolve opp
        string resolvedOppId;
        string resolvedOppRole;

        if (_saveOppStep >= 2 && _saveOppOppChoiceLink && _saveOppOppExactMatch && _saveOppConflictOpp is not null)
        {
            resolvedOppId = _saveOppConflictOpp.Id;
            resolvedOppRole = _saveOppConflictOpp.Role;
        }
        else
        {
            var newOpp = new Opportunity
            {
                OrganizationId    = resolvedOrgId,
                Role              = _role,
                RoleDescription   = _roleDescription,
                PostingUrl        = _saveOppPostingUrl,
                CompensationRange = _saveOppCompensationRange,
                WorkArrangement   = _saveOppWorkArrangement,
                Stage             = OpportunityStage.Open,
            };
            await Db.SaveOpportunityAsync(newOpp);
            await DataSync.BroadcastAsync("opportunity", newOpp.Id, "created");
            resolvedOppId = newOpp.Id;
            resolvedOppRole = newOpp.Role;
        }

        // Update E&G state
        _linkedOrgId = resolvedOrgId;
        _linkedOrgName = resolvedOrgName;
        _orgText = resolvedOrgName;
        _linkedOppId = resolvedOppId;
        _linkedOppRole = resolvedOppRole;
        _linkedOppRoleDesc = _roleDescription;
        _entitySelectionLocked = true;
        _opportunities = await Db.GetOpportunitiesByOrganizationAsync(resolvedOrgId);

        await SaveSessionAsync();
        await DataSync.BroadcastAsync("session", _sessionId!, "updated");

        _showSaveOppModal = false;
        RecalculateUnsavedChangesBanner();
    }

