    // ── Update Opportunity (M6-4) ──────────────────────────────────────────────

    async Task UpdateOpportunityAsync()
    {
        if (_linkedOppId is null) return;
        var opp = await Db.GetOpportunityAsync(_linkedOppId);
        if (opp is null) return;

        var changes = new List<FieldChange>();
        if (opp.Role != _role)
            changes.Add(new FieldChange { FieldName = "Role", OldValue = opp.Role });
        if (opp.RoleDescription != _roleDescription)
            changes.Add(new FieldChange { FieldName = "RoleDescription", OldValue = opp.RoleDescription });

        if (changes.Count == 0) { _showUnsavedChangesBanner = false; return; }

        opp.Role = _role;
        opp.RoleDescription = _roleDescription;
        opp.UpdatedAt = DateTime.UtcNow;

        var result = await Db.VersionedWriteAsync("opportunities", opp, new[] { $"org:{opp.OrganizationId}", $"opp:{opp.Id}" });
        if (result == VersionedWriteResult.Success)
        {
            await Db.SaveHistoryEntryAsync(new OpportunityFieldHistory
            {
                Id            = Guid.NewGuid().ToString(),
                OpportunityId = opp.Id,
                ChangedAt     = DateTime.UtcNow,
                Source        = HistorySource.EvaluateAndGenerate,
                Changes       = changes,
            });
            _linkedOppRole = _role;
            _linkedOppRoleDesc = _roleDescription;
            await DataSync.BroadcastAsync("opportunity", opp.Id, "updated");
        }
        RecalculateUnsavedChangesBanner();
    }

