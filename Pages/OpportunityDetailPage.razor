@page "/opportunities/{Id}"
@inherits NavigationGuardBase
@inject IIndexedDbService Db
@inject IDataSyncService DataSync
@inject IAiProviderFactory Providers
@inject AppStateService AppState
@inject NavigationManager Nav
@using System.Text.Json

<PageTitle>@(_opp?.Role ?? "Opportunity") — Simply Job Application</PageTitle>

<NavigationLock OnBeforeInternalNavigation="HandleLocationChanging" />
<NavigationGuardModal Show="_showGuardModal" StayLabel="@StayLabel" LeaveLabel="@LeaveLabel"
                      OnStay="() => OnGuardStay()" OnLeave="() => OnGuardLeave()" />

<ConflictAlertModal Show="_showConflictAlert"
                    Message="@_conflictMessage"
                    ShowKeepEditing="@_conflictShowKeepEditing"
                    OnDiscardAndReload="HandleConflictDiscardAndReload"
                    OnKeepEditing="HandleConflictKeepEditing" />

<DeletionAlertModal Show="_showDeletionAlert"
                    Message="@_deletionMessage"
                    OnDismiss="HandleDeletionDismiss" />

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else if (_opp is null)
{
    <div class="alert alert-warning">Opportunity not found.</div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/organizations">Organizations</a></li>
            @if (_org is not null)
            {
                <li class="breadcrumb-item">
                    <a href="/organizations/@_opp.OrganizationId">@_org.Name</a>
                </li>
            }
            <li class="breadcrumb-item active">@_opp.Role</li>
        </ol>
    </nav>

    @* ── Header section ────────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@(_isEditing ? _editOpp.Role : _opp.Role)</h5>
            <div class="d-flex gap-2 align-items-center">
                @if (!_isEditing)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="StartEdit">Edit</button>
                    <button class="btn btn-sm btn-outline-primary" @onclick="NavigateToEvaluate">
                        Evaluate &amp; Generate
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                    <button class="btn btn-sm btn-primary" @onclick="SaveEditAsync"
                            disabled="@(!CanSaveEdit || _savingEdit)">
                        @(_savingEdit ? "Saving…" : "Save")
                    </button>
                }
            </div>
        </div>
        <div class="card-body">
            @if (!_isEditing)
            {
                <dl class="row mb-0">
                    <dt class="col-sm-3">Organization</dt>
                    <dd class="col-sm-9">
                        @if (_org is not null)
                        {
                            <a href="/organizations/@_opp.OrganizationId">@_org.Name</a>
                        }
                        else { <span>—</span> }
                    </dd>
                    <dt class="col-sm-3">Stage</dt>
                    <dd class="col-sm-9">
                        <select class="form-select form-select-sm" style="max-width:200px"
                                value="@_opp.Stage"
                                @onchange="HandleStageQuickEdit">
                            @foreach (var s in Enum.GetValues<OpportunityStage>())
                            {
                                <option value="@s">@StageName(s)</option>
                            }
                        </select>
                        @if (_stageSaving)
                        {
                            <span class="text-muted small ms-2">Saving…</span>
                        }
                    </dd>
                    <dt class="col-sm-3">Work Arrangement</dt>
                    <dd class="col-sm-9">@(_opp.WorkArrangement is null ? "—" : WorkArrangementLabel(_opp.WorkArrangement.Value))</dd>
                    <dt class="col-sm-3">Compensation</dt>
                    <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(_opp.CompensationRange) ? "—" : _opp.CompensationRange)</dd>
                    <dt class="col-sm-3">Posting URL</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrWhiteSpace(_opp.PostingUrl))
                        {
                            <a href="@_opp.PostingUrl" target="_blank" rel="noopener noreferrer">@_opp.PostingUrl</a>
                        }
                        else { <span>—</span> }
                    </dd>
                    <dt class="col-sm-3 text-muted small">Created</dt>
                    <dd class="col-sm-9 text-muted small">@_opp.CreatedAt.ToLocalTime().ToString("g")</dd>
                    <dt class="col-sm-3 text-muted small">Updated</dt>
                    <dd class="col-sm-9 text-muted small">@_opp.UpdatedAt.ToLocalTime().ToString("g")</dd>
                </dl>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_editOpp.Role" @bind:event="oninput" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Organization</label>
                        <div class="form-control-plaintext">@(_org?.Name ?? "—")</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Stage</label>
                        <select class="form-select" @bind="_editStageStr">
                            @foreach (var s in Enum.GetValues<OpportunityStage>())
                            {
                                <option value="@s">@StageName(s)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Work Arrangement</label>
                        <select class="form-select" @bind="_editWorkArrangementStr">
                            <option value="">— Select —</option>
                            <option value="Remote">Remote</option>
                            <option value="Hybrid">Hybrid</option>
                            <option value="OnSite">On-site</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Compensation Range</label>
                        <input class="form-control" @bind="_editOpp.CompensationRange" placeholder="e.g. $120k–$150k" />
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-semibold">Posting URL</label>
                        <input class="form-control" @bind="_editOpp.PostingUrl" placeholder="https://" />
                    </div>
                </div>
                @if (_editSaveError is not null)
                {
                    <div class="alert alert-danger mt-3 mb-0">@_editSaveError</div>
                }
            }
        </div>
    </div>

    @* ── Role Description ──────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Role Description</h5>
            <div class="d-flex gap-2">
                @if (!_isEditing)
                {
                    @if (!string.IsNullOrWhiteSpace(_opp.RoleDescription))
                    {
                        @if (_extractingQuals)
                        {
                            <span class="text-muted small align-self-center">Extracting…</span>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="TryExtractQualificationsAsync">
                                Extract Qualifications
                            </button>
                        }
                    }
                    <button class="btn btn-sm btn-link text-muted p-0"
                            @onclick="() => _showHistoryModal = true">
                        Show Change History
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-outline-primary" disabled
                            title="Not available in Edit mode">
                        Extract Qualifications
                    </button>
                }
            </div>
        </div>
        <div class="card-body">
            @if (_extractError is not null)
            {
                <div class="alert alert-danger mb-3">@_extractError</div>
            }
            @if (!_isEditing)
            {
                @if (string.IsNullOrWhiteSpace(_opp.RoleDescription))
                {
                    <div class="text-muted fst-italic">No role description yet — enter one in Edit mode.</div>
                }
                else
                {
                    <pre class="mb-0" style="white-space:pre-wrap;font-family:inherit;max-height:300px;overflow-y:auto">@_opp.RoleDescription</pre>
                }
            }
            else
            {
                <textarea class="form-control" rows="8" @bind="_editOpp.RoleDescription"
                          placeholder="Paste or type the role description here…"></textarea>
            }
        </div>
    </div>

    @* ── Qualifications ────────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Qualifications</h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                @* Required *@
                <div class="col-md-6">
                    <h6 class="fw-semibold">Required</h6>
                    @if (!_isEditing)
                    {
                        @if (_opp.RequiredQualifications.Length == 0)
                        {
                            <div class="text-muted fst-italic small">None listed.</div>
                        }
                        else
                        {
                            <ul class="mb-0">
                                @foreach (var q in _opp.RequiredQualifications)
                                {
                                    <li>@q</li>
                                }
                            </ul>
                        }
                    }
                    else
                    {
                        @foreach (var (q, i) in _editRequired.Select((q, i) => (q, i)))
                        {
                            <div class="input-group mb-1">
                                <input class="form-control form-control-sm"
                                       value="@q"
                                       @onchange="e => _editRequired[i] = e.Value?.ToString() ?? string.Empty" />
                                <button class="btn btn-outline-danger btn-sm"
                                        @onclick="() => _editRequired.RemoveAt(i)">×</button>
                            </div>
                        }
                        <button class="btn btn-outline-secondary btn-sm mt-1"
                                @onclick="() => _editRequired.Add(string.Empty)">+ Add</button>
                    }
                </div>
                @* Preferred *@
                <div class="col-md-6">
                    <h6 class="fw-semibold">Preferred</h6>
                    @if (!_isEditing)
                    {
                        @if (_opp.PreferredQualifications.Length == 0)
                        {
                            <div class="text-muted fst-italic small">None listed.</div>
                        }
                        else
                        {
                            <ul class="mb-0">
                                @foreach (var q in _opp.PreferredQualifications)
                                {
                                    <li>@q</li>
                                }
                            </ul>
                        }
                    }
                    else
                    {
                        @foreach (var (q, i) in _editPreferred.Select((q, i) => (q, i)))
                        {
                            <div class="input-group mb-1">
                                <input class="form-control form-control-sm"
                                       value="@q"
                                       @onchange="e => _editPreferred[i] = e.Value?.ToString() ?? string.Empty" />
                                <button class="btn btn-outline-danger btn-sm"
                                        @onclick="() => _editPreferred.RemoveAt(i)">×</button>
                            </div>
                        }
                        <button class="btn btn-outline-secondary btn-sm mt-1"
                                @onclick="() => _editPreferred.Add(string.Empty)">+ Add</button>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ── Correspondence section ───────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Correspondence</h5>
            @if (!_isEditing)
            {
                <div class="dropdown @(_showAddCorrDropdown ? "show" : "")">
                    <button class="btn btn-sm btn-primary dropdown-toggle" type="button"
                            @onclick="() => _showAddCorrDropdown = !_showAddCorrDropdown">
                        Add
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end @(_showAddCorrDropdown ? "show" : "")">
                        @foreach (var ct in Enum.GetValues<CorrespondenceType>())
                        {
                            var captured = ct;
                            <li>
                                <a class="dropdown-item" href="#" @onclick:preventDefault
                                   @onclick="() => OpenAddCorrespondence(captured)">
                                    @CorrTypeLabel(captured)
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
        <div class="card-body p-0">
            @if (_correspondence.Count == 0)
            {
                <div class="px-3 py-3 text-muted">No correspondence yet.</div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3" style="width:140px">Date / Time</th>
                            <th style="width:180px">Type</th>
                            <th>Content</th>
                            <th style="width:160px">Contact</th>
                            <th class="text-center" style="width:60px">Files</th>
                            <th style="width:1%"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var corr in _correspondence.OrderByDescending(c => c.OccurredAt))
                        {
                            <tr style="cursor:pointer" @onclick="() => OpenEditCorrespondence(corr)">
                                <td class="ps-3 small text-muted">@corr.OccurredAt.ToLocalTime().ToString("g")</td>
                                <td class="small">@GetTypeDirectionLabel(corr)</td>
                                <td class="small text-muted text-truncate" style="max-width:250px">@GetCorrContentPreview(corr)</td>
                                <td class="small text-muted">@GetCorrContactDisplay(corr)</td>
                                <td class="text-center small text-muted">
                                    @(_correspondenceFileCounts.TryGetValue(corr.Id, out var cnt) && cnt > 0 ? cnt.ToString() : "—")
                                </td>
                                <td class="pe-2" @onclick:stopPropagation>
                                    @if (!_isEditing)
                                    {
                                        <button class="btn btn-sm btn-outline-danger"
                                                title="Delete correspondence"
                                                @onclick="() => _deleteCorrespondenceTarget = corr">
                                            @TrashIcon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* ── Contacts section ──────────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Contacts</h5>
            @if (!_isEditing)
            {
                <div class="d-flex gap-2 align-items-center">
                    @{
                        var unassociated = UnassociatedContacts;
                        var allAssociated = _orgContacts.Count > 0 && unassociated.Count == 0;
                        var noContacts = _orgContacts.Count == 0;
                    }
                    <select class="form-select form-select-sm" style="max-width:220px"
                            disabled="@(noContacts || allAssociated || _addingContact)"
                            title="@(noContacts ? "No contacts in this organization" : allAssociated ? "All contacts already associated" : null)"
                            @onchange="HandleAddContact">
                        <option value="">Add contact…</option>
                        @foreach (var c in unassociated)
                        {
                            <option value="@c.Id">@c.FullName</option>
                        }
                    </select>
                </div>
            }
        </div>
        <div class="card-body p-0">
            @if (_contactRoles.Count == 0)
            {
                <div class="px-3 py-3 text-muted">No contacts associated with this opportunity yet.</div>
            }
            else
            {
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">Name</th>
                            <th>Title</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th style="min-width:220px">Roles</th>
                            <th style="width:1%"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var role in _contactRoles)
                        {
                            var contact = _orgContacts.FirstOrDefault(c => c.Id == role.ContactId);
                            if (contact is null) continue;
                            <tr>
                                <td class="ps-3 fw-semibold">@contact.FullName</td>
                                <td class="text-muted small">@(string.IsNullOrWhiteSpace(contact.Title) ? "—" : contact.Title)</td>
                                <td class="text-muted small">@(string.IsNullOrWhiteSpace(contact.Email) ? "—" : contact.Email)</td>
                                <td class="text-muted small">@(string.IsNullOrWhiteSpace(contact.Phone) ? "—" : contact.Phone)</td>
                                <td>
                                    @if (!_isEditing)
                                    {
                                        <TagPicker @key="@($"tag-{role.ContactId}-{_tagPickerKey}")"
                                                   AvailableOptions="_contactRoleLabels"
                                                   SelectedValues="role.Roles"
                                                   AllowCreate="true"
                                                   OnChanged="vals => HandleRoleTagsChanged(role, vals)" />
                                    }
                                </td>
                                <td class="pe-2">
                                    @if (!_isEditing)
                                    {
                                        <button class="btn btn-sm btn-outline-danger"
                                                title="Remove @contact.FullName from this opportunity"
                                                @onclick="() => _removeRoleTarget = role">
                                            @TrashIcon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @* ── E&G Sessions section ──────────────────────────────────────────────────── *@
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">E&amp;G Sessions</h5>
        </div>
        <div class="card-body p-0">
            @if (_sessions.Count == 0)
            {
                <div class="px-3 py-3 text-muted">No E&amp;G sessions yet.</div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-3">Date / Time</th>
                            <th>Resume</th>
                            <th class="text-center" style="width:100px">Match Score</th>
                            <th class="text-center" style="width:80px">Artifacts</th>
                            <th style="width:1%"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in _sessions)
                        {
                            <tr style="cursor:pointer"
                                @onclick="() => NavigateToSession(session.Id)">
                                <td class="ps-3 small text-muted">@session.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td class="small text-muted">@GetResumeDisplay(session)</td>
                                <td class="text-center small">
                                    @(string.IsNullOrWhiteSpace(session.MatchScore) ? "—" : session.MatchScore)
                                </td>
                                <td class="text-center">
                                    @if (session.ArtifactsGenerated) { @CheckIcon }
                                </td>
                                <td class="pe-2" @onclick:stopPropagation>
                                    @if (!_isEditing)
                                    {
                                        <button class="btn btn-sm btn-outline-danger"
                                                title="Delete session"
                                                @onclick="() => _deleteSessionTarget = session">
                                            @TrashIcon
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@* ── Correspondence Add/Edit modal ──────────────────────────────────────────── *@
@if (_showCorrespondenceModal)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true"
         style="background:rgba(0,0,0,.45)" @onclick="HandleCorrModalBackdropClick">
        <div class="modal-dialog modal-lg" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@GetCorrModalTitle()</h5>
                    <button type="button" class="btn-close" @onclick="HandleCorrModalClose"></button>
                </div>
                <div class="modal-body">
                    @if (_corrSaveError is not null)
                    {
                        <div class="alert alert-danger">@_corrSaveError</div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Date / Time</label>
                        <input type="datetime-local" class="form-control"
                               value="@_modalCorr.OccurredAt.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")"
                               @onchange="e => _modalCorr.OccurredAt = ParseDateTimeLocal(e.Value?.ToString())" />
                    </div>

                    @if (TypeHasDirection(_modalCorr.Type))
                    {
                        var (inLbl, outLbl) = GetDirectionLabels(_modalCorr.Type);
                        <div class="mb-3">
                            <label class="form-label">Direction</label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" id="corr-dir-in" name="corrdir" autocomplete="off"
                                       checked="@(_modalCorr.Direction == CorrespondenceDirection.Incoming)"
                                       @onchange="() => _modalCorr.Direction = CorrespondenceDirection.Incoming" />
                                <label class="btn btn-outline-primary" for="corr-dir-in">@inLbl</label>
                                <input type="radio" class="btn-check" id="corr-dir-out" name="corrdir" autocomplete="off"
                                       checked="@(_modalCorr.Direction == CorrespondenceDirection.Outgoing)"
                                       @onchange="() => _modalCorr.Direction = CorrespondenceDirection.Outgoing" />
                                <label class="btn btn-outline-primary" for="corr-dir-out">@outLbl</label>
                            </div>
                        </div>
                    }

                    @if (_modalCorr.Type == CorrespondenceType.Email)
                    {
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input class="form-control" @bind="_modalCorr.Subject" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Contact <span class="text-muted fw-normal small">(optional)</span></label>
                        <select class="form-select"
                                value="@(_modalCorr.ContactId ?? "")"
                                @onchange="e => _modalCorr.ContactId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString()">
                            <option value="">— none —</option>
                            @if (DanglingContactId is not null)
                            {
                                <option value="@DanglingContactId">(deleted)</option>
                            }
                            @foreach (var c in _orgContacts.OrderBy(c => c.FullName, StringComparer.OrdinalIgnoreCase))
                            {
                                <option value="@c.Id">@c.FullName</option>
                            }
                        </select>
                    </div>

                    @if (_modalCorr.Type == CorrespondenceType.ResumeSubmitted)
                    {
                        var noSessions = !_sessions.Any() && DanglingSessionId is null;
                        <div class="mb-3">
                            <label class="form-label">Session <span class="text-muted fw-normal small">(optional)</span></label>
                            <select class="form-select" disabled="@noSessions"
                                    value="@(_modalCorr.LinkedSessionId ?? "")"
                                    @onchange="e => _modalCorr.LinkedSessionId = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString()">
                                <option value="">— none —</option>
                                @if (DanglingSessionId is not null)
                                {
                                    <option value="@DanglingSessionId">(deleted)</option>
                                }
                                @foreach (var s in _sessions.OrderByDescending(s => s.CreatedAt))
                                {
                                    <option value="@s.Id">@s.CreatedAt.ToLocalTime().ToString("g") – @s.Role</option>
                                }
                            </select>
                            @if (noSessions)
                            {
                                <div class="form-text">No sessions available for this opportunity.</div>
                            }
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="corr-coverletter"
                                       @bind="_modalCorr.CoverLetterSubmitted" />
                                <label class="form-check-label" for="corr-coverletter">Cover Letter Submitted</label>
                            </div>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Body / Notes</label>
                        <MarkdownEditor Value="@_modalCorr.Body" ValueChanged="v => _modalCorr.Body = v" Height="200px" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Attachments</label>
                        @if (_fileUploadError is not null)
                        {
                            <div class="alert alert-warning py-1 px-2 small mb-2">@_fileUploadError</div>
                        }
                        <InputFile OnChange="HandleCorrFileSelected" multiple class="form-control form-control-sm mb-2" />
                        @if (_modalExistingFiles.Count > 0 || _modalNewFiles.Count > 0)
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var f in _modalExistingFiles)
                                {
                                    var ef = f;
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-1 px-0">
                                        <span class="small">@ef.FileName <span class="text-muted">(@FormatFileSize(ef.FileSize))</span></span>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => DownloadExistingFile(ef)">Download</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveExistingFile(ef.Id)">Remove</button>
                                        </div>
                                    </li>
                                }
                                @foreach (var f in _modalNewFiles)
                                {
                                    var nf = f;
                                    <li class="list-group-item d-flex justify-content-between align-items-center py-1 px-0">
                                        <span class="small text-success">@nf.FileName <span class="text-muted">(@FormatFileSize(nf.FileSize))</span></span>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveStagedFile(nf)">Remove</button>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="HandleCorrModalClose" disabled="@_savingCorr">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveCorrespondenceAsync" disabled="@_savingCorr">
                        @(_savingCorr ? "Saving…" : "Save")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Extract qualifications confirmation ────────────────────────────────────── *@
@if (_showExtractConfirm)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true"
         style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Extract Qualifications</h5>
                </div>
                <div class="modal-body">
                    The qualifications lists already have content. Extracting will replace them.
                    Do you want to continue?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => _showExtractConfirm = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="RunExtractQualificationsAsync">Continue</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Change History modal ────────────────────────────────────────────────────── *@
@if (_showHistoryModal)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true"
         style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Change History</h5>
                    <button type="button" class="btn-close" @onclick="() => _showHistoryModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    @if (_history.Count == 0)
                    {
                        <div class="p-3 text-muted">No change history yet.</div>
                    }
                    else
                    {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th class="ps-3" style="width:160px">When</th>
                                    <th style="width:160px">Source</th>
                                    <th>Changed Fields (old values)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var h in _history.OrderByDescending(h => h.ChangedAt))
                                {
                                    <tr>
                                        <td class="ps-3 small text-muted">@h.ChangedAt.ToLocalTime().ToString("g")</td>
                                        <td class="small">@HistorySourceLabel(h.Source)</td>
                                        <td class="small">
                                            @foreach (var fc in h.Changes)
                                            {
                                                <div>
                                                    <span class="fw-semibold">@fc.FieldName:</span>
                                                    <span class="text-muted">@fc.OldValue</span>
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" @onclick="() => _showHistoryModal = false">Close</button>
                </div>
            </div>
        </div>
    </div>
}

