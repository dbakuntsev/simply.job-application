    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (_currentId == Id) return;
        _currentId = Id;
        UnsubscribeEvents();
        SubscribeEvents();
        await LoadAsync();
    }

    public override async ValueTask DisposeAsync()
    {
        UnsubscribeEvents();
        await base.DisposeAsync();
    }

    private void SubscribeEvents()
    {
        DataSync.OnOpportunityChanged             += HandleOppChangedRemote;
        DataSync.OnOpportunityFieldHistoryChanged += HandleHistoryChanged;
        DataSync.OnContactChanged                 += HandleContactChanged;
        DataSync.OnContactOpportunityRoleChanged  += HandleRoleChanged;
        DataSync.OnOrganizationChanged            += HandleOrgChanged;
        DataSync.OnSessionChanged                 += HandleSessionChanged;
        DataSync.OnCorrespondenceChanged          += HandleCorrespondenceChanged;
        DataSync.OnCorrespondenceFileChanged      += HandleCorrFileChanged;
    }

    private void UnsubscribeEvents()
    {
        DataSync.OnOpportunityChanged             -= HandleOppChangedRemote;
        DataSync.OnOpportunityFieldHistoryChanged -= HandleHistoryChanged;
        DataSync.OnContactChanged                 -= HandleContactChanged;
        DataSync.OnContactOpportunityRoleChanged  -= HandleRoleChanged;
        DataSync.OnOrganizationChanged            -= HandleOrgChanged;
        DataSync.OnSessionChanged                 -= HandleSessionChanged;
        DataSync.OnCorrespondenceChanged          -= HandleCorrespondenceChanged;
        DataSync.OnCorrespondenceFileChanged      -= HandleCorrFileChanged;
    }

    // ── Data loading ──────────────────────────────────────────────────────────

    private async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();

        _opp = await Db.GetOpportunityAsync(Id);
        if (_opp is null) { _loading = false; return; }

        _org = await Db.GetOrganizationAsync(_opp.OrganizationId);
        _orgContacts = (await Db.GetContactsByOrganizationAsync(_opp.OrganizationId))
            .OrderBy(c => c.FullName, StringComparer.OrdinalIgnoreCase).ToList();
        _contactRoles = await Db.GetRolesByOpportunityAsync(Id);
        _contactRoleLabels = (await Db.GetLookupValuesAsync("lookupContactRoles"))
            .Select(v => v.Value).ToList();

        var allSessions = await Db.GetAllSessionsAsync();
        _sessions = allSessions
            .Where(s => s.OpportunityId == Id)
            .OrderByDescending(s => s.CreatedAt).ToList();

        _history = await Db.GetHistoryByOpportunityAsync(Id);

        await LoadCorrespondenceAsync();

        _loading = false;
    }

    // ── Navigate to E&G ──────────────────────────────────────────────────────

    private void NavigateToEvaluate()
    {
        if (_opp is null) return;
        AppState.ContextualOrgId      = _opp.OrganizationId;
        AppState.ContextualOrgName    = _org?.Name ?? "";
        AppState.ContextualOppId      = _opp.Id;
        AppState.ContextualOppRole    = _opp.Role;
        AppState.ContextualOppRoleDesc = _opp.RoleDescription;
        Nav.NavigateTo("/evaluate");
    }

    // ── Edit mode ─────────────────────────────────────────────────────────────

    private void StartEdit()
    {
        if (_opp is null) return;
        _editOpp = new Opportunity
        {
            Id = _opp.Id,
            Version = _opp.Version,
            OrganizationId = _opp.OrganizationId,
            Role = _opp.Role,
            RoleDescription = _opp.RoleDescription,
            PostingUrl = _opp.PostingUrl,
            CompensationRange = _opp.CompensationRange,
            Stage = _opp.Stage,
            WorkArrangement = _opp.WorkArrangement,
            RequiredQualifications = _opp.RequiredQualifications.ToArray(),
            PreferredQualifications = _opp.PreferredQualifications.ToArray(),
            CreatedAt = _opp.CreatedAt,
            UpdatedAt = _opp.UpdatedAt,
        };
        _editStageStr = _opp.Stage.ToString();
        _editWorkArrangementStr = _opp.WorkArrangement?.ToString() ?? "";
        _editRequired = _opp.RequiredQualifications.ToList();
        _editPreferred = _opp.PreferredQualifications.ToList();
        _editSaveError = null;
        _isEditing = true;
    }

    private void CancelEdit()
    {
        _isEditing = false;
        _editSaveError = null;
    }

    private async Task SaveEditAsync()
    {
        if (!CanSaveEdit || _savingEdit || _opp is null) return;
        _savingEdit = true;
        _editSaveError = null;

        var newStage = Enum.TryParse<OpportunityStage>(_editStageStr, out var s) ? s : _opp.Stage;
        var newWa = _editWorkArrangementStr switch
        {
            "Remote" => (WorkArrangement?)WorkArrangement.Remote,
            "Hybrid" => WorkArrangement.Hybrid,
            "OnSite" => WorkArrangement.OnSite,
            _ => null,
        };

        // Collect field changes (reverse delta — old values)
        var changes = new List<FieldChange>();
        if (_editOpp.Role != _opp.Role)
            changes.Add(new FieldChange { FieldName = "Role", OldValue = _opp.Role });
        if (newStage != _opp.Stage)
            changes.Add(new FieldChange { FieldName = "Stage", OldValue = StageName(_opp.Stage) });
        if (_editOpp.RoleDescription != _opp.RoleDescription)
            changes.Add(new FieldChange { FieldName = "RoleDescription", OldValue = _opp.RoleDescription });
        if (newWa != _opp.WorkArrangement)
            changes.Add(new FieldChange { FieldName = "WorkArrangement", OldValue = _opp.WorkArrangement is null ? "" : WorkArrangementLabel(_opp.WorkArrangement.Value) });
        if (_editOpp.CompensationRange != _opp.CompensationRange)
            changes.Add(new FieldChange { FieldName = "CompensationRange", OldValue = _opp.CompensationRange });
        if (_editOpp.PostingUrl != _opp.PostingUrl)
            changes.Add(new FieldChange { FieldName = "PostingUrl", OldValue = _opp.PostingUrl });
        if (!_editRequired.SequenceEqual(_opp.RequiredQualifications))
            changes.Add(new FieldChange { FieldName = "RequiredQualifications", OldValue = JsonSerializer.Serialize(_opp.RequiredQualifications) });
        if (!_editPreferred.SequenceEqual(_opp.PreferredQualifications))
            changes.Add(new FieldChange { FieldName = "PreferredQualifications", OldValue = JsonSerializer.Serialize(_opp.PreferredQualifications) });

        _editOpp.Stage = newStage;
        _editOpp.WorkArrangement = newWa;
        _editOpp.RequiredQualifications = _editRequired.Where(q => !string.IsNullOrWhiteSpace(q)).ToArray();
        _editOpp.PreferredQualifications = _editPreferred.Where(q => !string.IsNullOrWhiteSpace(q)).ToArray();
        _editOpp.UpdatedAt = DateTime.UtcNow;

        var result = await Db.VersionedWriteAsync("opportunities", _editOpp, new[] { $"opp:{_editOpp.Id}" });

        if (result == VersionedWriteResult.Success)
        {
            if (changes.Count > 0)
            {
                var histEntry = new OpportunityFieldHistory
                {
                    OpportunityId = Id,
                    Source = HistorySource.DirectEdit,
                    Changes = changes,
                };
                await Db.SaveHistoryEntryAsync(histEntry);
                await DataSync.BroadcastAsync("opportunityFieldHistory", histEntry.Id, "create");
            }

            await DataSync.BroadcastAsync("opportunity", Id, "update");
            _opp = _editOpp;
            _isEditing = false;
            _savingEdit = false;
            _history = await Db.GetHistoryByOpportunityAsync(Id);
            return;
        }

        // VersionMismatch — show conflict modal, no Keep Editing
        _savingEdit = false;
        _isEditing = false;
        _conflictShowKeepEditing = false;
        _conflictMessage = "This opportunity was modified in another tab. Your changes have been discarded. Reload to see the current version.";
        _showConflictAlert = true;
    }

    // ── Stage quick-edit ──────────────────────────────────────────────────────

    private async Task HandleStageQuickEdit(ChangeEventArgs e)
    {
        if (_opp is null || _stageSaving) return;
        if (!Enum.TryParse<OpportunityStage>(e.Value?.ToString(), out var newStage)) return;
        if (newStage == _opp.Stage) return;

        _stageSaving = true;
        var oldStage = _opp.Stage;
        _opp.Stage = newStage;
        _opp.UpdatedAt = DateTime.UtcNow;

        var result = await Db.VersionedWriteAsync("opportunities", _opp, new[] { $"opp:{_opp.Id}" });
        if (result == VersionedWriteResult.Success)
        {
            var histEntry = new OpportunityFieldHistory
            {
                OpportunityId = Id,
                Source = HistorySource.StageQuickEdit,
                Changes = new List<FieldChange>
                {
                    new FieldChange { FieldName = "Stage", OldValue = StageName(oldStage) }
                },
            };
            await Db.SaveHistoryEntryAsync(histEntry);
            _history = await Db.GetHistoryByOpportunityAsync(Id);
            await DataSync.BroadcastAsync("opportunity", Id, "update");
            await DataSync.BroadcastAsync("opportunityFieldHistory", histEntry.Id, "create");
        }
        else
        {
            // Revert on conflict
            _opp.Stage = oldStage;
        }

        _stageSaving = false;
    }

    // ── AI Qualification Extraction ───────────────────────────────────────────

    private async Task TryExtractQualificationsAsync()
    {
        if (_opp is null) return;
        var hasContent = _opp.RequiredQualifications.Length > 0 || _opp.PreferredQualifications.Length > 0;
        if (hasContent)
        {
            _showExtractConfirm = true;
        }
        else
        {
            await RunExtractQualificationsAsync();
        }
    }

    private async Task RunExtractQualificationsAsync()
    {
        if (_opp is null) return;
        _showExtractConfirm = false;
        _extractingQuals = true;
        _extractError = null;

        var settings = await Db.GetSettingsAsync();
        var apiKey = settings.ProviderApiKeys.GetValueOrDefault(settings.AiProvider) ?? "";
        if (string.IsNullOrWhiteSpace(apiKey))
        {
            _extractError = "No API key configured. Check Settings.";
            _extractingQuals = false;
            return;
        }
        var provider = Providers.Get(settings.AiProvider);
        var modelId = settings.ProviderModels.GetValueOrDefault(settings.AiProvider)
                      ?? provider.DefaultModelId;

        QualificationExtractionResult result;
        try
        {
            result = await provider.ExtractQualificationsAsync(
                _opp.RoleDescription,
                modelId,
                apiKey);
        }
        catch (Exception ex)
        {
            _extractError = $"AI extraction failed: {ex.Message}";
            _extractingQuals = false;
            return;
        }

        // Build history changes
        var changes = new List<FieldChange>();
        if (!result.Required.SequenceEqual(_opp.RequiredQualifications))
            changes.Add(new FieldChange { FieldName = "RequiredQualifications", OldValue = JsonSerializer.Serialize(_opp.RequiredQualifications) });
        if (!result.Preferred.SequenceEqual(_opp.PreferredQualifications))
            changes.Add(new FieldChange { FieldName = "PreferredQualifications", OldValue = JsonSerializer.Serialize(_opp.PreferredQualifications) });

        _opp.RequiredQualifications = result.Required.ToArray();
        _opp.PreferredQualifications = result.Preferred.ToArray();
        _opp.UpdatedAt = DateTime.UtcNow;

        var writeResult = await Db.VersionedWriteAsync("opportunities", _opp, new[] { $"opp:{_opp.Id}" });
        if (writeResult == VersionedWriteResult.Success)
        {
            if (changes.Count > 0)
            {
                var histEntry = new OpportunityFieldHistory
                {
                    OpportunityId = Id,
                    Source = HistorySource.QualificationExtraction,
                    Changes = changes,
                };
                await Db.SaveHistoryEntryAsync(histEntry);
                _history = await Db.GetHistoryByOpportunityAsync(Id);
                await DataSync.BroadcastAsync("opportunityFieldHistory", histEntry.Id, "create");
            }
            await DataSync.BroadcastAsync("opportunity", Id, "update");
        }
        else
        {
            _conflictShowKeepEditing = false;
            _conflictMessage = "This opportunity was modified in another tab while extracting qualifications. Reload to see the current version.";
            _showConflictAlert = true;
        }

        _extractingQuals = false;
    }

    // ── Contacts / role tags ──────────────────────────────────────────────────

    private async Task HandleAddContact(ChangeEventArgs e)
    {
        var contactId = e.Value?.ToString();
        if (string.IsNullOrEmpty(contactId) || _addingContact || _opp is null) return;
        _addingContact = true;

        var role = new ContactOpportunityRole
        {
            ContactId = contactId,
            OpportunityId = Id,
            Roles = Array.Empty<string>(),
        };
        await Db.SaveRoleAsync(role);
        await DataSync.BroadcastAsync("contactOpportunityRole", $"{contactId}:{Id}", "create");
        _contactRoles = await Db.GetRolesByOpportunityAsync(Id);
        _tagPickerKey++;
        _addingContact = false;
    }

    private async Task HandleRoleTagsChanged(ContactOpportunityRole role, string[] newValues)
    {
        // Persist new lookup labels not already in the table
        var newLabels = newValues.Except(_contactRoleLabels, StringComparer.OrdinalIgnoreCase).ToList();
        foreach (var label in newLabels)
        {
            var lv = new LookupValue { Id = Guid.NewGuid().ToString(), Value = label };
            await Db.AddLookupValueAsync("lookupContactRoles", lv);
            _contactRoleLabels.Add(label);
        }

        role.Roles = newValues;
        await Db.SaveRoleAsync(role);
        await DataSync.BroadcastAsync("contactOpportunityRole", $"{role.ContactId}:{Id}", "update");
    }

    private async Task ConfirmRemoveRoleAsync()
    {
        if (_removeRoleTarget is null) return;
        await Db.DeleteRoleAsync(_removeRoleTarget.ContactId, Id);
        await DataSync.BroadcastAsync("contactOpportunityRole", $"{_removeRoleTarget.ContactId}:{Id}", "delete");
        _removeRoleTarget = null;
        _contactRoles = await Db.GetRolesByOpportunityAsync(Id);
        _tagPickerKey++;
    }

    // ── Session delete ────────────────────────────────────────────────────────

    private async Task ConfirmDeleteSessionAsync()
    {
        if (_deleteSessionTarget is null) return;
        var sessionId = _deleteSessionTarget.Id;
        _deleteSessionTarget = null;

        // Delete generated files then session
        if (_opp is not null)
        {
            var session = _sessions.FirstOrDefault(s => s.Id == sessionId);
            if (session is not null)
            {
                if (session.TailoredResumeFileId is not null)
                    await Db.DeleteFileAsync(session.TailoredResumeFileId);
                if (session.CoverLetterFileId is not null)
                    await Db.DeleteFileAsync(session.CoverLetterFileId);
            }
        }
        await Db.DeleteSessionAsync(sessionId);
        await DataSync.BroadcastAsync("session", sessionId, "delete");
        _sessions = _sessions.Where(s => s.Id != sessionId).ToList();
    }

    // ── Conflict / deletion handlers ──────────────────────────────────────────

    private async Task HandleConflictDiscardAndReload()
    {
        _showConflictAlert = false;
        _isEditing = false;
        await LoadAsync();
    }

    private void HandleConflictKeepEditing() => _showConflictAlert = false;

    private void HandleDeletionDismiss()
    {
        _showDeletionAlert = false;
        Nav.NavigateTo(_pendingNavigation);
    }

    // ── Correspondence modal (M5-2/M5-3) ─────────────────────────────────────

    protected override void OnGuardStay()
    {
        if (_corrGuardPending) { _showGuardModal = false; _corrGuardPending = false; }
        else base.OnGuardStay();
    }

    protected override void OnGuardLeave()
    {
        if (_corrGuardPending) { _showGuardModal = false; _corrGuardPending = false; CloseCorrModal(); }
        else base.OnGuardLeave();
    }

    private bool IsCorrModalDirty()
    {
        if (_editCorrespondence is null)
        {
            return _modalCorr.OccurredAt != _addModeDefaultTime ||
                   !string.IsNullOrEmpty(_modalCorr.Subject) ||
                   !string.IsNullOrEmpty(_modalCorr.Body) ||
                   !string.IsNullOrEmpty(_modalCorr.ContactId) ||
                   !string.IsNullOrEmpty(_modalCorr.LinkedSessionId) ||
                   _modalCorr.CoverLetterSubmitted ||
                   _modalNewFiles.Count > 0;
        }
        return _modalCorr.OccurredAt  != _editCorrespondence.OccurredAt ||
               _modalCorr.Subject     != _editCorrespondence.Subject ||
               _modalCorr.Body        != _editCorrespondence.Body ||
               _modalCorr.ContactId   != _editCorrespondence.ContactId ||
               _modalCorr.LinkedSessionId   != _editCorrespondence.LinkedSessionId ||
               _modalCorr.Direction         != _editCorrespondence.Direction ||
               _modalCorr.CoverLetterSubmitted != _editCorrespondence.CoverLetterSubmitted ||
               _modalNewFiles.Count > 0 ||
               _modalRemovedFileIds.Count > 0;
    }

    private void OpenAddCorrespondence(CorrespondenceType type)
    {
        _showAddCorrDropdown = false;
        var now = DateTime.UtcNow;
        _addModeDefaultTime = now;
        _editCorrespondence = null;
        _modalCorr = new Correspondence
        {
            OpportunityId = Id,
            Type = type,
            OccurredAt = now,
            Direction = CorrespondenceDirection.Incoming,
        };
        _modalExistingFiles = new();
        _modalNewFiles = new();
        _modalRemovedFileIds = new();
        _fileUploadError = null;
        _corrSaveError = null;
        _showCorrespondenceModal = true;
    }

    private async Task OpenEditCorrespondence(Correspondence corr)
    {
        _editCorrespondence = corr;
        _modalCorr = new Correspondence
        {
            Id                   = corr.Id,
            Version              = corr.Version,
            OpportunityId        = corr.OpportunityId,
            Type                 = corr.Type,
            OccurredAt           = corr.OccurredAt,
            Direction            = corr.Direction,
            Subject              = corr.Subject,
            Body                 = corr.Body,
            ContactId            = corr.ContactId,
            LinkedSessionId      = corr.LinkedSessionId,
            CoverLetterSubmitted = corr.CoverLetterSubmitted,
            CreatedAt            = corr.CreatedAt,
            UpdatedAt            = corr.UpdatedAt,
        };
        _modalExistingFiles = await Db.GetFilesByCorrespondenceAsync(corr.Id);
        _modalNewFiles = new();
        _modalRemovedFileIds = new();
        _fileUploadError = null;
        _corrSaveError = null;
        _showCorrespondenceModal = true;
    }

    private void CloseCorrModal()
    {
        _showCorrespondenceModal = false;
        _editCorrespondence = null;
        _modalNewFiles = new();
        _modalRemovedFileIds = new();
        _fileUploadError = null;
        _corrSaveError = null;
    }

    private void HandleCorrModalClose()
    {
        if (IsCorrModalDirty()) { _corrGuardPending = true; _showGuardModal = true; }
        else CloseCorrModal();
    }

    private void HandleCorrModalBackdropClick() => HandleCorrModalClose();

    private async Task SaveCorrespondenceAsync()
    {
        if (_savingCorr) return;
        _savingCorr = true;
        _corrSaveError = null;

        _modalCorr.UpdatedAt = DateTime.UtcNow;
        if (_editCorrespondence is null)
            _modalCorr.CreatedAt = DateTime.UtcNow;

        if (!TypeHasDirection(_modalCorr.Type))
            _modalCorr.Direction = CorrespondenceDirection.Incoming;

        var newFiles = _modalNewFiles.Select(f => { f.CorrespondenceId = _modalCorr.Id; return f; }).ToList();
        var result = await Db.SaveCorrespondenceWithFilesAsync(_modalCorr, newFiles, _modalRemovedFileIds);

        if (result == VersionedWriteResult.VersionMismatch)
        {
            _savingCorr = false;
            _showCorrespondenceModal = false;
            _corrGuardPending = false;
            _conflictShowKeepEditing = false;
            _conflictMessage = "This correspondence entry was modified in another tab. Your changes have been discarded.";
            _showConflictAlert = true;
            await LoadCorrespondenceAsync();
            return;
        }

        var isNew = _editCorrespondence is null;
        await DataSync.BroadcastAsync("correspondence", _modalCorr.Id, isNew ? "create" : "update");
        CloseCorrModal();
        await LoadCorrespondenceAsync();
        _savingCorr = false;
    }

    private async Task HandleCorrFileSelected(InputFileChangeEventArgs e)
    {
        _fileUploadError = null;
        const long maxSize = 5 * 1024 * 1024;
        foreach (var file in e.GetMultipleFiles(100))
        {
            if (file.Size > maxSize)
            {
                _fileUploadError = $"File \"{file.Name}\" exceeds the 5 MB limit and was not added.";
                continue;
            }
            using var ms = new System.IO.MemoryStream();
            await file.OpenReadStream(maxSize).CopyToAsync(ms);
            _modalNewFiles.Add(new CorrespondenceFile
            {
                CorrespondenceId = _modalCorr.Id,
                FileName         = file.Name,
                FileSize         = file.Size,
                FileDataBase64   = Convert.ToBase64String(ms.ToArray()),
                UploadedAt       = DateTime.UtcNow,
            });
        }
    }

    private void RemoveStagedFile(CorrespondenceFile f) => _modalNewFiles.Remove(f);

    private void RemoveExistingFile(string id)
    {
        _modalRemovedFileIds.Add(id);
        _modalExistingFiles.RemoveAll(f => f.Id == id);
    }

    private async Task DownloadExistingFile(CorrespondenceFile f) =>
        await Db.DownloadGenericFileAsync(f.FileName, f.FileDataBase64);

    private async Task ConfirmDeleteCorrespondenceAsync()
    {
        if (_deleteCorrespondenceTarget is null) return;
        var id = _deleteCorrespondenceTarget.Id;
        _deleteCorrespondenceTarget = null;
        await Db.DeleteCorrespondenceCascadeAsync(id);
        await DataSync.BroadcastAsync("correspondence", id, "delete");
        _correspondence.RemoveAll(c => c.Id == id);
        _correspondenceFileCounts.Remove(id);
    }

    private async Task LoadCorrespondenceAsync()
    {
        _correspondence = await Db.GetCorrespondenceByOpportunityAsync(Id);
        _correspondenceFileCounts = new();
        foreach (var c in _correspondence)
            _correspondenceFileCounts[c.Id] = await Db.GetCorrespondenceFileCountAsync(c.Id);
    }

    // ── BroadcastChannel live updates (M4-8) ──────────────────────────────────

    private void HandleOppChangedRemote(string? id, string @event)
    {
        if (id != Id) return;

        if (@event == "delete")
        {
            _pendingNavigation = _opp?.OrganizationId is not null
                ? $"/organizations/{_opp.OrganizationId}"
                : "/opportunities";
            _deletionMessage = "This opportunity has been deleted in another tab.";
            _showDeletionAlert = true;
            InvokeAsync(StateHasChanged);
            return;
        }

        if (_isEditing)
        {
            _conflictShowKeepEditing = true;
            _conflictMessage = "This opportunity was updated in another tab. You can discard your changes and reload, or continue editing.";
            _showConflictAlert = true;
            InvokeAsync(StateHasChanged);
            return;
        }

        InvokeAsync(async () => { await LoadAsync(); StateHasChanged(); });
    }

    private void HandleHistoryChanged(string? id, string @event)
    {
        InvokeAsync(async () =>
        {
            _history = await Db.GetHistoryByOpportunityAsync(Id);
            StateHasChanged();
        });
    }

    private void HandleContactChanged(string? id, string @event)
    {
        InvokeAsync(async () =>
        {
            if (_opp is null) return;
            _orgContacts = (await Db.GetContactsByOrganizationAsync(_opp.OrganizationId))
                .OrderBy(c => c.FullName, StringComparer.OrdinalIgnoreCase).ToList();
            StateHasChanged();
        });
    }

    private void HandleRoleChanged(string? id, string @event)
    {
        InvokeAsync(async () =>
        {
            _contactRoles = await Db.GetRolesByOpportunityAsync(Id);
            _tagPickerKey++;
            StateHasChanged();
        });
    }

    private void HandleOrgChanged(string? id, string @event)
    {
        if (id != _opp?.OrganizationId) return;

        if (@event == "delete")
        {
            _pendingNavigation = "/organizations";
            _deletionMessage = "The organization for this opportunity has been deleted in another tab.";
            _showDeletionAlert = true;
            InvokeAsync(StateHasChanged);
            return;
        }

        InvokeAsync(async () =>
        {
            _org = await Db.GetOrganizationAsync(_opp!.OrganizationId);
            StateHasChanged();
        });
    }

    private void HandleSessionChanged(string? id, string @event)
    {
        InvokeAsync(async () =>
        {
            var allSessions = await Db.GetAllSessionsAsync();
            _sessions = allSessions.Where(s => s.OpportunityId == Id)
                .OrderByDescending(s => s.CreatedAt).ToList();
            StateHasChanged();
        });
    }

    // ── BroadcastChannel live updates (M5-5) ──────────────────────────────────

    private void HandleCorrespondenceChanged(string? id, string @event)
    {
        if (@event == "delete" && id == _editCorrespondence?.Id && _showCorrespondenceModal)
        {
            CloseCorrModal();
            _corrGuardPending = false;
            _deletionMessage = "This correspondence entry was deleted in another tab.";
            _showDeletionAlert = true;
            InvokeAsync(StateHasChanged);
            return;
        }
        InvokeAsync(async () => { await LoadCorrespondenceAsync(); StateHasChanged(); });
    }

    private void HandleCorrFileChanged(string? id, string @event) =>
        InvokeAsync(async () => { await LoadCorrespondenceAsync(); StateHasChanged(); });
}
