    private void NavigateToSession(string id) => Nav.NavigateTo("/history/" + id);

    // ── Correspondence helpers ────────────────────────────────────────────────

    private static bool TypeHasDirection(CorrespondenceType t) =>
        t is CorrespondenceType.Email or CorrespondenceType.PhoneCall or CorrespondenceType.Text;

    private static (string inLabel, string outLabel) GetDirectionLabels(CorrespondenceType t) =>
        t == CorrespondenceType.PhoneCall ? ("Received", "Made") : ("Received", "Sent");

    private static string CorrTypeLabel(CorrespondenceType t) => t switch
    {
        CorrespondenceType.ResumeSubmitted => "Resume Submitted",
        CorrespondenceType.PhoneCall       => "Phone Call",
        CorrespondenceType.VideoCall       => "Video Call",
        _                                  => t.ToString(),
    };

    private static string GetTypeDirectionLabel(Correspondence corr)
    {
        var type = CorrTypeLabel(corr.Type);
        if (!TypeHasDirection(corr.Type)) return type;
        var dir = corr.Type == CorrespondenceType.PhoneCall
            ? (corr.Direction == CorrespondenceDirection.Incoming ? "Received" : "Made")
            : (corr.Direction == CorrespondenceDirection.Incoming ? "Received" : "Sent");
        return $"{type} · {dir}";
    }

    private static string StripMarkdown(string text)
    {
        if (string.IsNullOrEmpty(text)) return text;
        var ml = System.Text.RegularExpressions.RegexOptions.Multiline;
        Func<string, string, string, string> r =
            System.Text.RegularExpressions.Regex.Replace;
        Func<string, string, string, System.Text.RegularExpressions.RegexOptions, string> rm =
            System.Text.RegularExpressions.Regex.Replace;
        text = rm(text, @"^#{1,6}\s+", "", ml);
        text = r(text, @"\*{1,2}([^*\r\n]+)\*{1,2}", "$1");
        text = r(text, @"_{1,2}([^_\r\n]+)_{1,2}", "$1");
        text = r(text, @"\[([^\]]+)\]\([^\)]+\)", "$1");
        text = r(text, @"`{1,3}[^`\r\n]*`{1,3}", "");
        text = rm(text, @"^[\*\-\+]\s+", "", ml);
        text = rm(text, @"^\d+\.\s+", "", ml);
        text = r(text, @"\s+", " ").Trim();
        return text;
    }

    private string GetCorrContentPreview(Correspondence corr)
    {
        var raw = corr.Type == CorrespondenceType.Email && !string.IsNullOrWhiteSpace(corr.Subject)
            ? corr.Subject
            : StripMarkdown(corr.Body);
        return raw.Length > 120 ? raw[..120] + "…" : raw;
    }

    private string GetCorrContactDisplay(Correspondence corr)
