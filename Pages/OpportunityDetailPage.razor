    private string? DanglingSessionId
    {
        get
        {
            if (string.IsNullOrEmpty(_modalCorr.LinkedSessionId)) return null;
            return _sessions.Any(s => s.Id == _modalCorr.LinkedSessionId) ? null : _modalCorr.LinkedSessionId;
        }
    }

    private static readonly RenderFragment TrashIcon = builder =>
