@page "/"
@inject IndexedDbService Db
@inject DocxService Docx
@inject AiProviderFactory Providers
@inject AppStateService AppState
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Apply — Simply Job Application</PageTitle>

@if (!_hasApiKey)
{
    <div class="alert alert-warning sja-api-alert" role="alert">
        No API key configured for the selected provider.
        <a href="/settings">Go to Settings</a> to enter your key.
    </div>
}

<!-- ── Sticky progress bar ─────────────────────────────────────────────── -->
<div class="sja-progress-bar" role="navigation" aria-label="Application progress">
    <nav class="sja-steps" aria-label="Steps">
        <div class="sja-step @StepClass(1)" aria-current="@(StepClass(1) == "active" ? "step" : null)">
            @if (StepClass(1) == "completed") { <span class="sja-step-icon" aria-hidden="true">✓</span> }
            <span>Input</span>
        </div>
        <div class="sja-step-connector" aria-hidden="true"></div>
        <div class="sja-step @StepClass(2)" aria-current="@(StepClass(2) == "active" ? "step" : null)">
            @if (StepClass(2) == "completed") { <span class="sja-step-icon" aria-hidden="true">✓</span> }
            <span>Evaluation</span>
        </div>
        <div class="sja-step-connector" aria-hidden="true"></div>
        <div class="sja-step @StepClass(3)" aria-current="@(StepClass(3) == "active" ? "step" : null)">
            @if (StepClass(3) == "completed") { <span class="sja-step-icon" aria-hidden="true">✓</span> }
            <span>Generation</span>
        </div>
    </nav>
    <button class="btn btn-outline-secondary btn-sm"
            disabled="@(_evaluating || _reevaluating || _generating)"
            @onclick="NewSession">
        New
    </button>
</div>

<!-- ══ Swimlane 1: User Input ════════════════════════════════════════════ -->
<section id="lane-input" class="sja-swimlane sja-lane-input" aria-label="User Input">
    <div class="sja-swimlane-header">
        <h5 class="mb-0">Job/Role &amp; Resume Input</h5>
    </div>
    <div class="sja-swimlane-body">
        <div class="row g-3">
            <div class="col-12 col-lg-7">
                <div class="card h-100">
                    <div class="card-header">Job Description</div>
                    <div class="card-body">
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label">Company Name</label>
                                <input class="form-control" @bind="_companyName" placeholder="Acme Corp"
                                       readonly="@_inputsLocked" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Job Title</label>
                                <input class="form-control" @bind="_jobTitle" placeholder="Software Engineer"
                                       readonly="@_inputsLocked" />
                            </div>
                        </div>
                        <div>
                            <label class="form-label">Job Details</label>
                            <textarea class="form-control" rows="8" @bind="_jobDetails"
                                      placeholder="Paste the full job description here…"
                                      readonly="@_inputsLocked"></textarea>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="card h-100">
                    <div class="card-header">Resume</div>
                    <div class="card-body">
                        @if (_selectedFileName is not null)
                        {
                            <div class="alert alert-success py-2 d-flex justify-content-between align-items-center mb-3">
                                <span>📄 @_selectedFileName</span>
                                @if (!_inputsLocked)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="ClearResume"
                                            aria-label="Clear selected resume">✕</button>
                                }
                            </div>
                        }
                        @if (!_inputsLocked)
                        {
                            <div class="mb-2">
                                <label class="form-label">Upload DOCX</label>
                                <InputFile class="form-control" accept=".docx" OnChange="OnFileUpload" />
                            </div>
                            <div class="text-center text-muted small my-2">— or —</div>
                            <button class="btn btn-outline-secondary w-100" type="button"
                                    @onclick="OpenFilePickerAsync">
                                Choose from Files Library
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_error is not null)
        {
            <div class="alert alert-danger mt-3" role="alert">@_error</div>
        }

        <div class="d-flex justify-content-end mt-3">
            <button class="btn btn-primary px-4"
                    disabled="@(!CanEvaluate)"
                    @onclick="EvaluateWithScrollAsync"
                    aria-label="Evaluate match">
                @if (_evaluating)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>@_loadingStep</span>
                }
                else { <span>Evaluate</span> }
            </button>
        </div>
    </div>
</section>

<!-- ══ Swimlane 2: Evaluation ════════════════════════════════════════════ -->
<section id="lane-evaluation" class="sja-swimlane sja-lane-eval" aria-label="Evaluation">
    <div class="sja-swimlane-header">
        <h5 class="mb-0">Match Evaluation &amp; ATS fitting</h5>
    </div>
    <div class="sja-swimlane-body">
        @if (_evaluating || _reevaluating)
        {
            <div class="card mb-3" aria-busy="true" aria-label="Loading match evaluation">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div class="sja-skeleton" style="width:9rem;height:0.9rem"></div>
                    <div class="sja-skeleton" style="width:4.5rem;height:1.4rem;border-radius:0.75rem"></div>
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <div class="sja-skeleton" style="height:0.8rem;width:32%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:90%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:76%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:84%"></div>
                    <div class="sja-skeleton mt-2" style="height:0.8rem;width:28%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:93%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:70%"></div>
                </div>
            </div>
            <div class="card" aria-busy="true" aria-label="Loading keyword suggestions">
                <div class="card-header"><div class="sja-skeleton" style="width:14rem;height:0.9rem"></div></div>
                <div class="card-body d-flex flex-column gap-2">
                    <div class="sja-skeleton" style="height:0.8rem;width:58%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:70%"></div>
                    <div class="sja-skeleton" style="height:0.8rem;width:48%"></div>
                </div>
            </div>
        }
        else if (_evaluation is null)
        {
            <div class="sja-empty-state">
                <p class="text-muted mb-3">Evaluate your input to see match analysis and keyword suggestions.</p>
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="@(() => ScrollToAsync("lane-input"))"
                        aria-label="Go to User Input section">
                    ↑ Go to Input
                </button>
            </div>
        }
        else
        {
            var currentKwSet = _evaluation.SuggestedKeywords
                .Select(k => k.Keyword)
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            var previouslyConfirmed = _confirmedKeywords
                .Where(k => !currentKwSet.Contains(k.Keyword))
                .ToList();
            var usedKeywords = GetAllKeywordsForSession();

            <!-- Match evaluation -->
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Match Evaluation</span>
                    <span class="badge @ScoreBadgeClass(_evaluation.Score)">@_evaluation.Score</span>
                </div>
                <div class="card-body">
                    @if (_evaluation.Strengths.Count > 0)
                    {
                        <p class="mb-1 fw-semibold text-success">Strengths:</p>
                        <ul class="mb-3">
                            @foreach (var s in _evaluation.Strengths) { <li>@s</li> }
                        </ul>
                    }
                    @if (_evaluation.Gaps.Count > 0)
                    {
                        <p class="mb-1 fw-semibold">Areas needing attention:</p>
                        <ul class="mb-0">
                            @foreach (var g in _evaluation.Gaps) { <li>@g</li> }
                        </ul>
                    }
                    else
                    {
                        <p class="mb-0 text-success">No significant gaps identified.</p>
                    }
                </div>
            </div>

            <!-- Keywords card: interactive before generate, read-only after -->
            @if (_materials is null)
            {
                <div class="card mb-3">
                    <div class="card-header">Additional Keywords for ATS</div>
                    <div class="card-body">
                        @if (previouslyConfirmed.Count > 0)
                        {
                            <p class="fw-semibold small mb-1">Previously selected</p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var kw in previouslyConfirmed)
                                {
                                    var kwCopy = kw;
                                    <span class="badge text-bg-secondary d-flex align-items-center gap-1">
                                        @if (!string.IsNullOrEmpty(kw.Category))
                                        {
                                            <span class="opacity-75 small">@kw.Category:</span>
                                        }
                                        @kw.Keyword
                                        <button type="button" class="btn-close btn-close-white"
                                                style="font-size:0.6rem"
                                                aria-label="Remove @kw.Keyword"
                                                @onclick="() => RemoveConfirmedKeyword(kwCopy.Keyword)"></button>
                                    </span>
                                }
                            </div>
                        }

                        @if (_evaluation.SuggestedKeywords.Count > 0)
                        {
                            <p class="text-muted small mb-2">
                                These skills appear in the job description but not in your resume.
                                Check the ones you are comfortable adding to your Skills section.
                            </p>
                            var kwIdx = 0;
                            foreach (var group in _evaluation.SuggestedKeywords.GroupBy(k => k.Category))
                            {
                                <p class="fw-semibold mb-1 mt-2 small">@group.Key</p>
                                foreach (var kw in group)
                                {
                                    var idx = kwIdx++;
                                    var kwCopy = kw;
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="kw-@idx"
                                               checked="@_confirmedKeywords.Any(c => string.Equals(c.Keyword, kwCopy.Keyword, StringComparison.OrdinalIgnoreCase))"
                                               @onchange="e => ToggleKeyword(kwCopy, (bool)e.Value!)" />
                                        <label class="form-check-label small" for="kw-@idx">@kw.Keyword</label>
                                    </div>
                                }
                            }
                        }
                        else
                        {
                            <p class="text-muted small mb-0">No additional keywords suggested for this job description.</p>
                        }

                        <div class="mt-3">
                            <label class="form-label small">
                                Add keywords manually
                                <span class="text-muted">(one per line, optionally prefixed with <code>Category: </code>; or comma-separated)</span>
                            </label>
                            <textarea class="form-control form-control-sm" rows="2"
                                      placeholder="@("Developer Tools: Terraform\nGraphQL, REST")"
                                      @bind="_customKeywords"></textarea>
                        </div>

                        @if (GetAdditionalKeywords().Count > 0)
                        {
                            <button class="btn btn-outline-secondary btn-sm w-100 mt-3"
                                    disabled="@(_reevaluating || _generating)"
                                    @onclick="ReEvaluateAsync"
                                    aria-label="Re-evaluate with selected keywords">
                                @if (_reevaluating)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Re-evaluating…</span>
                                }
                                else { <span>Re-evaluate with Selected Keywords</span> }
                            </button>
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button class="btn btn-success px-4"
                            disabled="@(_generating || _reevaluating)"
                            @onclick="GenerateWithScrollAsync"
                            aria-label="Generate application materials">
                        @if (_generating)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>@_loadingStep</span>
                        }
                        else { <span>Generate</span> }
                    </button>
                </div>
            }
            else if (usedKeywords.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-header">Additional Keywords Used</div>
                    <div class="card-body">
                        @foreach (var group in usedKeywords.GroupBy(k => string.IsNullOrEmpty(k.Category) ? "Other" : k.Category))
                        {
                            <p class="fw-semibold small mb-1 mt-2">@group.Key</p>
                            <div class="d-flex flex-wrap gap-2 mb-1">
                                @foreach (var kw in group)
                                {
                                    <span class="badge text-bg-secondary">@kw.Keyword</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>

<!-- ══ Swimlane 3: Generated Content ════════════════════════════════════ -->
<section id="lane-generated" class="sja-swimlane sja-lane-gen" aria-label="Generated Content">
    <div class="sja-swimlane-header">
        <h5 class="mb-0">Generated Customized Content</h5>
    </div>
    <div class="sja-swimlane-body">
        @if (_generating)
        {
            <div class="row g-3" aria-busy="true">
                <div class="col-12 col-lg-6">
                    <div class="card h-100" aria-label="Loading tailored resume">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div class="sja-skeleton" style="width:8rem;height:0.9rem"></div>
                            <div class="sja-skeleton" style="width:6.5rem;height:1.8rem;border-radius:0.25rem"></div>
                        </div>
                        <div class="card-body"><div class="sja-skeleton" style="height:0.8rem;width:75%"></div></div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="card h-100" aria-label="Loading why apply">
                        <div class="card-header"><div class="sja-skeleton" style="width:5rem;height:0.9rem"></div></div>
                        <div class="card-body d-flex flex-column gap-2">
                            <div class="sja-skeleton" style="height:0.8rem;width:95%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:68%"></div>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card" aria-label="Loading cover letter">
                        <div class="card-header"><div class="sja-skeleton" style="width:6rem;height:0.9rem"></div></div>
                        <div class="card-body d-flex flex-column gap-2">
                            <div class="sja-skeleton" style="height:0.8rem;width:91%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:83%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:62%"></div>
                            <div class="sja-skeleton mt-2" style="height:0.8rem;width:88%"></div>
                            <div class="sja-skeleton" style="height:0.8rem;width:74%"></div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (_materials is null)
        {
            <div class="sja-empty-state">
                <p class="text-muted mb-2">To generate tailored application materials:</p>
                <ol class="text-muted mb-3 d-inline-block text-start ps-3">
                    <li>Complete evaluation</li>
                    <li>Click Generate</li>
                </ol>
                <br />
                <button class="btn btn-outline-secondary btn-sm"
                        @onclick="@(() => ScrollToAsync("lane-evaluation"))"
                        aria-label="Go to Evaluation section">
                    ↑ Go to Evaluation
                </button>
            </div>
        }
        else
        {
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>Tailored Resume</span>
                            @if (_tailoredResumeFileId is not null)
                            {
                                <button class="btn btn-sm btn-primary" @onclick="DownloadTailoredResume">
                                    Download DOCX
                                </button>
                            }
                        </div>
                        <div class="card-body text-muted small">
                            Tailored resume generated and saved to the Files Library.
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>Why Apply</span>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@_materials.WhyApplyText</p>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <span>Cover Letter</span>
                            @if (_coverLetterFileId is not null)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="DownloadCoverLetter">
                                    Download DOCX
                                </button>
                            }
                        </div>
                        <div class="card-body">
                            @foreach (var para in _materials.CoverLetterText.Split(
                                new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                            {
                                <p>@para</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

<!-- File picker modal -->
@if (_showFilePicker)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)"
         role="dialog" aria-modal="true" aria-label="Choose Resume from Files Library">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Choose Resume from Files Library</h5>
                    <button class="btn-close" @onclick="() => _showFilePicker = false" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @if (_fileMeta.Count == 0)
                    {
                        <p class="text-muted">No files stored yet.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var f in _fileMeta.OrderByDescending(x => x.LastUsedAt))
                            {
                                <button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                        @onclick="() => SelectStoredFile(f.Id, f.Name)">
                                    <span>@f.Name</span>
                                    <small class="text-muted">@f.LastUsedAt.ToLocalTime().ToString("g")</small>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    string _companyName = "", _jobTitle = "", _jobDetails = "";
    byte[]? _resumeBytes;
    string? _selectedFileName;
    string? _selectedFileId;

    bool _evaluating;
    bool _reevaluating;
    bool _generating;
    bool _inputsLocked;
    string? _loadingStep;
    string? _error;
    bool _hasApiKey = true;

    MatchEvaluation? _evaluation;
    GeneratedMaterials? _materials;
    string? _tailoredResumeFileId;
    string? _coverLetterFileId;

    // Persisted between Turn 1 and Turn 2
    string? _resumeMarkdown;
    string? _inputFileId;
    string? _sessionId;

    // Keyword selection — keywords the user has explicitly confirmed
    readonly List<SuggestedKeyword> _confirmedKeywords = new();
    string _customKeywords = "";

    bool _showFilePicker;
    List<StoredFileMeta> _fileMeta = new();
    AppSettings _settings = new();

    bool CanEvaluate => !_evaluating && !_reevaluating && !_generating && !_inputsLocked && _hasApiKey &&
                        !string.IsNullOrWhiteSpace(_companyName) &&
                        !string.IsNullOrWhiteSpace(_jobTitle) &&
                        !string.IsNullOrWhiteSpace(_jobDetails) &&
                        _resumeBytes is not null;

    protected override async Task OnInitializedAsync()
    {
        _settings = await Db.GetSettingsAsync();
        _hasApiKey = !string.IsNullOrWhiteSpace(
            _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider));
        _fileMeta = await Db.GetAllFileMetaAsync();

        if (AppState.PendingResumeFileId is not null)
        {
            await SelectStoredFile(AppState.PendingResumeFileId, AppState.PendingResumeFileName ?? "resume.docx");
            AppState.PendingResumeFileId = null;
            AppState.PendingResumeFileName = null;
        }
    }

    // ── Scroll helpers ────────────────────────────────────────────────────────

    Task ScrollToAsync(string id) =>
        JS.InvokeVoidAsync("sjaScrollTo", id).AsTask();

    async Task EvaluateWithScrollAsync()
    {
        await ScrollToAsync("lane-evaluation");
        await EvaluateAsync();
    }

    async Task GenerateWithScrollAsync()
    {
        await ScrollToAsync("lane-generated");
        await GenerateAsync();
    }

    // ── Progress step state ───────────────────────────────────────────────────

    string StepClass(int step) => step switch
    {
        1 => _inputsLocked              ? "completed" : "active",
        2 => _materials is not null     ? "completed"
           : _inputsLocked             ? "active"
                                       : "",
        3 => _materials is not null     ? "active"    : "",
        _ => ""
    };

    // ── File handling ─────────────────────────────────────────────────────────

    async Task OnFileUpload(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            using var ms = new MemoryStream();
            await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
            _resumeBytes = ms.ToArray();
            _selectedFileName = file.Name;
            _selectedFileId = null;
        }
        catch (Exception ex)
        {
            _error = $"Error reading file: {ex.Message}";
        }
    }

    async Task SelectStoredFile(string id, string name)
    {
        var file = await Db.GetFileAsync(id);
        if (file is null) { _error = "File not found in storage."; return; }
        _resumeBytes = Convert.FromBase64String(file.DataBase64);
        _selectedFileName = name;
        _selectedFileId = id;
        _showFilePicker = false;
    }

    async Task OpenFilePickerAsync()
    {
        _fileMeta = await Db.GetAllFileMetaAsync();
        _showFilePicker = true;
    }

    void ClearResume()
    {
        _resumeBytes = null;
        _selectedFileName = null;
        _selectedFileId = null;
    }

    void NewSession()
    {
        _companyName = "";
        _jobTitle = "";
        _jobDetails = "";
        _resumeBytes = null;
        _selectedFileName = null;
        _selectedFileId = null;
        _evaluation = null;
        _materials = null;
        _tailoredResumeFileId = null;
        _coverLetterFileId = null;
        _resumeMarkdown = null;
        _inputFileId = null;
        _sessionId = null;
        _confirmedKeywords.Clear();
        _customKeywords = "";
        _inputsLocked = false;
        _error = null;
    }

    // ── AI turns ──────────────────────────────────────────────────────────────

    async Task EvaluateAsync()
    {
        _error = null;
        _evaluation = null;
        _materials = null;
        _tailoredResumeFileId = null;
        _coverLetterFileId = null;
        _resumeMarkdown = null;
        _inputFileId = null;
        _confirmedKeywords.Clear();
        _customKeywords = "";
        _inputsLocked = true;
        _evaluating = true;

        try
        {
            _settings = await Db.GetSettingsAsync();
            var apiKey = _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider) ?? "";
            var modelId = _settings.ProviderModels.GetValueOrDefault(_settings.AiProvider)
                          ?? Providers.Get(_settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(_settings.AiProvider);

            _loadingStep = "Extracting resume…";
            StateHasChanged();
            _resumeMarkdown = Docx.ExtractMarkdown(_resumeBytes!);

            _loadingStep = "Evaluating match…";
            StateHasChanged();
            var job = new JobDescription
            {
                CompanyName = _companyName,
                JobTitle    = _jobTitle,
                JobDetails  = _jobDetails,
            };
            _evaluation = await provider.EvaluateMatchAsync(job, _resumeMarkdown, modelId, apiKey, null);

            // Store resume in file library (needed for session record).
            _inputFileId = _selectedFileId;
            if (_inputFileId is null)
            {
                _inputFileId = Guid.NewGuid().ToString();
                await Db.SaveFileAsync(new StoredFile
                {
                    Id           = _inputFileId,
                    Name         = _selectedFileName ?? "resume.docx",
                    DataBase64   = Convert.ToBase64String(_resumeBytes!),
                    LastUsedAt   = DateTime.UtcNow,
                    SessionCount = 1,
                });
                await Db.EnforceFileLimitAsync(_settings.FilesLimit);
            }
            else
            {
                var existing = await Db.GetFileAsync(_inputFileId);
                if (existing is not null)
                {
                    existing.LastUsedAt = DateTime.UtcNow;
                    existing.SessionCount++;
                    await Db.SaveFileAsync(existing);
                }
            }

            _sessionId = Guid.NewGuid().ToString();
            await SaveSessionAsync();
            await Db.EnforceSessionLimitAsync(_settings.HistoryLimit);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            _inputsLocked = false;
        }
        finally
        {
            _evaluating = false;
            _loadingStep = null;
        }
    }

    async Task GenerateAsync()
    {
        if (_evaluation is null || _resumeMarkdown is null) return;

        _error = null;
        _generating = true;

        try
        {
            _settings = await Db.GetSettingsAsync();
            var apiKey = _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider) ?? "";
            var modelId = _settings.ProviderModels.GetValueOrDefault(_settings.AiProvider)
                          ?? Providers.Get(_settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(_settings.AiProvider);

            var job = new JobDescription
            {
                CompanyName = _companyName,
                JobTitle    = _jobTitle,
                JobDetails  = _jobDetails,
            };

            _loadingStep = "Generating materials…";
            StateHasChanged();
            _materials = await provider.GenerateMaterialsAsync(
                job, _resumeMarkdown, _evaluation, modelId, apiKey, GetAdditionalKeywords());

            var resumeDocxBytes = Docx.GenerateResumeDocx(_resumeBytes!, _materials.ResumeMarkdown);
            var resumeFileId = Guid.NewGuid().ToString();
            await Db.SaveFileAsync(new StoredFile
            {
                Id           = resumeFileId,
                Name         = $"Resume - {_companyName} - {_jobTitle}.docx",
                DataBase64   = Convert.ToBase64String(resumeDocxBytes),
                LastUsedAt   = DateTime.UtcNow,
                SessionCount = 1,
            });
            _tailoredResumeFileId = resumeFileId;

            var clDocx    = Docx.GenerateCoverLetterDocx(_materials.CoverLetterText);
            var clFileId  = Guid.NewGuid().ToString();
            await Db.SaveFileAsync(new StoredFile
            {
                Id           = clFileId,
                Name         = $"Cover Letter - {_companyName} - {_jobTitle}.docx",
                DataBase64   = Convert.ToBase64String(clDocx),
                LastUsedAt   = DateTime.UtcNow,
                SessionCount = 1,
            });
            _coverLetterFileId = clFileId;

            await Db.EnforceFileLimitAsync(_settings.FilesLimit);
            await SaveSessionAsync();   // updates the record created during Evaluate
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _generating = false;
            _loadingStep = null;
        }
    }

    async Task ReEvaluateAsync()
    {
        if (_resumeMarkdown is null) return;

        _error = null;
        _materials = null;
        _tailoredResumeFileId = null;
        _coverLetterFileId = null;
        _reevaluating = true;

        try
        {
            _settings = await Db.GetSettingsAsync();
            var apiKey   = _settings.ProviderApiKeys.GetValueOrDefault(_settings.AiProvider) ?? "";
            var modelId  = _settings.ProviderModels.GetValueOrDefault(_settings.AiProvider)
                           ?? Providers.Get(_settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(_settings.AiProvider);

            var job = new JobDescription
            {
                CompanyName = _companyName,
                JobTitle    = _jobTitle,
                JobDetails  = _jobDetails,
            };

            _evaluation = await provider.EvaluateMatchAsync(
                job, _resumeMarkdown, modelId, apiKey, GetAdditionalKeywords());

            await SaveSessionAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _reevaluating = false;
        }
    }

    // ── Keyword helpers ───────────────────────────────────────────────────────

    // Returns deduplicated union of confirmed + parsed custom keywords as SuggestedKeyword list.
    List<SuggestedKeyword> GetAllKeywordsForSession()
    {
        var seen   = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var result = new List<SuggestedKeyword>();
        foreach (var kw in _confirmedKeywords)
            if (seen.Add(kw.Keyword)) result.Add(kw);
        foreach (var kw in ParseCustomKeywords())
            if (seen.Add(kw.Keyword)) result.Add(kw);
        return result;
    }

    // Returns strings formatted as "Category: Keyword" (or just "Keyword") for the AI prompt.
    IReadOnlyList<string> GetAdditionalKeywords() =>
        GetAllKeywordsForSession()
            .Select(kw => string.IsNullOrEmpty(kw.Category) ? kw.Keyword : $"{kw.Category}: {kw.Keyword}")
            .ToList();

    // Parses the free-form textarea. Each line: "Category: Keyword" or plain "Keyword".
    // Comma-separated entries are supported on lines that contain no colon.
    List<SuggestedKeyword> ParseCustomKeywords()
    {
        var result = new List<SuggestedKeyword>();
        foreach (var line in _customKeywords.Split(new[] { '\n', '\r' },
                     StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            if (string.IsNullOrWhiteSpace(line)) continue;
            var colonIdx = line.IndexOf(':');
            if (colonIdx > 0)
            {
                var cat = line[..colonIdx].Trim();
                var kw  = line[(colonIdx + 1)..].Trim();
                if (!string.IsNullOrWhiteSpace(kw))
                    result.Add(new SuggestedKeyword { Category = cat, Keyword = kw });
            }
            else
            {
                foreach (var part in line.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    if (!string.IsNullOrWhiteSpace(part))
                        result.Add(new SuggestedKeyword { Category = "", Keyword = part });
            }
        }
        return result;
    }

    void ToggleKeyword(SuggestedKeyword kw, bool isChecked)
    {
        if (isChecked)
        {
            if (!_confirmedKeywords.Any(c => string.Equals(c.Keyword, kw.Keyword, StringComparison.OrdinalIgnoreCase)))
                _confirmedKeywords.Add(kw);
        }
        else
        {
            _confirmedKeywords.RemoveAll(c => string.Equals(c.Keyword, kw.Keyword, StringComparison.OrdinalIgnoreCase));
        }
    }

    void RemoveConfirmedKeyword(string keyword) =>
        _confirmedKeywords.RemoveAll(c => string.Equals(c.Keyword, keyword, StringComparison.OrdinalIgnoreCase));

    // ── Session persistence ───────────────────────────────────────────────────

    async Task SaveSessionAsync()
    {
        // _sessionId is pinned when Evaluate succeeds; Generate reuses the same ID
        // so IndexedDB put() overwrites the existing record rather than inserting a new one.
        var existing = _sessionId is not null ? await Db.GetSessionAsync(_sessionId) : null;
        var session  = new SessionRecord
        {
            Id                = _sessionId ?? Guid.NewGuid().ToString(),
            CreatedAt         = existing?.CreatedAt ?? DateTime.UtcNow,
            CompanyName       = _companyName,
            JobTitle          = _jobTitle,
            JobDetails        = _jobDetails,
            InputResumeFileId = _inputFileId ?? "",
            MatchScore        = _evaluation?.Score ?? "",
            MatchGaps         = _evaluation?.Gaps ?? new(),
            MatchStrengths    = _evaluation?.Strengths ?? new(),
            AdditionalKeywords = GetAllKeywordsForSession(),
            CoverLetterText   = _materials?.CoverLetterText ?? "",
            WhyApplyText      = _materials?.WhyApplyText ?? "",
            TailoredResumeFileId = _tailoredResumeFileId,
            CoverLetterFileId    = _coverLetterFileId,
        };
        await Db.SaveSessionAsync(session);
    }

    // ── Downloads ─────────────────────────────────────────────────────────────

    async Task DownloadCoverLetter()
    {
        if (_coverLetterFileId is null) return;
        await DownloadFileAsync(_coverLetterFileId, $"Cover Letter - {_companyName} - {_jobTitle}.docx");
    }

    async Task DownloadTailoredResume()
    {
        if (_tailoredResumeFileId is null) return;
        await DownloadFileAsync(_tailoredResumeFileId, $"Resume - {_companyName} - {_jobTitle}.docx");
    }

    async Task DownloadFileAsync(string fileId, string fileName)
    {
        var file = await Db.GetFileAsync(fileId);
        if (file is null) { _error = "File not found."; return; }
        await Db.DownloadFileAsync(fileName, Convert.FromBase64String(file.DataBase64));
    }

    static string ScoreBadgeClass(string score) => score switch
    {
        "Excellent" => "bg-success",
        "Good"      => "bg-primary",
        "Fair"      => "bg-warning text-dark",
        _           => "bg-danger",
    };
}
