@page "/settings"
@inherits NavigationGuardBase
@inject IIndexedDbService Db
@inject IAiProviderFactory Providers
@inject IDemoDataService Demo
@inject AppToastService Toasts

<PageTitle>Settings — Simply Opportunity Tracker</PageTitle>

<NavigationLock OnBeforeInternalNavigation="HandleLocationChanging" />
<NavigationGuardModal Show="_showGuardModal" StayLabel="@StayLabel" LeaveLabel="@LeaveLabel"
                      OnStay="() => OnGuardStay()" OnLeave="() => OnGuardLeave()" />

<h4 class="mb-4">Settings</h4>

<div class="row g-4">
    <div class="col-12 col-md-6 offset-md-3">
        <div class="card">
            <div class="card-header">AI Provider</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">Provider</label>
                    <select class="form-select" @bind="_selectedProvider" @bind:after="OnProviderChanged">
                        @foreach (var p in Providers.All)
                        {
                            <option value="@p.ProviderId">@p.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">API Key</label>
                    <input type="password" class="form-control" @bind="_apiKey"
                           placeholder="sk-…" autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Model</label>
                    <select class="form-select" @bind="_selectedModel">
                        @foreach (var m in _models)
                        {
                            <option value="@m.Id">@m.DisplayName</option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">Resume Generation</div>
            <div class="card-body">
                <div class="mb-0">
                    <label class="form-label d-flex align-items-center gap-2">
                        Output resume pages
                        <button type="button"
                                class="btn btn-link p-0 lh-1 text-muted"
                                style="font-size:.85rem"
                                data-bs-toggle="popover"
                                data-bs-trigger="click"
                                data-bs-placement="right"
                                data-bs-title="Output resume pages"
                                data-bs-content="The number of pages is passed to the AI as a guideline, not a hard constraint — the model targets it, but will not be effective at hard pruning (for example, 2 pages compressed to 1 page). The most reliable result comes from keeping the output the same length as the original resume, which is the default when this field is left empty."
                                aria-label="More information about output resume pages">
                            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="12" cy="12" r="10"/>
                                <line x1="12" y1="8" x2="12" y2="12"/>
                                <line x1="12" y1="16" x2="12.01" y2="16"/>
                            </svg>
                        </button>
                    </label>
                    <input type="number" class="form-control" @bind="_outputResumePages" min="1" max="10"
                           placeholder="Same as input" />
                    <div class="form-text">
                        Leave empty to match the page count of the uploaded resume.
                    </div>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-header">Storage</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label mb-1">Storage usage</label>
                    @if (!_storageLoaded)
                    {
                        <div class="text-muted small">Calculating…</div>
                    }
                    else
                    {
                        @if (_storageQuota > 0)
                        {
                            var pct = Math.Min(100.0, _storageUsage * 100.0 / _storageQuota);
                            <div class="d-flex justify-content-between small text-muted mb-1">
                                <span>@pct.ToString("F1")% of @FormatBytes(_storageQuota)</span>
                                <span>@FormatBytes(_storageUsage) used</span>
                            </div>
                            <div class="progress mb-3" style="height:8px">
                                <div class="progress-bar" role="progressbar"
                                     style="width:@pct.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%"
                                     aria-valuenow="@((int)pct)" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                        }
                        @foreach (var group in _storeGroups)
                        {
                            <div class="d-flex justify-content-between small mt-1">
                                <span class="text-muted">@group.Label</span>
                                <span>@FormatBytes(group.Bytes)</span>
                            </div>
                        }
                    }
                </div>
                <hr class="my-3" />
                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-outline-secondary" @onclick="ExportAsync" disabled="@_exporting">
                        @(_exporting ? "Exporting…" : "Export Data")
                    </button>
                    <label class="btn btn-outline-secondary mb-0">
                        Import Data
                        <InputFile @key="@_importInputKey" style="display:none"
                                   OnChange="HandleImportFileSelected"
                                   accept=".json,.json.gz" />
                    </label>
                </div>
                <div class="form-text mt-2">
                    Export saves all your data as a compressed backup (.json.gz).
                    Import replaces all existing data; settings are not affected.
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3">
            <button class="btn btn-primary" @onclick="SaveAsync">Save</button>
            <div class="ms-auto d-flex gap-2">
                <button class="btn btn-outline-secondary" @onclick="LoadDemoDataAsync" disabled="@_loadingDemo">
                    @(_loadingDemo ? "Loading…" : "Load Demo Data")
                </button>
                <button class="btn btn-outline-danger" @onclick="() => _confirmClear = true">
                    Clear Storage
                </button>
            </div>
        </div>

        @if (_error is not null)
        {
            <div class="alert alert-danger mt-3">@_error</div>
        }
    </div>
</div>

@if (_confirmClear)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Clear Storage</h5>
                    <button class="btn-close" @onclick="() => _confirmClear = false"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-semibold text-danger mb-2">This action is permanent and cannot be undone.</p>
                    <p class="mb-2">The following data will be permanently deleted:</p>
                    <ul class="mb-2">
                        <li>Sessions &amp; Files</li>
                        <li>Resumes</li>
                        <li>Organizations &amp; Contacts</li>
                        <li>Opportunities</li>
                        <li>Correspondence</li>
                    </ul>
                    <p class="mb-0">Your settings (API key, model, preferences) will not be affected.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _confirmClear = false">Cancel</button>
                    <button class="btn btn-danger" @onclick="ClearStorageAsync">Yes, delete everything</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_confirmDemoLoad)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Load Demo Data</h5>
                    <button class="btn-close" @onclick="() => _confirmDemoLoad = false"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-semibold text-danger mb-2">This will permanently delete all existing data.</p>
                    <p class="mb-0">All current records will be replaced with demo data. Your settings (API key, model, preferences) will not be affected.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _confirmDemoLoad = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmLoadDemoDataAsync">Yes, load demo data</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showValidationModal && _validationResult is not null)
{
    var hasErrors   = _validationResult.HasErrors;
    var hasWarnings = _validationResult.HasWarnings;
    var errCount    = _validationResult.Errors.Count;
    var warnCount   = _validationResult.Warnings.Count;
    var summary = (hasErrors, hasWarnings) switch {
        (true,  true)  => $"Found {errCount} error{(errCount  == 1 ? "" : "s")} and {warnCount} warning{(warnCount == 1 ? "" : "s")} in the backup file.",
        (true,  false) => $"Found {errCount} error{(errCount  == 1 ? "" : "s")} in the backup file.",
        _              => $"Found {warnCount} warning{(warnCount == 1 ? "" : "s")} in the backup file."
    };

    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);z-index:1055">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(hasErrors ? "Backup Validation Issues" : "Backup Validation Warnings")</h5>
                    <button class="btn-close" @onclick="CancelValidationAsync"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-3">@summary</p>

                    @if (hasErrors)
                    {
                        <div class="mb-3">
                            <button class="btn btn-link p-0 fw-semibold text-danger text-decoration-none"
                                    @onclick="() => _errorsExpanded = !_errorsExpanded">
                                @(_errorsExpanded ? "▾" : "▸") Errors (@errCount)
                            </button>
                            @if (_errorsExpanded)
                            {
                                <ul class="mt-2 mb-0 small" style="max-height:15rem;overflow-y:auto">
                                    @foreach (var msg in _validationResult.Errors)
                                    {
                                        <li class="text-danger-emphasis font-monospace">@msg</li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    @if (hasWarnings)
                    {
                        <div class="@(hasErrors ? "mb-0" : "mb-3")">
                            <button class="btn btn-link p-0 fw-semibold text-warning-emphasis text-decoration-none"
                                    @onclick="() => _warningsExpanded = !_warningsExpanded">
                                @(_warningsExpanded ? "▾" : "▸") Warnings (@warnCount)
                            </button>
                            @if (_warningsExpanded)
                            {
                                <ul class="mt-2 mb-0 small" style="max-height:15rem;overflow-y:auto">
                                    @foreach (var msg in _validationResult.Warnings)
                                    {
                                        <li class="font-monospace">@msg</li>
                                    }
                                </ul>
                            }
                        </div>
                    }

                    @if (hasErrors)
                    {
                        <div class="alert alert-danger mb-0 mt-3">
                            <strong>Warning:</strong> Importing a backup with errors may cause runtime failures,
                            missing records, or data corruption. Proceed only if you understand and accept these risks.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelValidationAsync">Cancel</button>
                    @if (hasErrors)
                    {
                        <button class="btn btn-danger" @onclick="ConfirmValidation">Import Anyway</button>
                    }
                    else
                    {
                        <button class="btn btn-primary" @onclick="ConfirmValidation">Import</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (_confirmImport)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4);z-index:1055">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Import Backup</h5>
                    <button class="btn-close" @onclick="CancelImportAsync"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-semibold text-danger mb-2">This will replace all existing data.</p>
                    <p class="mb-0">All current records (sessions, files, organizations, contacts,
                        opportunities, correspondence, resumes) will be permanently replaced with
                        the contents of the backup. Your settings will not be affected.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelImportAsync">Cancel</button>
                    <button class="btn btn-danger" @onclick="PerformImportAsync">Yes, import and replace</button>
                </div>
            </div>
        </div>
    </div>
}

@inject IJSRuntime JS

@code {
    string _selectedProvider = "openai";
    string _apiKey = "";
    string _selectedModel = "";
    int? _outputResumePages;

    record StoreGroup(string Label, long Bytes);
    List<StoreGroup> _storeGroups = new();
    long _storageQuota;
    long _storageUsage;
    bool _storageLoaded;

    bool _confirmClear;
    bool _confirmDemoLoad;
    bool _loadingDemo;
    string? _error;

    bool _exporting;
    bool _confirmImport;
    int _importInputKey;

    BackupValidationResult? _validationResult;
    bool _showValidationModal;
    bool _errorsExpanded;
    bool _warningsExpanded;

    IReadOnlyList<AiModel> _models = Array.Empty<AiModel>();
    AppSettings _settings = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);
        if (firstRender)
            await JS.InvokeVoidAsync("eval",
                "document.querySelectorAll('[data-bs-toggle=\"popover\"]')" +
                ".forEach(el => bootstrap.Popover.getOrCreateInstance(el))");
    }

    // ── Navigation guard ──────────────────────────────────────────────────────

    protected override bool IsDirty =>
        _selectedProvider != _settings.AiProvider ||
        _apiKey != (_settings.ProviderApiKeys.GetValueOrDefault(_selectedProvider) ?? "") ||
        _selectedModel != (_settings.ProviderModels.GetValueOrDefault(_selectedProvider)
                           ?? Providers.Get(_selectedProvider).DefaultModelId) ||
        _outputResumePages != _settings.OutputResumePages;

    protected override string StayLabel  => "Stay and save settings";
    protected override string LeaveLabel => "Discard changes and leave";

    protected override async Task OnInitializedAsync()
    {
        _settings = await Db.GetSettingsAsync();
        _selectedProvider = _settings.AiProvider;
        _outputResumePages = _settings.OutputResumePages;
        LoadProviderFields();

        await LoadStorageUsageAsync();
    }

    static readonly string[] _allStores =
    [
        "sessions", "files",
        "baseResumes", "baseResumeVersions",
        "organizations", "contacts", "contactOpportunityRoles", "lookupIndustries", "lookupContactRoles",
        "opportunities", "opportunityFieldHistory",
        "correspondence", "correspondenceFiles",
    ];

    async Task LoadStorageUsageAsync()
    {
        var storeBytes = await Db.GetStoreBytesAsync(_allStores);

        long Sum(params string[] names) => names.Sum(n => storeBytes.GetValueOrDefault(n));

        _storeGroups =
        [
            new("Sessions & Files",           Sum("sessions", "files")),
            new("Resumes",                    Sum("baseResumes", "baseResumeVersions")),
            new("Organizations & Contacts",   Sum("organizations", "contacts", "contactOpportunityRoles", "lookupIndustries", "lookupContactRoles")),
            new("Opportunities",              Sum("opportunities", "opportunityFieldHistory")),
            new("Correspondence",             Sum("correspondence", "correspondenceFiles")),
        ];

        var estimate = await JS.InvokeAsync<double[]?>("sjaGetStorageEstimate");
        if (estimate is { Length: >= 2 })
        {
            _storageQuota = (long)estimate[0];
            _storageUsage = (long)estimate[1];
        }

        _storageLoaded = true;
    }

    static string FormatBytes(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824.0:F1} GB";
        if (bytes >= 1_048_576)     return $"{bytes / 1_048_576.0:F1} MB";
        if (bytes >= 1_024)         return $"{bytes / 1_024.0:F1} KB";
        return $"{bytes} B";
    }

    void LoadProviderFields()
    {
        var provider = Providers.Get(_selectedProvider);
        _models = provider.AvailableModels;
        _apiKey = _settings.ProviderApiKeys.GetValueOrDefault(_selectedProvider) ?? "";
        _selectedModel = _settings.ProviderModels.GetValueOrDefault(_selectedProvider)
                         ?? provider.DefaultModelId;
    }

    void OnProviderChanged()
    {
        LoadProviderFields();
    }

    async Task SaveAsync()
    {
        _error = null;
        try
        {
            _settings.AiProvider = _selectedProvider;
            _settings.ProviderApiKeys[_selectedProvider] = _apiKey;
            _settings.ProviderModels[_selectedProvider] = _selectedModel;
            _settings.OutputResumePages = _outputResumePages;
            await Db.SaveSettingsAsync(_settings);
            Toasts.ShowSuccess("Settings saved.");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    async Task ClearStorageAsync()
    {
        _confirmClear = false;
        try
        {
            await Db.ClearAllUserDataAsync();
            Toasts.ShowSuccess("All data was cleared.");
            await LoadStorageUsageAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    async Task ExportAsync()
    {
        _exporting = true;
        _error = null;
        try
        {
            var base64 = await Db.ExportDataAsync();
            var date = DateTime.Now.ToString("yyyy-MM-dd");
            await Db.DownloadGenericFileAsync($"simply-backup-{date}.json.gz", base64);
            Toasts.ShowSuccess("Backup exported.");
        }
        catch (Exception ex)
        {
            _error = $"Export failed: {ex.Message}";
        }
        finally
        {
            _exporting = false;
        }
    }

    async Task HandleImportFileSelected(InputFileChangeEventArgs e)
    {
        _error           = null;
        _validationResult = null;
        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 100 * 1024 * 1024).CopyToAsync(ms);
            var bytes   = ms.ToArray();
            var isGzip  = bytes.Length >= 2 && bytes[0] == 0x1f && bytes[1] == 0x8b;
            var base64  = Convert.ToBase64String(bytes);

            // Throws for fatal errors (parse failure, unsupported/future schema version).
            // Returns { Errors, Warnings } for content validation issues.
            var result = await Db.ValidateBackupAsync(base64, isGzip);

            if (result.HasIssues)
            {
                _validationResult  = result;
                _errorsExpanded    = result.HasErrors;
                _warningsExpanded  = !result.HasErrors && result.HasWarnings;
                _showValidationModal = true;
            }
            else
            {
                _confirmImport = true;
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to validate file: {ex.Message}";
            await Db.ClearPendingImportAsync();
            _importInputKey++;
        }
    }

    // Called from the validation modal Cancel button / X button.
    async Task CancelValidationAsync()
    {
        _showValidationModal = false;
        _validationResult    = null;
        await Db.ClearPendingImportAsync();
        _importInputKey++;
    }

    // Called from the validation modal "Import" / "Import Anyway" button.
    void ConfirmValidation()
    {
        _showValidationModal = false;
        _validationResult    = null;
        _confirmImport       = true;
    }

    // Called from the overwrite-confirmation modal Cancel button / X button.
    async Task CancelImportAsync()
    {
        _confirmImport = false;
        await Db.ClearPendingImportAsync();
        _importInputKey++;
    }

    async Task LoadDemoDataAsync()
    {
        _error = null;
        var isEmpty = await Demo.IsDatabaseEmptyAsync();
        if (isEmpty)
        {
            await ConfirmLoadDemoDataAsync();
        }
        else
        {
            _confirmDemoLoad = true;
        }
    }

    async Task ConfirmLoadDemoDataAsync()
    {
        _confirmDemoLoad = false;
        _loadingDemo = true;
        _error = null;
        try
        {
            await Demo.LoadDemoDataAsync();
            await LoadStorageUsageAsync();
            Toasts.ShowSuccess("Loaded demo data - explore freely. Visit Settings page to clear demo data.");
        }
        catch (Exception ex)
        {
            _error = $"Failed to load demo data: {ex.Message}";
        }
        finally
        {
            _loadingDemo = false;
        }
    }

    async Task PerformImportAsync()
    {
        _confirmImport = false;
        _error         = null;
        try
        {
            await Db.ImportMigratedDataAsync();
            await JS.InvokeVoidAsync("eval", "location.reload()");
        }
        catch (Exception ex)
        {
            _error = $"Import failed: {ex.Message}";
            await Db.ClearPendingImportAsync();
            _importInputKey++;
        }
    }
}
