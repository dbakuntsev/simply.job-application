@page "/"
@page "/welcome"
@layout Layout.WelcomeLayout
@inject NavigationManager Nav
@inject Simply.JobApplication.Services.IIndexedDbService Db

<PageTitle>Welcome — Simply Opportunity Tracker</PageTitle>

@if (_ready)
{
<!-- ══ HERO ═══════════════════════════════════════════════════════════════════ -->
<section class="wlc-hero">
    <div class="container text-center py-5 px-4">
        <span class="badge rounded-pill text-bg-primary wlc-badge mb-4">
            FREE / FOSS &nbsp;·&nbsp; Bring Your Own AI Key &nbsp;·&nbsp; 100% Private
        </span>
        <h1 class="display-4 fw-bold mb-3 lh-sm">
            Opportunity<br>
