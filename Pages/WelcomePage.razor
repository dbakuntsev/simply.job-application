@page "/"
@page "/welcome"
@layout Layout.WelcomeLayout
@inject NavigationManager Nav
@inject IIndexedDbService Db
@inject IDemoDataService Demo
@inject IPwaService Pwa
@inject AppToastService Toasts
@implements IDisposable

<PageTitle>Welcome - Simply Opportunity Tracker</PageTitle>

@if (_ready)
{
    <section class="wlc-hero">
        <div class="container py-5 px-4">
            <div class="row justify-content-center text-center">
                <div class="col-12 col-xl-9">
                    <div class="wlc-trust-strip text-bg-primary mx-auto mb-4">
                        100% private · Bring your own AI key · Works offline (PWA)
                    </div>

                    <h1 class="display-4 fw-bold mb-3 lh-sm">
                        Private Opportunity Tracker with Built-in AI
                    </h1>

                    <p class="lead text-muted mx-auto mb-4" style="max-width:720px">
                        Manage your pipeline and generate tailored resumes and cover letters - all in your browser.
                        No accounts. No data leaves your machine.
                    </p>

                    <div class="d-flex justify-content-center gap-3 flex-wrap mb-3">
                        <button class="btn btn-primary btn-lg px-5"
                                @onclick="TryDemoAsync"
                                disabled="@_busy">
                            @(_busyAction == WelcomeAction.TryDemo ? "Loading..." : "Try Demo")
                        </button>
                        <button class="btn btn-outline-primary btn-lg px-4"
                                @onclick="StartFromScratchAsync"
                                disabled="@_busy">
                            Start from Scratch
                        </button>
                        <button class="btn btn-outline-secondary btn-lg px-4"
                                @onclick="GoToEvaluate">
                            Evaluate &amp; Generate
                        </button>
                    </div>

                    <div class="d-flex justify-content-center align-items-center gap-3 flex-wrap wlc-tertiary">
                        @if (Pwa.IsInstallable && !Pwa.IsStandalone)
                        {
                            <button class="btn btn-link p-0 wlc-tertiary-link"
                                    @onclick="InstallAsync">
                                Install App
                            </button>
                            <span class="text-muted">·</span>
                        }
                        <a href="https://github.com/dbakuntsev/simply.job-application"
                           target="_blank"
                           rel="noopener noreferrer">GitHub</a>
                        <span class="text-muted">·</span>
                        <a href="https://github.com/sponsors/dbakuntsev"
                           target="_blank"
                           rel="noopener noreferrer">Sponsor</a>
                    </div>

                    @if (_error is not null)
                    {
                        <div class="alert alert-danger mt-4 mb-0 text-start mx-auto" style="max-width:720px">
                            @_error
                        </div>
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="py-5">
        <div class="container">
            <div class="text-center mb-5">
                <p class="wlc-section-eyebrow">Choose your path</p>
                <h2 class="fw-bold mb-0">Two ways to use the app</h2>
            </div>

            <div class="row g-4">
                <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4 p-lg-5">
                            <h5 class="fw-bold mb-4">
                                <span class="wlc-path-icon wlc-path-primary me-2">1</span>
                                Manage Your Pipeline
                            </h5>
                            <div class="d-flex flex-column gap-4">
                                <div>
                                    <h6 class="fw-bold mb-1">Organizations, Contacts, Opportunities</h6>
                                    <p class="text-muted mb-0">
                                        Track target organizations, people, roles, stages, compensation, and requirements.
                                    </p>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Correspondence History</h6>
                                    <p class="text-muted mb-0">
                                        Log submissions, emails, calls, interviews, files, and follow-ups against the right opportunity.
                                    </p>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Browser-Only Storage</h6>
                                    <p class="text-muted mb-0">
                                        All your data lives in IndexedDB on this device, with offline access through the PWA.
                                    </p>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Demo or Clean Start</h6>
                                    <p class="text-muted mb-0">
                                        Explore a populated sample pipeline, or begin with an empty workspace and build your own.
                                    </p>
                                </div>
                            </div>
                            <button class="btn btn-primary mt-4" @onclick="TryDemoAsync" disabled="@_busy">
                                Try Demo
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body p-4 p-lg-5">
                            <h5 class="fw-bold mb-4">
                                <span class="wlc-path-icon wlc-path-secondary me-2">2</span>
                                Evaluate &amp; Generate
                            </h5>
                            <div class="d-flex flex-column gap-4">
                                <div>
                                    <h6 class="fw-bold mb-1">Bring Your Own Resume</h6>
                                    <p class="text-muted mb-0">
                                        Upload a base resume and reuse it across evaluation sessions without sending it to this app's servers.
                                    </p>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Paste a Role Description</h6>
                                    <p class="text-muted mb-0">
                                        Score fit, identify gaps, and collect ATS keywords from the opportunity you care about.
                                    </p>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Generate Application Materials</h6>
                                    <p class="text-muted mb-0">
                                        Produce tailored resumes, cover letters, and why-apply summaries using your own AI provider key.
                                    </p>
                                </div>
                                <div>
                                    <h6 class="fw-bold mb-1">Ask Follow-up Questions</h6>
                                    <p class="text-muted mb-0">
                                        Pose role- or history-specific questions and get answers grounded in the opportunity and your resume.
                                    </p>
                                </div>
                            </div>
                            <button class="btn btn-outline-primary mt-4" @onclick="GoToEvaluate">
                                Go to Evaluate &amp; Generate
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="wlc-alt-bg py-5">
        <div class="container">
            <div class="text-center mb-5">
                <p class="wlc-section-eyebrow">What you get</p>
                <h2 class="fw-bold mb-0">Everything in one private workspace</h2>
            </div>

            <div class="row g-4">
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-1">Opportunity Pipeline</h6>
                            <p class="text-muted mb-0">Track stages, requirements, compensation, posting URLs, and decision history.</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-1">Contacts &amp; Correspondence</h6>
                            <p class="text-muted mb-0">Keep recruiters, hiring managers, messages, calls, interviews, and files together.</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-1">Resume Library</h6>
                            <p class="text-muted mb-0">Store base resumes, version them, and compare versions before generating.</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-1">AI Match Scoring</h6>
                            <p class="text-muted mb-0">Review strengths, gaps, suggested keywords, and fit summaries for each role.</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-1">Generated Materials</h6>
                            <p class="text-muted mb-0">Download tailored resumes and cover letters from saved generation sessions.</p>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card border-0 h-100">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-1">Ask the AI</h6>
                            <p class="text-muted mb-0">Get tailored answers about an opportunity using its full evaluation context and correspondence history.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="wlc-dark-bg py-5">
        <div class="container text-center">
            <h3 class="fw-bold text-white mb-3">Your data stays in your browser</h3>
            <p class="mb-4 mx-auto" style="max-width:640px;color:rgba(255,255,255,.75)">
                Organizations, contacts, opportunities, correspondence, resumes, and generated materials are stored in IndexedDB.
                The only external calls are to your chosen AI provider using your own API key.
            </p>
            <button class="btn btn-light btn-lg px-5 fw-semibold" @onclick="StartFromScratchAsync" disabled="@_busy">
                Start from Scratch
            </button>
        </div>
    </section>
}

@if (_confirmDemoLoad)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Load Demo Data</h5>
                    <button class="btn-close" @onclick="CancelDemoLoad"></button>
                </div>
                <div class="modal-body">
                    <p class="fw-semibold text-danger mb-2">This will permanently delete all existing data.</p>
                    <p class="mb-0">All current records will be replaced with demo data. Your settings (API key, model, preferences) will not be affected.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDemoLoad">Cancel</button>
                    <button class="btn btn-primary" @onclick="ConfirmLoadDemoDataAsync" disabled="@_busy">
                        @(_busyAction == WelcomeAction.TryDemo ? "Loading..." : "Yes, load demo data")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showStartChoice)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Start from Scratch</h5>
                    <button class="btn-close" @onclick="CancelStartChoice"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-0">The database is not empty. Would you like to clear it before continuing?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelStartChoice">Cancel</button>
                    <button class="btn btn-outline-primary" @onclick="KeepDataAndContinue">Keep Data</button>
                    <button class="btn btn-danger" @onclick="ClearDataAndContinueAsync" disabled="@_busy">
                        @(_busyAction == WelcomeAction.ClearData ? "Clearing..." : "Clear Data")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .wlc-hero {
        border-bottom: 1px solid #dee2e6;
        background:
            linear-gradient(135deg, rgba(var(--bs-primary-rgb), .08), rgba(var(--bs-success-rgb), .08)),
            #fff;
    }

    h1:focus { outline: none; }

    .wlc-trust-strip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .45rem .85rem;
        border: 1px solid rgba(var(--bs-primary-rgb), .2);
        border-radius: 999px;
        background: rgba(255, 255, 255, .8);
        color: #334155;
        font-size: .92rem;
        font-weight: 600;
    }

    .wlc-tertiary,
    .wlc-tertiary a,
    .wlc-tertiary-link {
        color: #495057;
        font-weight: 600;
        text-decoration: none;
        font-size: 1rem;
    }

    .wlc-tertiary a:hover,
    .wlc-tertiary-link:hover {
        color: var(--bs-primary);
        text-decoration: underline;
    }

    .wlc-alt-bg { background: #f8f9fa; }
    .wlc-dark-bg { background: #2c3e50; }

    .wlc-section-eyebrow {
        font-size: .8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--bs-primary);
        margin-bottom: .25rem;
    }

    .wlc-path-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 6px;
        vertical-align: middle;
        font-size: .9rem;
        font-weight: 700;
    }

    .wlc-path-primary {
        background: rgba(var(--bs-primary-rgb), .12);
        color: var(--bs-primary);
    }

    .wlc-path-secondary {
        background: rgba(var(--bs-success-rgb), .12);
        color: var(--bs-success);
    }

    @@media (max-width: 575.98px) {
        .wlc-trust-strip {
            border-radius: 8px;
            line-height: 1.35;
        }

        .wlc-hero .btn {
            width: 100%;
        }
    }
</style>

@code {
    private const string DemoLoadedToast = "Loaded demo data - explore freely. Visit Settings page to clear demo data.";
    private bool _ready;
    private bool _busy;
    private bool _confirmDemoLoad;
    private bool _showStartChoice;
    private string? _error;
    private WelcomeAction? _busyAction;

    private enum WelcomeAction
    {
        TryDemo,
        ClearData
    }

    protected override void OnInitialized() => Pwa.StateChanged += OnPwaStateChanged;

    protected override async Task OnInitializedAsync()
    {
        await Pwa.EnsureInitializedAsync();
        _ready = true;
    }

    private void OnPwaStateChanged() => InvokeAsync(StateHasChanged);

    private async Task TryDemoAsync()
    {
        _error = null;
        var isEmpty = await Demo.IsDatabaseEmptyAsync();
        if (isEmpty)
        {
            await LoadDemoAndNavigateAsync();
        }
        else
        {
            _confirmDemoLoad = true;
        }
    }

    private async Task ConfirmLoadDemoDataAsync() => await LoadDemoAndNavigateAsync();

    private async Task LoadDemoAndNavigateAsync()
    {
        _confirmDemoLoad = false;
        _busy = true;
        _busyAction = WelcomeAction.TryDemo;
        try
        {
            await Demo.LoadDemoDataAsync();
            Toasts.ShowSuccess(DemoLoadedToast);
            NavigateToOrganizations();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load demo data: {ex.Message}";
        }
        finally
        {
            _busy = false;
            _busyAction = null;
        }
    }

    private async Task StartFromScratchAsync()
    {
        _error = null;
        var isEmpty = await Demo.IsDatabaseEmptyAsync();
        if (isEmpty)
        {
            Toasts.ShowInfo("Start by adding an Organization");
            NavigateToOrganizations();
        }
        else
        {
            _showStartChoice = true;
        }
    }

    private async Task ClearDataAndContinueAsync()
    {
        _busy = true;
        _busyAction = WelcomeAction.ClearData;
        _showStartChoice = false;
        _error = null;
        try
        {
            await Db.ClearAllUserDataAsync();
            Toasts.ShowSuccess("All data was cleared");
            NavigateToOrganizations();
        }
        catch (Exception ex)
        {
            _error = $"Failed to clear data: {ex.Message}";
        }
        finally
        {
            _busy = false;
            _busyAction = null;
        }
    }

    private void KeepDataAndContinue()
    {
        _showStartChoice = false;
        NavigateToOrganizations();
    }

    private void CancelDemoLoad() => _confirmDemoLoad = false;

    private void CancelStartChoice() => _showStartChoice = false;

    private void NavigateToOrganizations() => Nav.NavigateTo("organizations");

    private void GoToEvaluate() => Nav.NavigateTo("evaluate");

    private async Task InstallAsync() => await Pwa.PromptInstallAsync();

    public void Dispose() => Pwa.StateChanged -= OnPwaStateChanged;
}
