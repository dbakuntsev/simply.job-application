<style>
    /* ── Hero ─────────────────────────────────────────────────────────────────── */
    .wlc-hero {
        border-bottom: 1px solid #dee2e6;
    }

    /* ── Section backgrounds ──────────────────────────────────────────────────── */
    .wlc-alt-bg  { background: #f8f9fa; }
    .wlc-dark-bg { background: #2c3e50; }

    /* ── Focus ring suppression (Blazor FocusOnNavigate programmatic focus) ─────── */
    h1:focus { outline: none; }

    /* ── Badge / eyebrow ──────────────────────────────────────────────────────── */
    .wlc-badge {
        font-size: 1rem;
        letter-spacing: .07em;
    }

    .wlc-accent { color: var(--bs-primary); }

    .wlc-section-eyebrow {
        font-size: .8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--bs-primary);
        margin-bottom: .25rem;
    }

    /* ── Path header icons ────────────────────────────────────────────────────── */
    .wlc-path-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 6px;
        vertical-align: middle;
    }
    .wlc-path-primary  { background: rgba(var(--bs-primary-rgb), .12); color: var(--bs-primary); }
    .wlc-path-secondary { background: rgba(var(--bs-success-rgb), .12); color: var(--bs-success); }

    /* ── Icon circles ─────────────────────────────────────────────────────────── */
    .wlc-icon-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        border-radius: 50%;
    }

    .wlc-icon-light { background: rgba(255, 255, 255, .15); color: #fff; }

    /* ── Feature icons ────────────────────────────────────────────────────────── */
    .wlc-feature-icon { line-height: 1; }

    /* ── Check items ──────────────────────────────────────────────────────────── */
    .wlc-check-item {
        display: flex;
        align-items: flex-start;
        gap: .75rem;
    }

    .wlc-check-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        min-width: 1.5rem;
        border-radius: 50%;
        background: rgba(var(--bs-success-rgb), .12);
        color: var(--bs-success);
        margin-top: .05rem;
    }

    /* ── Numbered circles ─────────────────────────────────────────────────────── */
    .wlc-num-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        min-width: 2.5rem;
        border-radius: 50%;
        background: var(--bs-primary);
        color: #fff;
        font-size: .85rem;
        font-weight: 700;
    }

    .wlc-num-secondary {
        background: var(--bs-success);
    }
</style>

@code {
    private bool _ready;

    protected override async Task OnInitializedAsync()
    {
        var relPath = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        if (relPath == "")
        {
            var orgs = await Db.GetAllOrganizationsAsync();
            if (orgs.Count > 0) { Nav.NavigateTo("organizations", replace: true); return; }
            var resumes = await Db.GetAllBaseResumesAsync();
            if (resumes.Count > 0) { Nav.NavigateTo("organizations", replace: true); return; }
            var sessions = await Db.GetAllSessionsAsync();
            if (sessions.Count > 0) { Nav.NavigateTo("organizations", replace: true); return; }
        }
        _ready = true;
    }
}
