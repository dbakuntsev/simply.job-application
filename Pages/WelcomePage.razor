<!-- ══ HOW TO GET STARTED ══════════════════════════════════════════════════════ -->
<section class="wlc-alt-bg py-5">
    <div class="container">
        <div class="text-center mb-5">
            <p class="wlc-section-eyebrow">Get up and running</p>
            <h2 class="fw-bold mb-0">Start in under five minutes</h2>
        </div>

        <div class="row justify-content-center">
            <div class="col-12 col-lg-8">
                <div class="d-flex flex-column gap-4">
                    <div class="d-flex gap-4 align-items-start">
                        <div class="wlc-num-circle flex-shrink-0">1</div>
                        <div>
                            <h6 class="fw-bold mb-1">Get an OpenAI API key</h6>
                            <p class="text-muted small mb-0">
                                Create a key at <strong>platform.openai.com</strong> and paste it into
                                <a href="settings">Settings</a>. Your key is stored only in your
                                browser's local storage — never on any server.
                            </p>
                        </div>
                    </div>
                    <div class="d-flex gap-4 align-items-start">
                        <div class="wlc-num-circle flex-shrink-0">2</div>
                        <div>
                            <h6 class="fw-bold mb-1">Upload your resume</h6>
                            <p class="text-muted small mb-0">
                                On the <a href="evaluate">Evaluate &amp; Generate</a> screen, upload a DOCX
                                file. The document is parsed locally — hyperlinks and formatting are preserved
                                for the round-trip back to DOCX.
                            </p>
                        </div>
                    </div>
                    <div class="d-flex gap-4 align-items-start">
                        <div class="wlc-num-circle flex-shrink-0">3</div>
                        <div>
                            <h6 class="fw-bold mb-1">Paste the job description and evaluate</h6>
                            <p class="text-muted small mb-0">
                                Click <strong>Evaluate</strong>. Review the match score, strengths, gaps, and
                                suggested keywords. Select any keywords you are comfortable claiming and
                                optionally re-evaluate to see the updated score.
                            </p>
                        </div>
                    </div>
                    <div class="d-flex gap-4 align-items-start">
                        <div class="wlc-num-circle flex-shrink-0">4</div>
                        <div>
                            <h6 class="fw-bold mb-1">Generate and download</h6>
                            <p class="text-muted small mb-0">
                                Click <strong>Generate</strong> to produce your tailored resume, cover letter,
                                and why-apply summary. Download the DOCX files and submit your application.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ PRIVACY TRUST BLOCK ════════════════════════════════════════════════════ -->
<section class="wlc-dark-bg py-5">
    <div class="container text-center">
        <div class="wlc-icon-circle wlc-icon-light mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
        </div>
        <h3 class="fw-bold text-white mb-3">Your data stays in your browser</h3>
        <p class="mb-5 mx-auto" style="max-width:560px;color:rgba(255,255,255,.75)">
            Resumes, job descriptions, evaluation results, and generated materials are stored
            exclusively in your browser's IndexedDB. Nothing is sent to any server operated by
            this application. The only external calls are to the OpenAI API using your own key,
            subject to OpenAI's data handling policies.
        </p>
        <a href="evaluate" class="btn btn-light btn-lg px-5 fw-semibold">Get Started</a>
    </div>
</section>

<style>
    /* ── Hero ─────────────────────────────────────────────────────────────────── */
    .wlc-hero {
        border-bottom: 1px solid #dee2e6;
    }

    /* ── Section backgrounds ──────────────────────────────────────────────────── */
    .wlc-alt-bg  { background: #f8f9fa; }
    .wlc-dark-bg { background: #2c3e50; }

    /* ── Focus ring suppression (Blazor FocusOnNavigate programmatic focus) ─────── */
    h1:focus { outline: none; }

    /* ── Badge / eyebrow ──────────────────────────────────────────────────────── */
    .wlc-badge {
        font-size: 1rem;
        letter-spacing: .07em;
    }

    .wlc-accent { color: var(--bs-primary); }

    .wlc-section-eyebrow {
        font-size: .75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: var(--bs-primary);
        margin-bottom: .25rem;
    }

    /* ── Step pill ─────────────────────────────────────────────────────────────── */
    .wlc-step-pill {
        font-size: .95rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #6c757d;
        border: 1px solid #dee2e6;
        border-radius: 100px;
        padding: .2rem .7rem;
    }

    /* ── Icon circles ─────────────────────────────────────────────────────────── */
    .wlc-icon-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        border-radius: 50%;
    }

    .wlc-icon-primary { background: rgba(var(--bs-primary-rgb), .12); color: var(--bs-primary); }
    .wlc-icon-success { background: rgba(var(--bs-success-rgb), .12); color: var(--bs-success); }
    .wlc-icon-warning { background: rgba(var(--bs-warning-rgb), .15); color: var(--bs-warning); }
    .wlc-icon-light   { background: rgba(255, 255, 255, .15);         color: #fff; }

    /* ── Feature icons ────────────────────────────────────────────────────────── */
    .wlc-feature-icon { line-height: 1; }

    /* ── Check items ──────────────────────────────────────────────────────────── */
    .wlc-check-item {
        display: flex;
        align-items: flex-start;
        gap: .75rem;
    }

    .wlc-check-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.5rem;
        height: 1.5rem;
        min-width: 1.5rem;
        border-radius: 50%;
        background: rgba(var(--bs-success-rgb), .12);
        color: var(--bs-success);
        margin-top: .05rem;
    }

    /* ── Numbered circles ─────────────────────────────────────────────────────── */
    .wlc-num-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        min-width: 2.5rem;
        border-radius: 50%;
        background: var(--bs-primary);
        color: #fff;
        font-size: .85rem;
        font-weight: 700;
    }
</style>
