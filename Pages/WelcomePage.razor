@page "/"
@layout Layout.WelcomeLayout

<PageTitle>Welcome — Simply Job Application</PageTitle>

<!-- ══ HERO ═══════════════════════════════════════════════════════════════════ -->
<section class="wlc-hero">
    <div class="container text-center py-5 px-4">
        <span class="badge rounded-pill text-bg-primary wlc-badge mb-4">
            FREE / FOSS &nbsp;·&nbsp; AI-Powered &nbsp;·&nbsp; 100% Browser-Side
        </span>
        <h1 class="display-4 fw-bold mb-3 lh-sm">
            Land the role.<br>
            <span class="wlc-accent">Faster.</span>
        </h1>
        <p class="lead text-muted mx-auto mb-5" style="max-width:560px">
            AI-powered resume tailoring and cover letter generation — entirely in your browser,
            with no data sent to any server except the AI model of your choice.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="evaluate" class="btn btn-primary btn-lg px-5">Get Started</a>
            <a href="settings" class="btn btn-outline-secondary btn-lg px-4">Configure API Key</a>
            <a href="https://github.com/dbakuntsev/simply.job-application" target="_blank" rel="noopener noreferrer"
               class="btn btn-secondary btn-lg px-4 d-inline-flex align-items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                </svg>
                GitHub
            </a>
        </div>
    </div>
</section>

<!-- ══ HOW IT WORKS ════════════════════════════════════════════════════════════ -->
<section class="py-5">
    <div class="container">
        <div class="text-center mb-5">
            <p class="wlc-section-eyebrow">How it works</p>
            <h2 class="fw-bold mb-0">Three steps to a stronger job application</h2>
        </div>

        <div class="row g-4">
            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body p-4 p-lg-5">
                        <div class="wlc-icon-circle wlc-icon-primary mx-auto mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/>
                                <path d="m21 21-4.35-4.35"/>
                            </svg>
                        </div>
                        <span class="wlc-step-pill mb-3 d-inline-block">Step 1</span>
                        <h5 class="fw-bold mb-2">Evaluate the Match</h5>
                        <p class="text-muted small mb-0">
                            Paste a job description and select your resume. The AI scores how well you
                            match the role, identifies your strongest qualifications, and flags gaps.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body p-4 p-lg-5">
                        <div class="wlc-icon-circle wlc-icon-success mx-auto mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/>
                                <circle cx="7" cy="7" r="1" fill="currentColor"/>
                            </svg>
                        </div>
                        <span class="wlc-step-pill mb-3 d-inline-block">Step 2</span>
                        <h5 class="fw-bold mb-2">Add Missing Keywords</h5>
                        <p class="text-muted small mb-0">
                            Review AI-suggested ATS keywords. Check the ones you genuinely have,
                            type your own, and optionally re-run the evaluation to see the new score.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body p-4 p-lg-5">
                        <div class="wlc-icon-circle wlc-icon-warning mx-auto mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                            </svg>
                        </div>
                        <span class="wlc-step-pill mb-3 d-inline-block">Step 3</span>
                        <h5 class="fw-bold mb-2">Generate Tailored Materials</h5>
                        <p class="text-muted small mb-0">
                            Get a tailored resume DOCX, a two-paragraph cover letter, and a concise
                            "why apply" summary — all optimised for ATS and ready to download.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ WHAT YOU GET ════════════════════════════════════════════════════════════ -->
<section class="wlc-alt-bg py-5">
    <div class="container">
        <div class="text-center mb-5">
            <p class="wlc-section-eyebrow">What you get</p>
            <h2 class="fw-bold mb-0">Everything you need, in one session</h2>
        </div>

        <div class="row g-4">
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card border-0 h-100">
                    <div class="card-body p-4">
                        <div class="wlc-feature-icon text-primary mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <line x1="18" y1="20" x2="18" y2="10"/>
                                <line x1="12" y1="20" x2="12" y2="4"/>
                                <line x1="6"  y1="20" x2="6"  y2="14"/>
                            </svg>
                        </div>
                        <h6 class="fw-bold mb-1">Match Score</h6>
                        <p class="text-muted small mb-0">
                            A 0–100 score with clear strengths and gaps so you know where you stand
                            before you apply.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card border-0 h-100">
                    <div class="card-body p-4">
                        <div class="wlc-feature-icon text-success mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <polygon points="12 2 2 7 12 12 22 7 12 2"/>
                                <polyline points="2 17 12 22 22 17"/>
                                <polyline points="2 12 12 17 22 12"/>
                            </svg>
                        </div>
                        <h6 class="fw-bold mb-1">Keyword Suggestions</h6>
                        <p class="text-muted small mb-0">
                            Grouped ATS keywords derived from the job description that you can
                            confirm and feed into generation.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card border-0 h-100">
                    <div class="card-body p-4">
                        <div class="wlc-feature-icon text-primary mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                                <polyline points="14 2 14 8 20 8"/>
                                <line x1="16" y1="13" x2="8" y2="13"/>
                                <line x1="16" y1="17" x2="8" y2="17"/>
                            </svg>
                        </div>
                        <h6 class="fw-bold mb-1">Tailored Resume</h6>
                        <p class="text-muted small mb-0">
                            Your resume rewritten to match the role — hyperlinks, formatting, and
                            structure preserved — exported as DOCX.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card border-0 h-100">
                    <div class="card-body p-4">
                        <div class="wlc-feature-icon text-success mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24"
                                 fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </div>
                        <h6 class="fw-bold mb-1">Cover Letter &amp; Why Apply</h6>
                        <p class="text-muted small mb-0">
                            A two-paragraph cover letter plus a concise summary of why you are a
                            strong candidate for this specific role.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ WHO IT'S FOR ════════════════════════════════════════════════════════════ -->
