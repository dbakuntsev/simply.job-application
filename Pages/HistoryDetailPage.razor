@page "/history/{Id}"
@inject IIndexedDbService Db
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Session Detail — Simply Job Application</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else if (_session is null)
{
    <div class="alert alert-warning">Session not found.</div>
    <a href="history" class="btn btn-secondary">Back to History</a>
}
else
{
    <!-- ── Secondary nav bar ────────────────────────────────────────────────── -->
    <div class="sja-progress-bar" role="navigation" aria-label="Session sections">
        <nav class="sja-steps" aria-label="Steps">
            <div class="sja-step completed" role="button" style="cursor:pointer"
                 @onclick="@(() => ScrollToAsync("hist-lane-input"))">
                <span class="sja-step-icon" aria-hidden="true">✓</span>
                <span>Input</span>
            </div>
            <div class="sja-step-connector" aria-hidden="true"></div>
            <div class="sja-step completed" role="button" style="cursor:pointer"
                 @onclick="@(() => ScrollToAsync("hist-lane-eval"))">
                <span class="sja-step-icon" aria-hidden="true">✓</span>
                <span>Evaluation</span>
            </div>
            <div class="sja-step-connector" aria-hidden="true"></div>
            <div class="sja-step @(_hasGenerated ? "completed" : "")" role="button" style="cursor:pointer"
                 @onclick="@(() => ScrollToAsync("hist-lane-gen"))">
                @if (_hasGenerated) { <span class="sja-step-icon" aria-hidden="true">✓</span> }
                <span>Generation</span>
            </div>
        </nav>
        <div class="d-flex align-items-center gap-2 ms-auto flex-shrink-0">
            <span class="badge @ScoreBadgeClass(_session.MatchScore)">@_session.MatchScore</span>
            <small class="text-muted d-none d-sm-inline">@_session.CreatedAt.ToLocalTime().ToString("g")</small>
            <a href="history" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>
    </div>

    <!-- ── Page title ────────────────────────────────────────────────────────── -->
    <h4 class="mb-3 mt-3">@_session.OrganizationNameSnapshot — @_session.Role</h4>

    <!-- ══ Swimlane 1: Input ════════════════════════════════════════════════ -->
    <section id="hist-lane-input" class="sja-swimlane sja-lane-input" aria-label="Job and Resume Input">
        <div class="sja-swimlane-header">
            <h5 class="mb-0">Job/Role &amp; Resume Input</h5>
        </div>
        <div class="sja-swimlane-body">
            <div class="row g-3">
                <div class="col-12 col-lg-7">
                    <div class="card h-100">
                        <div class="card-header">Job Description</div>
                        <div class="card-body">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label">Organization</label>
                                    <input class="form-control" value="@_session.OrganizationNameSnapshot" readonly />
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Role</label>
                                    <input class="form-control" value="@_session.Role" readonly />
                                </div>
                            </div>
                            <div>
                                <label class="form-label">Role Description</label>
                                <textarea class="form-control" rows="8" readonly>@_session.RoleDescription</textarea>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-5">
                    <div class="card h-100">
                        <div class="card-header">Resume</div>
                        <div class="card-body">
                            @if (_resumeMeta is not null)
                            {
                                <div class="alert alert-success py-2 d-flex justify-content-between align-items-center mb-3">
                                    <span>📄 @_resumeMeta.Name</span>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => DownloadFileAsync(_session.BaseResumeVersionId, _resumeMeta.Name)">
                                        Download
                                    </button>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted small">File no longer in library.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ Swimlane 2: Evaluation ═══════════════════════════════════════════ -->
    <section id="hist-lane-eval" class="sja-swimlane sja-lane-eval" aria-label="Evaluation">
        <div class="sja-swimlane-header">
            <h5 class="mb-0">Match Evaluation &amp; ATS Fitting</h5>
        </div>
        <div class="sja-swimlane-body">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Match Evaluation</span>
                    <span class="badge @ScoreBadgeClass(_session.MatchScore)">@_session.MatchScore</span>
                </div>
                <div class="card-body">
                    @if (_session.MatchStrengths.Count > 0)
                    {
                        <p class="mb-1 fw-semibold text-success">Strengths:</p>
                        <ul class="mb-3">
                            @foreach (var s in _session.MatchStrengths) { <li>@s</li> }
                        </ul>
                    }
                    @if (_session.MatchGaps.Count > 0)
                    {
                        <p class="mb-1 fw-semibold">Areas needing attention:</p>
                        <ul class="mb-0">
                            @foreach (var g in _session.MatchGaps) { <li>@g</li> }
                        </ul>
                    }
                    else
                    {
                        <p class="mb-0 text-success">No significant gaps identified.</p>
                    }
                </div>
            </div>

            @if (_session.AdditionalKeywords.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-header">Additional Keywords Used</div>
                    <div class="card-body">
                        @foreach (var group in _session.AdditionalKeywords.GroupBy(k => string.IsNullOrEmpty(k.Category) ? "Other" : k.Category))
                        {
                            <p class="fw-semibold small mb-1 mt-2">@group.Key</p>
                            <div class="d-flex flex-wrap gap-2 mb-1">
                                @foreach (var kw in group)
                                {
                                    <span class="badge text-bg-secondary">@kw.Keyword</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- ══ Swimlane 3: Generated Content ════════════════════════════════════ -->
    @if (!string.IsNullOrEmpty(_session.WhyApplyText) ||
         !string.IsNullOrEmpty(_session.CoverLetterText) ||
         _session.TailoredResumeFileId is not null)
    {
        <section id="hist-lane-gen" class="sja-swimlane sja-lane-gen" aria-label="Generated Content">
            <div class="sja-swimlane-header">
                <h5 class="mb-0">Generated Customized Content</h5>
            </div>
            <div class="sja-swimlane-body">
                <div class="row g-3">
                    @if (_session.TailoredResumeFileId is not null)
                    {
                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <span>Tailored Resume</span>
                                    @if (_resumeFileMeta is not null)
                                    {
                                        <button class="btn btn-sm btn-primary"
                                                @onclick="() => DownloadFileAsync(_session.TailoredResumeFileId!, _resumeFileMeta.Name)">
                                            Download DOCX
                                        </button>
                                    }
                                </div>
                                <div class="card-body text-muted small">
                                    @(_resumeFileMeta?.Name ?? "Tailored resume saved to Files Library.")
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_session.WhyApplyText))
                    {
                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">Why Apply</div>
                                <div class="card-body">
                                    <p class="mb-0">@_session.WhyApplyText</p>
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_session.CoverLetterText))
                    {
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <span>Cover Letter</span>
                                    @if (_session.CoverLetterFileId is not null && _clMeta is not null)
                                    {
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => DownloadFileAsync(_session.CoverLetterFileId, _clMeta.Name)">
                                            Download DOCX
                                        </button>
                                    }
                                </div>
                                <div class="card-body">
                                    @foreach (var para in _session.CoverLetterText.Split(
                                        new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <p>@para</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }
}

@code {
    [Parameter] public string Id { get; set; } = "";

    SessionRecord? _session;
    StoredFileMeta? _resumeMeta;
    StoredFileMeta? _resumeFileMeta;
    StoredFileMeta? _clMeta;
    bool _loading = true;
    bool _hasGenerated;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        _session = await Db.GetSessionAsync(Id);
        if (_session is null) { _loading = false; return; }

        var allMeta = await Db.GetAllFileMetaAsync();
        var metaMap = allMeta.ToDictionary(f => f.Id);

        metaMap.TryGetValue(_session.BaseResumeVersionId, out _resumeMeta);
        if (_session.TailoredResumeFileId is not null)
            metaMap.TryGetValue(_session.TailoredResumeFileId, out _resumeFileMeta);
        if (_session.CoverLetterFileId is not null)
            metaMap.TryGetValue(_session.CoverLetterFileId, out _clMeta);

        _hasGenerated = _session.ArtifactsGenerated;

        _loading = false;
    }

    Task ScrollToAsync(string id) => JS.InvokeVoidAsync("sjaScrollTo", id).AsTask();

    async Task DownloadFileAsync(string? fileId, string fileName)
    {
        if (fileId is null) return;
        var file = await Db.GetFileAsync(fileId);
        if (file is null) { _error = "File no longer in storage."; return; }
        await Db.DownloadFileAsync(fileName, Convert.FromBase64String(file.DataBase64));
    }

    static string ScoreBadgeClass(string score) => score switch
    {
        "Excellent" => "bg-success",
        "Good"      => "bg-primary",
        "Fair"      => "bg-warning text-dark",
        _           => "bg-danger",
    };
}
