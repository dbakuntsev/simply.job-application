@page "/history/{Id}"
@implements IAsyncDisposable
@inject IIndexedDbService Db
@inject IDocxService Docx
@inject IAiProviderFactory Providers
@inject IDataSyncService DataSync
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Session Detail — Simply Opportunity Tracker</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"></div></div>
}
else if (_session is null)
{
    <div class="alert alert-warning">Session not found.</div>
    <a href="history" class="btn btn-secondary">Back to History</a>
}
else
{
    <!-- ── Secondary nav bar ────────────────────────────────────────────────── -->
    <div class="sja-progress-bar" role="navigation" aria-label="Session sections">
        <nav class="sja-steps" aria-label="Steps">
            <div class="sja-step completed" role="button" style="cursor:pointer"
                 @onclick="@(() => ScrollToAsync("hist-lane-input"))">
                <span class="sja-step-icon" aria-hidden="true">✓</span>
                <span>Input</span>
            </div>
            <div class="sja-step-connector" aria-hidden="true"></div>
            <div class="sja-step completed" role="button" style="cursor:pointer"
                 @onclick="@(() => ScrollToAsync("hist-lane-eval"))">
                <span class="sja-step-icon" aria-hidden="true">✓</span>
                <span>Evaluation</span>
            </div>
            <div class="sja-step-connector" aria-hidden="true"></div>
            <div class="sja-step @(_session.ArtifactsGenerated ? "completed" : "")" role="button" style="cursor:pointer"
                 @onclick="@(() => ScrollToAsync("hist-lane-gen"))">
                @if (_session.ArtifactsGenerated) { <span class="sja-step-icon" aria-hidden="true">✓</span> }
                <span>Generation</span>
            </div>
        </nav>
        <div class="d-flex align-items-center gap-2 ms-auto flex-shrink-0">
            <span class="badge @ScoreBadgeClass(_session.MatchScore)">@_session.MatchScore</span>
            <small class="text-muted d-none d-sm-inline">@_session.CreatedAt.ToLocalTime().ToString("g")</small>
            @if (_isAdHoc)
            {
                <button class="btn btn-outline-danger btn-sm" @onclick="RequestDelete">Delete</button>
            }
            <a href="history" class="btn btn-outline-secondary btn-sm">← Back</a>
        </div>
    </div>

    <!-- ── Page title ────────────────────────────────────────────────────────── -->
    <h4 class="mb-3 mt-3">
        @if (_orgDisplay.Url is not null)
        {
            <a href="@_orgDisplay.Url">@_orgDisplay.Text</a>
        }
        else
        {
            @_orgDisplay.Text
        }
        @if (!string.IsNullOrEmpty(_session.Role))
        {
            <span> — @_session.Role</span>
        }
    </h4>

    <!-- ══ Swimlane 1: Input ════════════════════════════════════════════════ -->
    <section id="hist-lane-input" class="sja-swimlane sja-lane-input" aria-label="Job and Resume Input">
        <div class="sja-swimlane-header">
            <h5 class="mb-0">Job/Role &amp; Resume Input</h5>
        </div>
        <div class="sja-swimlane-body">
            <div class="row g-3">
                <div class="col-12 col-lg-7">
                    <div class="card h-100">
                        <div class="card-header">Job Details</div>
                        <div class="card-body">
                            <div class="row g-2 mb-3">
                                <div class="col-sm-6">
                                    <p class="text-muted small mb-0">Organization</p>
                                    @if (_orgDisplay.Url is not null)
                                    {
                                        <a href="@_orgDisplay.Url">@_orgDisplay.Text</a>
                                    }
                                    else
                                    {
                                        <span>@_orgDisplay.Text</span>
                                    }
                                </div>
                                <div class="col-sm-6">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="text-muted small mb-0">Opportunity</p>
                                        @if (_session.OpportunityId is null)
                                        {
                                            <button class="btn btn-sm btn-outline-primary py-0"
                                                    @onclick="() => _showSaveOppModal = true">
                                                Save Opportunity
                                            </button>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(_oppDisplay.Text))
                                    {
                                        @if (_oppDisplay.Url is not null)
                                        {
                                            <a href="@_oppDisplay.Url">@_oppDisplay.Text</a>
                                        }
                                        else
                                        {
                                            <span>@_oppDisplay.Text</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </div>
                                <div class="col-sm-6">
                                    <p class="text-muted small mb-0">Role</p>
                                    <span>@_session.Role</span>
                                </div>
                                <div class="col-sm-6">
                                    <p class="text-muted small mb-0">Created</p>
                                    <span>@_session.CreatedAt.ToLocalTime().ToString("g")</span>
                                </div>
                            </div>
                            <div>
                                <p class="text-muted small mb-1">Role Description</p>
                                <div style="max-height:200px;overflow-y:auto;white-space:pre-wrap;background:#f8f9fa;padding:0.5rem;border-radius:0.25rem;font-size:0.9rem;">@_session.RoleDescription</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-12 col-lg-5">
                    <div class="card h-100">
                        <div class="card-header">Resume</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <p class="text-muted small mb-0">Base Resume</p>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span>@_resumeDisplayName</span>
                                    @if (_resumeVersion is not null)
                                    {
                                        <button class="btn btn-sm btn-outline-primary ms-2"
                                                @onclick="DownloadBaseResumeAsync">
                                            Download
                                        </button>
                                    }
                                </div>
                            </div>
                            @if (_session.TailoredResumeFileId is not null)
                            {
                                <div>
                                    <p class="text-muted small mb-0">Tailored Resume</p>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-success">✓ Generated</span>
                                        <div class="d-flex gap-2 ms-2">
                                            @if (_resumeVersion is not null)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="StartCompareAsync">
                                                    Compare
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="DownloadTailoredResumeAsync">
                                                Download DOCX
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ Swimlane 2: Evaluation ═══════════════════════════════════════════ -->
    <section id="hist-lane-eval" class="sja-swimlane sja-lane-eval" aria-label="Evaluation">
        <div class="sja-swimlane-header">
            <h5 class="mb-0">Match Evaluation &amp; ATS Fitting</h5>
        </div>
        <div class="sja-swimlane-body">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Match Evaluation</span>
                    <span class="badge @ScoreBadgeClass(_session.MatchScore)">@_session.MatchScore</span>
                </div>
                <div class="card-body">
                    @if (_session.MatchStrengths.Count > 0)
                    {
                        <p class="mb-1 fw-semibold text-success">Strengths:</p>
                        <ul class="mb-3">
                            @foreach (var s in _session.MatchStrengths) { <li>@s</li> }
                        </ul>
                    }
                    @if (_session.MatchGaps.Count > 0)
                    {
                        <p class="mb-1 fw-semibold">Areas needing attention:</p>
                        <ul class="mb-0">
                            @foreach (var g in _session.MatchGaps) { <li>@g</li> }
                        </ul>
                    }
                    else
                    {
                        <p class="mb-0 text-success">No significant gaps identified.</p>
                    }
                </div>
            </div>

            @if (_session.AdditionalKeywords.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-header">Additional Keywords Used</div>
                    <div class="card-body">
                        @foreach (var group in _session.AdditionalKeywords.GroupBy(k => string.IsNullOrEmpty(k.Category) ? "Other" : k.Category))
                        {
                            <p class="fw-semibold small mb-1 mt-2">@group.Key</p>
                            <div class="d-flex flex-wrap gap-2 mb-1">
                                @foreach (var kw in group)
                                {
                                    <span class="badge text-bg-secondary">@kw.Keyword</span>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- ══ Swimlane 3: Generated Content ════════════════════════════════════ -->
    @if (_session.ArtifactsGenerated ||
         !string.IsNullOrEmpty(_session.WhyApplyText) ||
         !string.IsNullOrEmpty(_session.CoverLetterText) ||
         _session.TailoredResumeFileId is not null)
    {
        <section id="hist-lane-gen" class="sja-swimlane sja-lane-gen" aria-label="Generated Content">
            <div class="sja-swimlane-header">
                <h5 class="mb-0">Generated Customized Content</h5>
            </div>
            <div class="sja-swimlane-body">
                <div class="row g-3">
                    @if (!string.IsNullOrEmpty(_session.WhyApplyText))
                    {
                        <div class="col-12 col-lg-6">
                            <div class="card h-100">
                                <div class="card-header">Why Apply</div>
                                <div class="card-body">
                                    @foreach (var para in _session.WhyApplyText.Split(
                                        new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <p class="mb-1">@para</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(_session.CoverLetterText))
                    {
                        <div class="col-12 @(!string.IsNullOrEmpty(_session.WhyApplyText) ? "col-lg-6" : "")">
                            <div class="card h-100">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <span>Cover Letter</span>
                                    @if (_session.CoverLetterFileId is not null)
                                    {
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="DownloadCoverLetterAsync">
                                            Download DOCX
                                        </button>
                                    }
                                </div>
                                <div class="card-body">
                                    @foreach (var para in _session.CoverLetterText.Split(
                                        new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <p>@para</p>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (_session.ArtifactsGenerated)
                    {
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <span>Questions &amp; Answers</span>
                                    <button class="btn btn-sm btn-outline-primary"
                                            disabled="@AnyQaGenerating"
                                            @onclick="() => { _qaRegenerateEntry = null; _showAskQuestionModal = true; }">
                                        Ask Question
                                    </button>
                                </div>
                                <div class="card-body">
                                    @if (_session.Questions.Count == 0)
                                    {
                                        <p class="text-muted small mb-0">No questions yet. Click "Ask Question" to generate a tailored answer.</p>
                                    }
                                    else
                                    {
                                        <div class="list-group list-group-flush">
                                            @foreach (var qa in _session.Questions)
                                            {
                                                var entry = qa;
                                                <div class="list-group-item px-0 d-flex align-items-center gap-2">
                                                    <button class="flex-grow-1 btn btn-link text-start p-0 text-decoration-none text-body"
                                                            style="min-width:0;overflow:hidden"
                                                            disabled="@(entry.Status == QuestionAnswerStatus.Generating)"
                                                            @onclick="() => OpenQaDetailModal(entry)">
                                                        <span class="fw-semibold" style="max-width:40%;display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;vertical-align:bottom">@entry.QuestionText</span>
                                                        <span class="text-muted mx-1">—</span>
                                                        @if (entry.Status == QuestionAnswerStatus.Generating)
                                                        {
                                                            <span class="spinner-border spinner-border-sm text-secondary" role="status" aria-label="Generating…"></span>
                                                        }
                                                        else if (entry.Status == QuestionAnswerStatus.Error)
                                                        {
                                                            <span class="text-danger small">Generation failed</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted small" style="display:inline-block;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;vertical-align:bottom">@entry.AnswerText</span>
                                                        }
                                                    </button>
                                                    <div class="d-flex gap-1 flex-shrink-0">
                                                        <button class="btn btn-sm btn-outline-secondary"
                                                                title="@(entry.Status == QuestionAnswerStatus.Error ? "Retry" : "Regenerate")"
                                                                disabled="@AnyQaGenerating"
                                                                @onclick="() => OpenRegenerateModal(entry)"
                                                                aria-label="Regenerate answer">
                                                            ↺
                                                        </button>
                                                        <button class="btn btn-sm btn-outline-danger"
                                                                title="Delete"
                                                                disabled="@(entry.Status == QuestionAnswerStatus.Generating)"
                                                                @onclick="async () => await DeleteQuestionAsync(entry)"
                                                                aria-label="Delete question">
                                                            ✕
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }

    @if (_error is not null)
    {
        <div class="alert alert-danger mt-3">@_error</div>
    }
}

<ResumeDiffModal Show="@_showDiff"
                 OriginalText="@_diffOriginal"
                 ModifiedText="@_diffModified"
                 FooterLabel="@_diffFooterLabel"
                 OnClose="@(() => _showDiff = false)" />

<ConfirmDeleteModal Show="@_showDeleteModal"
                    Title="Delete Session"
                    Message="Delete this session and its generated files? This action cannot be undone."
                    DeleteLabel="Delete"
                    OnConfirm="ConfirmDeleteAsync"
                    OnCancel="CancelDelete" />

<DeletionAlertModal Show="@_showDeletionAlert"
                    Message="@_deletionMessage"
                    OnDismiss="HandleDeletionDismiss" />

<AskQuestionModal Show="@_showAskQuestionModal"
                  Title="@(_qaRegenerateEntry is null ? "Ask Question" : "Regenerate Answer")"
                  Prefill="@_qaRegenerateEntry"
                  EstimateLength="@EstimateLengthAsync"
                  OnCancel="@(() => { _showAskQuestionModal = false; _qaRegenerateEntry = null; })"
                  OnSubmit="@(async req => await HandleAskQuestionSubmitAsync(req))" />

<QuestionAnswerDetailModal Show="@_showQaDetailModal"
                           Entry="@_qaDetailEntry"
                           OnClose="@(() => { _showQaDetailModal = false; _qaDetailEntry = null; })" />

@if (_session is not null)
{
    <SaveOpportunityModal @bind-Show="_showSaveOppModal"
                          Role="@_session.Role"
                          RoleDescription="@_session.RoleDescription"
                          SuggestedOrgName="@_session.OrganizationNameSnapshot"
                          LinkedOrgId="@_session.OrganizationId"
                          LinkedOrgName="@(_session.OrganizationId is null ? null : _session.OrganizationNameSnapshot)"
                          OnSaved="HandleOpportunitySavedAsync" />
}

@code {
    [Parameter] public string Id { get; set; } = "";

    SessionRecord? _session;
    BaseResumeVersion? _resumeVersion;
    string _resumeDisplayName = "";
    SessionDisplayHelper.EntityDisplay _orgDisplay = new("", null);
    SessionDisplayHelper.EntityDisplay _oppDisplay = new("", null);
    Dictionary<string, OrganizationProjection> _orgMap = new();
    Dictionary<string, OpportunityProjection> _oppMap = new();
    bool _isAdHoc;
    bool _loading = true;
    bool _showDeleteModal;
    bool _showDeletionAlert;
    bool _showDiff;
    string _diffOriginal = "";
    string _diffModified = "";
    string _diffFooterLabel = "";
    string _deletionMessage = "";
    string? _error;

    bool _showAskQuestionModal;
    bool _showQaDetailModal;
    bool _showSaveOppModal;
    QuestionAnswerEntry? _qaDetailEntry;
    QuestionAnswerEntry? _qaRegenerateEntry;

    bool AnyQaGenerating => _session?.Questions.Any(q => q.Status == QuestionAnswerStatus.Generating) ?? false;

    protected override async Task OnInitializedAsync()
    {
        _session = await Db.GetSessionAsync(Id);
        if (_session is null) { _loading = false; return; }

        // Resolve base resume
        if (!string.IsNullOrEmpty(_session.BaseResumeVersionId))
        {
            _resumeVersion = await Db.GetBaseResumeVersionAsync(_session.BaseResumeVersionId);
            string? resumeName = null;
            if (_resumeVersion is not null)
            {
                var resume = await Db.GetBaseResumeAsync(_resumeVersion.ResumeId);
                resumeName = resume?.Name;
            }
            _resumeDisplayName = SessionDisplayHelper.ResolveResumeName(_session, resumeName);
        }
        else
        {
            _resumeDisplayName = SessionDisplayHelper.ResolveResumeName(_session, null);
        }

        // Resolve org / opp for §2.10 display
        var orgProj = await Db.GetOrganizationProjectionsAsync();
        _orgMap = orgProj.ToDictionary(o => o.Id);
        var oppProj = await Db.GetOpportunityProjectionsAsync();
        _oppMap = oppProj.ToDictionary(o => o.Id);
        _orgDisplay = SessionDisplayHelper.ResolveOrg(_session, _orgMap);
        _oppDisplay = SessionDisplayHelper.ResolveOpp(_session, _oppMap);

        _isAdHoc = _session.OrganizationId is null;
        _loading = false;

        DataSync.OnSessionChanged += HandleSessionChanged;
        DataSync.OnOrganizationChanged += HandleOrgChanged;
        DataSync.OnOpportunityChanged += HandleOppChanged;
    }

    private Task ScrollToAsync(string id) => JS.InvokeVoidAsync("sjaScrollTo", id).AsTask();

    private void RequestDelete() => _showDeleteModal = true;
    private void CancelDelete() => _showDeleteModal = false;

    private async Task ConfirmDeleteAsync()
    {
        if (_session is null) return;
        _showDeleteModal = false;

        if (_session.TailoredResumeFileId is not null)
            await Db.DeleteFileAsync(_session.TailoredResumeFileId);
        if (_session.CoverLetterFileId is not null)
            await Db.DeleteFileAsync(_session.CoverLetterFileId);
        await Db.DeleteSessionAsync(_session.Id);
        await DataSync.BroadcastAsync("session", _session.Id, "deleted");
        Nav.NavigateTo("history");
    }

    private async Task StartCompareAsync()
    {
        if (_resumeVersion is null || _session?.TailoredResumeFileId is null) return;

        _diffOriginal = Docx.ExtractTextAsMarkdown(Convert.FromBase64String(_resumeVersion.FileDataBase64));

        if (!string.IsNullOrEmpty(_session.TailoredResumeMarkdown))
        {
            _diffModified = _session.TailoredResumeMarkdown;
        }
        else
        {
            var tailored = await Db.GetFileAsync(_session.TailoredResumeFileId);
            if (tailored is null) { _error = "Tailored resume file no longer in storage."; return; }
            _diffModified = Docx.ExtractTextAsMarkdown(Convert.FromBase64String(tailored.DataBase64));
        }
        _diffFooterLabel = $"Left: {_session.BaseResumeNameSnapshot} v{_session.BaseResumeVersionNumberSnapshot}  |  Right: Tailored Resume";
        _showDiff = true;
    }

    private async Task DownloadBaseResumeAsync()
    {
        if (_resumeVersion is null) return;
        var name = string.IsNullOrEmpty(_resumeVersion.FileName)
            ? $"{_session!.BaseResumeNameSnapshot}.docx"
            : _resumeVersion.FileName;
        await Db.DownloadGenericFileAsync(name, _resumeVersion.FileDataBase64);
    }

    private async Task DownloadTailoredResumeAsync()
    {
        if (_session?.TailoredResumeFileId is null) return;
        var file = await Db.GetFileAsync(_session.TailoredResumeFileId);
        if (file is null) { _error = "Tailored resume file no longer in storage."; return; }
        await Db.DownloadFileAsync(file.Name, Convert.FromBase64String(file.DataBase64));
    }

    private async Task DownloadCoverLetterAsync()
    {
        if (_session?.CoverLetterFileId is null) return;
        var file = await Db.GetFileAsync(_session.CoverLetterFileId);
        if (file is null) { _error = "Cover letter file no longer in storage."; return; }
        await Db.DownloadFileAsync(file.Name, Convert.FromBase64String(file.DataBase64));
    }

    private void HandleSessionChanged(string? id, string @event)
    {
        if (id == _session?.Id && @event == "deleted")
            InvokeAsync(() =>
            {
                _deletionMessage = "This session was deleted in another tab.";
                _showDeletionAlert = true;
                StateHasChanged();
                return Task.CompletedTask;
            });
    }

    private void HandleOrgChanged(string? id, string @event)
    {
        if (@event == "deleted" && id == _session?.OrganizationId)
            InvokeAsync(() =>
            {
                var name = _session?.OrganizationNameSnapshot ?? "Unknown";
                _deletionMessage = $"Organization '{name}' was deleted in another tab. This session no longer exists.";
                _showDeletionAlert = true;
                StateHasChanged();
                return Task.CompletedTask;
            });
    }

    private void HandleOppChanged(string? id, string @event)
    {
        if (@event == "deleted" && id == _session?.OpportunityId)
            InvokeAsync(() =>
            {
                var role = _session?.OpportunityRoleSnapshot ?? "Unknown";
                _deletionMessage = $"Opportunity '{role}' was deleted in another tab. This session no longer exists.";
                _showDeletionAlert = true;
                StateHasChanged();
                return Task.CompletedTask;
            });
    }

    private void HandleDeletionDismiss() => Nav.NavigateTo("history");

    // ── Save Opportunity ─────────────────────────────────────────────────────

    private async Task HandleOpportunitySavedAsync(SaveOpportunityModal.SaveResult result)
    {
        if (_session is null) return;

        _session.OrganizationId           = result.OrganizationId;
        _session.OrganizationNameSnapshot = result.OrganizationName;
        _session.OpportunityId            = result.OpportunityId;
        _session.OpportunityRoleSnapshot  = result.OpportunityRole;
        _session.Version++;
        await Db.SaveSessionAsync(_session);
        await DataSync.BroadcastAsync("session", _session.Id, "updated");

        if (result.CreatedNewOrganization || result.CreatedNewOpportunity)
        {
            var orgProj = await Db.GetOrganizationProjectionsAsync();
            _orgMap = orgProj.ToDictionary(o => o.Id);
            var oppProj = await Db.GetOpportunityProjectionsAsync();
            _oppMap = oppProj.ToDictionary(o => o.Id);
        }
        _orgDisplay = SessionDisplayHelper.ResolveOrg(_session, _orgMap);
        _oppDisplay = SessionDisplayHelper.ResolveOpp(_session, _oppMap);
        _isAdHoc = _session.OrganizationId is null;

        StateHasChanged();
    }

    // ── Q&A handlers ─────────────────────────────────────────────────────────

    private void OpenQaDetailModal(QuestionAnswerEntry entry)
    {
        _qaDetailEntry = entry;
        _showQaDetailModal = true;
    }

    private void OpenRegenerateModal(QuestionAnswerEntry entry)
    {
        _qaRegenerateEntry = entry;
        _showAskQuestionModal = true;
    }

    private async Task HandleAskQuestionSubmitAsync(AskQuestionModal.AskQuestionRequest req)
    {
        if (_session is null) return;
        _showAskQuestionModal = false;

        if (_qaRegenerateEntry is not null)
        {
            var entry = _qaRegenerateEntry;
            _qaRegenerateEntry = null;
            entry.QuestionText             = req.Question;
            entry.Tone                     = req.Tone;
            entry.LengthValue              = req.LengthValue;
            entry.LengthUnit               = req.LengthUnit;
            entry.SuggestedLengthValue     = req.Estimate?.Value;
            entry.SuggestedLengthUnit      = req.Estimate?.Unit;
            entry.SuggestedLengthRationale = req.Estimate?.Rationale;
            entry.AnswerText               = null;
            entry.Status                   = QuestionAnswerStatus.Generating;
            entry.ErrorMessage             = null;
            StateHasChanged();
            await RunQaGenerationAsync(entry);
        }
        else
        {
            var entry = new QuestionAnswerEntry
            {
                QuestionText             = req.Question,
                Tone                     = req.Tone,
                LengthValue              = req.LengthValue,
                LengthUnit               = req.LengthUnit,
                SuggestedLengthValue     = req.Estimate?.Value,
                SuggestedLengthUnit      = req.Estimate?.Unit,
                SuggestedLengthRationale = req.Estimate?.Rationale,
            };
            _session.Questions.Add(entry);
            StateHasChanged();
            await RunQaGenerationAsync(entry);
        }
    }

    // Invoked from AskQuestionModal when the user clicks "Estimate Length".
    // Looks up the current provider/model/key from settings and dispatches.
    private async Task<AnswerLengthEstimate> EstimateLengthAsync(AskQuestionModal.EstimateLengthRequest req)
    {
        if (_session is null) throw new InvalidOperationException("Session not loaded");

        var settings = await Db.GetSettingsAsync();
        var apiKey   = settings.ProviderApiKeys.GetValueOrDefault(settings.AiProvider) ?? "";
        var modelId  = settings.ProviderModels.GetValueOrDefault(settings.AiProvider)
                       ?? Providers.Get(settings.AiProvider).DefaultModelId;
        var provider = Providers.Get(settings.AiProvider);

        return await provider.EstimateAnswerLengthAsync(
            questionText:    req.Question,
            tone:            req.Tone,
            orgName:         _session.OrganizationNameSnapshot,
            roleName:        _session.Role,
            roleDescription: _session.RoleDescription,
            modelId:         modelId,
            apiKey:          apiKey);
    }

    private async Task RunQaGenerationAsync(QuestionAnswerEntry entry)
    {
        if (_session is null) return;
        try
        {
            var settings = await Db.GetSettingsAsync();
            var apiKey   = settings.ProviderApiKeys.GetValueOrDefault(settings.AiProvider) ?? "";
            var modelId  = settings.ProviderModels.GetValueOrDefault(settings.AiProvider)
                           ?? Providers.Get(settings.AiProvider).DefaultModelId;
            var provider = Providers.Get(settings.AiProvider);

            string? orgDescription = null;
            if (_session.OrganizationId is not null)
            {
                var org = await Db.GetOrganizationAsync(_session.OrganizationId);
                orgDescription = org?.Description?.Trim() is { Length: > 0 } d ? d : null;
            }

            entry.AnswerText = await provider.AnswerQuestionAsync(
                entry.QuestionText,
                entry.Tone,
                entry.LengthValue,
                entry.LengthUnit,
                _session.OrganizationNameSnapshot,
                orgDescription,
                _session.Role,
                _session.RoleDescription,
                _session.TailoredResumeMarkdown,
                modelId,
                apiKey);

            entry.Status = QuestionAnswerStatus.Done;
        }
        catch (Exception ex)
        {
            entry.Status       = QuestionAnswerStatus.Error;
            entry.ErrorMessage = ex.Message;
        }
        finally
        {
            StateHasChanged();
            _session.Version++;
            await Db.SaveSessionAsync(_session);
            await DataSync.BroadcastAsync("session", _session.Id, "updated");
        }
    }

    private async Task DeleteQuestionAsync(QuestionAnswerEntry entry)
    {
        if (_session is null || entry.Status == QuestionAnswerStatus.Generating) return;
        _session.Questions.Remove(entry);
        _session.Version++;
        await Db.SaveSessionAsync(_session);
        await DataSync.BroadcastAsync("session", _session.Id, "updated");
    }

    public async ValueTask DisposeAsync()
    {
        DataSync.OnSessionChanged -= HandleSessionChanged;
        DataSync.OnOrganizationChanged -= HandleOrgChanged;
        DataSync.OnOpportunityChanged -= HandleOppChanged;
        await Task.CompletedTask;
    }

    private static string ScoreBadgeClass(string score) => score switch
    {
        "Excellent" => "bg-success",
        "Good"      => "bg-primary",
        "Fair"      => "bg-warning text-dark",
        _           => "bg-danger",
    };
}
