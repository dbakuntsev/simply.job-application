@if (Show)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true"
         style="background:rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Record Changed</h5>
                </div>
                <div class="modal-body">@Message</div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="OnDiscardAndReload">Discard &amp; Reload</button>
                    <button class="btn btn-outline-secondary" @onclick="OnKeepEditing">Keep Editing</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public EventCallback OnDiscardAndReload { get; set; }
    [Parameter] public EventCallback OnKeepEditing { get; set; }
}
