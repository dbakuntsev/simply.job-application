@inject IPwaService Pwa
@implements IDisposable

@if (Pwa.UpdateAvailable && !_dismissed)
{
    <div class="pwa-update-banner" role="alert">
        <div class="container-fluid d-flex align-items-center gap-3 py-2 px-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                 viewBox="0 0 16 16" aria-hidden="true" class="flex-shrink-0 opacity-75">
                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
            </svg>
            <span class="flex-grow-1 small">A new version of Simply Opportunity Tracker is available.</span>
            <button class="btn btn-sm btn-light fw-semibold" @onclick="ReloadAsync">Reload now</button>
            <button type="button" class="btn-close btn-close-white" @onclick="Dismiss" aria-label="Dismiss update notification"></button>
        </div>
    </div>
}

@code {
    private bool _dismissed;

    protected override void OnInitialized() => Pwa.StateChanged += OnStateChanged;

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private async Task ReloadAsync() => await Pwa.ApplyUpdateAsync();

    private void Dismiss() => _dismissed = true;

    public void Dispose() => Pwa.StateChanged -= OnStateChanged;
}
