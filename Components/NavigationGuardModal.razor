@if (Show)
{
    <div class="modal d-block" tabindex="-1" role="dialog" aria-modal="true"
         style="background:rgba(0,0,0,.45);z-index:1060">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Unsaved Changes</h5>
                </div>
                <div class="modal-body">
                    You have unsaved changes. What would you like to do?
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="OnStay">@StayLabel</button>
                    <button class="btn btn-outline-secondary" @onclick="OnLeave">@LeaveLabel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public string StayLabel { get; set; } = "Stay";
    [Parameter] public string LeaveLabel { get; set; } = "Leave";
    [Parameter] public EventCallback OnStay { get; set; }
    [Parameter] public EventCallback OnLeave { get; set; }
}
